---
import Base from '../layouts/Base.astro';

const branches = [
  {
    name: 'research',
    items: [
      {
        title: 'Trust Bench',
        desc: 'Open-source tool for profiling LLM trustworthiness,extract trust signals, evaluate, diagnose failures, and improve models.',
        tags: ['AI safety', 'interpretability', 'PyTorch', 'LLM evaluation'],
        details: {
          problem: 'Evaluation tools score model outputs but none connect trust scores to what\'s happening inside the model. The closed loop,profile, diagnose, fix, verify,doesn\'t exist as open-source infrastructure.',
          approach: 'Extract internal trust signals (logprobs, entropy, layer activations per attention type) from models with full architectural access. Score across TrustLLM dimensions. Apply targeted improvements (RepE, calibration, Constitutional AI). Re-evaluate.',
          stack: 'Python, PyTorch, lm-eval-harness, TrustLLM datasets',
          outcome: 'In progress. First target: Qwen3.5 0.8B hybrid attention architecture,studying how trust signals differ across linear vs full attention layers.',
        },
      },
    ],
  },
  {
    name: 'writing',
    items: [
      {
        title: 'Understanding LLMs From Scratch',
        desc: 'How large language models work,from raw text to trained model,in 200 lines of Python.',
        tags: ['deep learning', 'transformers'],
        url: '/writing/understanding-llms',
        details: {
          problem: 'Most LLM explanations are either too abstract or assume deep ML knowledge. Needed a middle-ground walkthrough.',
          approach: 'Build a working transformer from scratch. Cover tokenization, embeddings, attention, backpropagation, training, and inference with code and ASCII diagrams.',
          stack: 'Python, PyTorch',
          outcome: 'Complete working implementation with explanations aimed at people who want to understand the mechanics, not just the API.',
        },
      },
    ],
  },
];
---

<Base title="Projects,Amaljith Kuttamath" description="AI/NLP projects, data engineering pipelines, and technical writing.">
  <div class="page-header animate-in">
    <h1>Projects</h1>
    <p class="subtitle">Things I've built, organized the way I think about them.</p>
  </div>

  <div class="git-tree animate-in animate-in-delay-1">
    {branches.map((branch) => (
      <div class="git-branch">
        <div class="branch-label">{branch.name}</div>
        {branch.items.map((item) => (
          <div class="git-commit">
            <h3>
              {item.url
                ? <a href={item.url}>{item.title}</a>
                : item.title}
            </h3>
            <p>{item.desc}</p>
            <div class="tags">
              {item.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
            {item.details && (
              <details class="commit-details">
                <summary>read more</summary>
                <div class="details-grid">
                  <div class="detail-row">
                    <span class="detail-label">Problem</span>
                    <span class="detail-value">{item.details.problem}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Approach</span>
                    <span class="detail-value">{item.details.approach}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Stack</span>
                    <span class="detail-value detail-stack">{item.details.stack}</span>
                  </div>
                  <div class="detail-row">
                    <span class="detail-label">Outcome</span>
                    <span class="detail-value">{item.details.outcome}</span>
                  </div>
                </div>
              </details>
            )}
          </div>
        ))}
      </div>
    ))}
  </div>
</Base>
