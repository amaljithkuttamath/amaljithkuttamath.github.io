---
import Base from '../layouts/Base.astro';

// Apps: things people return to.
const apps = [
  {
    href: '/apps/tokenizer',
    title: 'Tokenizer Arena',
    tagline: 'Watch five real tokenizers shred your text differently.',
    tag: 'live',
  },
  {
    href: '/apps/pdf-lens',
    title: 'PDF Lens',
    tagline: 'Drop a PDF, get clean text + token cost, all in your browser.',
    tag: 'wasm',
  },
  {
    href: '/apps/probability-xray',
    title: 'Probability X-ray',
    tagline: 'Chat with a local model, see the confidence behind every word.',
    tag: 'webgpu',
  },
  {
    href: '/apps/gguf-inspect',
    title: 'GGUF Inspect',
    tagline: 'Paste a GGUF URL. Get architecture, quantization, and memory fit.',
    tag: 'llama.cpp',
  },
];

// Lab: educational demos.
const lab = [
  {
    href: '/lab/microgpt',
    title: 'microGPT Trainer',
    tagline: 'Train a tiny transformer live, watch every component learn.',
  },
  {
    href: '/lab/watch-model-think',
    title: 'Watch a Model Think',
    tagline: 'Step through GPT-2 token by token: features, calibration, loops.',
  },
];
---

<Base
  title="Amaljith Kuttamath"
  description="AI Engineer. I help teams ship AI they can trust in production — with evaluation, confidence, and verification built in. Small, sharp tools that make language models legible."
>
  <section class="intro animate-in">
    <p class="kicker">AI Engineer &middot; Trustworthy AI in production</p>
    <h1 class="tagline">
      I help teams ship AI they can trust in production &mdash; and show them
      why it works.
    </h1>
    <p class="lede">
      I build small tools that make language models legible &mdash; what they
      see, how sure they are, and where they break. The same rigor goes into
      what I ship for you.
    </p>
    <div class="cta-row">
      <a href="/build" class="cta-primary">See how I work &rarr;</a>
      <a href="/resume.pdf" class="cta-ghost">R&eacute;sum&eacute; (PDF)</a>
      <span class="avail">
        <span class="avail-dot" aria-hidden="true"></span>
        Open to senior roles &amp; a few project builds
      </span>
    </div>
  </section>

  {/* The page used to CLAIM "everything below runs in your browser" and then
      show cards describing software. This runs a real tokenizer instead, on
      load, before any click. The claim and the proof are the same object.
      If the vocabulary cannot be fetched, the block removes itself rather
      than showing a plausible-looking fake split. */}
  <section class="proof animate-in animate-in-delay-1" id="proof" hidden>
    <div class="proof-bar">
      <span class="live-dot" aria-hidden="true"></span>
      <span>running in your browser</span>
      <span class="proof-meta" id="proof-meta">loading GPT-4o vocabulary…</span>
    </div>
    <div class="proof-stage">
      <p class="proof-src" id="proof-src"></p>
      <div class="proof-tokens" id="proof-tokens" aria-label="The sentence above, split into tokens"></div>
      <p class="proof-cap" id="proof-cap"></p>
      <a href="/apps/tokenizer" class="proof-try">Type your own &rarr;</a>
    </div>
  </section>

  <section class="lane animate-in animate-in-delay-1" aria-labelledby="lane-apps">
    <div class="lane-head">
      <h2 id="lane-apps" class="lane-label">Apps</h2>
      <span class="lane-hint">things you'll use again</span>
    </div>
    {/* One lead, then a scannable index. Eleven near-identical cards meant the
        eye skimmed all of them and the strongest proof competed on equal
        footing with the rest. Chitti keeps card weight; everything else drops
        to a row so it can be read in one pass instead of chosen between. */}
    <a href="/apps/chitti" class="featured-card">
      <div class="featured-main">
        <div class="featured-head">
          <span class="featured-title">Chitti</span>
          <span class="featured-tag">deep-agent</span>
        </div>
        <p class="featured-tagline">Ask about the world. Get real numbers, cited.</p>
        <p class="featured-sub">
          A browser-only agent over the World Bank Open Data API. It plans,
          fetches, charts, and verifies its own answer. Bring your own key.
        </p>
      </div>
      <span class="featured-cta">Open Chitti &rarr;</span>
    </a>
    <div class="app-index">
      {apps.map((a) => (
        <a href={a.href} class="app-row">
          <span class="app-row-title">{a.title}</span>
          <span class="app-row-desc">{a.tagline}</span>
          <span class="app-row-tag">{a.tag}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="lane animate-in animate-in-delay-2" aria-labelledby="lane-radar">
    <div class="lane-head">
      <h2 id="lane-radar" class="lane-label">Radar</h2>
      <span class="lane-hint">a daily read of the AI field</span>
    </div>
    <a href="/radar" class="radar-strip">
      <div class="radar-strip-main">
        <span class="live-dot" aria-hidden="true"></span>
        <span class="radar-title">AI Radar</span>
        <span class="radar-sub">
          ~30 sources collected, scored, graded, one digest per day
        </span>
      </div>
      <span class="radar-cta">Open board &rarr;</span>
    </a>
  </section>

  <section class="lane animate-in animate-in-delay-2" aria-labelledby="lane-lab">
    <div class="lane-head">
      <h2 id="lane-lab" class="lane-label">Lab</h2>
      <span class="lane-hint">experiments, one idea each</span>
    </div>
    <div class="lab-list">
      {lab.map((l) => (
        <a href={l.href} class="lab-item">
          <span class="lab-title">{l.title}</span>
          <span class="lab-tagline">{l.tagline}</span>
        </a>
      ))}
    </div>
  </section>
  <script is:inline type="module">
    // The proof block loads a REAL vocabulary and runs a REAL split, the same
    // way /apps/tokenizer does. It is hidden until that succeeds: a hardcoded
    // split shown under the words "running in your browser" would be a lie in
    // the one place the site is claiming it never fabricates. Failure removes
    // the block instead of degrading to a plausible fake.
    const SENTENCE = 'Shipping AI you can trust means being able to show why it works.';
    const el = (id) => document.getElementById(id);

    try {
      const { AutoTokenizer, env } = await import(
        'https://cdn.jsdelivr.net/npm/@huggingface/transformers@3'
      );
      env.allowLocalModels = false;
      const tok = await AutoTokenizer.from_pretrained('Xenova/gpt-4o');
      const ids = tok.encode(SENTENCE);
      const pieces = ids.map((id) => tok.decode([id]));

      el('proof-src').textContent = SENTENCE;
      const box = el('proof-tokens');
      pieces.forEach((p, i) => {
        const s = document.createElement('span');
        s.className = 'tk';
        // Make the leading space visible: token boundaries are the point, and
        // an invisible one reads as a rendering bug rather than a real split.
        s.textContent = p.replace(/^ /, '·');
        s.style.animationDelay = i * 45 + 'ms';
        box.appendChild(s);
      });

      el('proof-meta').textContent = 'GPT-4o · real vocabulary';
      el('proof-cap').innerHTML =
        'That is <b>' + pieces.length + '</b> tokens. Every one is billed, on every call, ' +
        'and the split changes with the model and the language.';
      el('proof').hidden = false;
    } catch {
      // Offline, blocked CDN, or an unsupported browser. Say nothing rather
      // than claim something unverified.
      el('proof').remove();
    }
  </script>
</Base>

<style>
  .intro {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  /* ── Proof block: the signature element ── */
  .proof {
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    background: var(--bg-elevated);
    overflow: hidden;
    margin-bottom: var(--space-3xl);
  }

  .proof-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem var(--space-md);
    border-bottom: 1px solid var(--fg-faint);
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
  }

  .proof-meta {
    margin-left: auto;
    text-align: right;
  }

  .proof-stage {
    padding: var(--space-md);
  }

  .proof-src {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    color: var(--fg);
    margin: 0 0 var(--space-md);
    line-height: 1.5;
  }

  .proof-tokens {
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
    font-family: var(--font-mono);
    font-size: var(--text-small);
  }

  .proof-tokens .tk {
    padding: 2px 5px;
    border-radius: var(--radius-sm);
    background: var(--bg-hover);
    color: var(--fg);
    opacity: 0;
    animation: tokIn 0.28s var(--ease) forwards;
  }

  @keyframes tokIn {
    from { opacity: 0; transform: translateY(3px); }
    to { opacity: 1; transform: none; }
  }

  .proof-cap {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    line-height: 1.6;
    margin: var(--space-md) 0 0;
  }

  .proof-cap :global(b) {
    color: var(--fg);
    font-weight: 500;
  }

  .proof-try {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--signal);
    border: 1px solid color-mix(in srgb, var(--signal) 45%, transparent);
    border-radius: var(--radius-full);
    padding: 3px 11px;
    transition: background var(--duration) var(--ease);
  }

  .proof-try:hover {
    background: var(--bg-hover);
  }

  /* Reduced motion: the tokens still arrive, they just do not travel. */
  @media (prefers-reduced-motion: reduce) {
    .proof-tokens .tk { animation: none; opacity: 1; }
  }

  /* ── App index: a list, not a grid of near-identical cards ── */
  .app-index {
    margin-top: var(--space-md);
  }

  .app-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--fg-faint);
    transition: border-color var(--duration) var(--ease);
  }

  .app-row:hover {
    border-color: var(--accent-color);
  }

  .app-row-title {
    font-size: var(--text-item-title);
    font-weight: 500;
    color: var(--fg);
    white-space: nowrap;
    transition: color var(--duration) var(--ease);
  }

  .app-row:hover .app-row-title {
    color: var(--signal);
  }

  .app-row-desc {
    font-size: var(--text-small);
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .app-row-tag {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .app-row { flex-wrap: wrap; gap: 0.3rem; }
    .app-row-tag { margin-left: 0; order: 3; flex-basis: 100%; }
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--signal);
    margin: 0 0 0.6rem;
  }

  .tagline {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.35;
    color: var(--fg);
    max-width: 580px;
    margin: 0 0 0.9rem;
  }

  .lede {
    font-size: var(--text-body);
    color: var(--fg-muted);
    line-height: 1.7;
    max-width: 60ch;
    margin: 0 0 var(--space-lg);
  }

  .cta-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-lg);
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--fg);
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-full);
    transition: border-color var(--duration) var(--ease),
                background var(--duration) var(--ease);
  }

  .cta-primary:hover {
    border-color: var(--signal);
    background: var(--bg-hover);
  }

  .cta-ghost {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--fg-muted);
    transition: color var(--duration) var(--ease);
  }

  .cta-ghost:hover {
    color: var(--accent-color);
  }

  .avail {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
  }

  .avail-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal);
    display: inline-block;
    animation: pulse 3s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* ── Lane ── */
  .lane {
    margin-bottom: var(--space-xl);
  }

  .lane-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .lane-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    margin: 0;
  }

  .lane-hint {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    text-transform: lowercase;
  }

  /* ── Featured card (flagship agent) ── */
  .featured-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: var(--space-md) var(--space-lg);
    margin-bottom: 0.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--fg);
    transition: border-color var(--duration) var(--ease),
                background var(--duration) var(--ease);
  }

  .featured-card:hover {
    border-color: var(--signal);
    background: var(--bg-hover);
  }

  .featured-main { min-width: 0; }

  .featured-head {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.35rem;
  }

  .featured-title {
    font-family: var(--font-serif);
    font-size: var(--text-subsection);
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .featured-tag {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--signal);
    text-transform: lowercase;
    letter-spacing: 0.02em;
    border: 1px solid color-mix(in srgb, var(--signal) 40%, transparent);
    background: color-mix(in srgb, var(--signal) 8%, transparent);
    border-radius: 100px;
    padding: 0.05rem 0.5rem;
    flex-shrink: 0;
  }

  .featured-tagline {
    font-size: var(--text-body);
    color: var(--fg);
    line-height: 1.4;
    margin: 0 0 0.25rem;
  }

  .featured-sub {
    font-size: var(--text-small);
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0;
    max-width: 60ch;
  }

  .featured-cta {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  /* ── Radar strip ── */
  .radar-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem var(--space-md);
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--fg);
    transition: border-color var(--duration) var(--ease),
                background var(--duration) var(--ease);
  }

  .radar-strip:hover {
    border-color: var(--signal);
    background: var(--bg-hover);
  }

  .radar-strip-main {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal);
    display: inline-block;
    animation: pulse 3s ease-in-out infinite;
    flex-shrink: 0;
    align-self: center;
  }

  .radar-title {
    font-size: var(--text-body);
    font-weight: 600;
  }

  .radar-sub {
    font-size: var(--text-small);
    color: var(--fg-muted);
  }

  .radar-cta {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  /* ── Lab list ── */
  .lab-list {
    display: flex;
    flex-direction: column;
  }

  .lab-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--fg-faint);
    text-decoration: none;
    color: var(--fg);
    transition: color var(--duration) var(--ease);
  }

  .lab-item:first-child {
    border-top: 1px solid var(--fg-faint);
  }

  .lab-item:hover {
    color: var(--accent-color);
  }

  .lab-title {
    font-size: var(--text-body);
    font-weight: 500;
    flex-shrink: 0;
  }

  .lab-tagline {
    font-size: var(--text-small);
    color: var(--fg-muted);
    text-align: right;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {

    .featured-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .radar-strip {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .lab-item {
      flex-direction: column;
      gap: 0.15rem;
    }

    .lab-tagline {
      text-align: left;
    }
  }
</style>
