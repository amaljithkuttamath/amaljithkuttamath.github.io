---
import Base from '../layouts/Base.astro';

const allPosts = import.meta.glob('./work/*.md', { eager: true }) as Record<string, any>;
const posts = Object.entries(allPosts)
  .map(([path, mod]) => ({ ...mod, url: '/work/' + path.replace('./work/', '').replace('.md', '') }))
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---

<Base title="Amaljith Kuttamath">
  <section class="hero animate-in">
    <div class="status">Researching LLM trust & safety</div>
  </section>

  <a href="/playground" class="playground-link animate-in animate-in-delay-1">
    <span class="playground-label">microGPT Playground</span>
    <span class="playground-cta">Train a transformer in your browser &rarr;</span>
  </a>

  <section class="animate-in animate-in-delay-1">
    <div class="section-header">
      <h2>Writing</h2>
      <a href="/blog">All &rarr;</a>
    </div>
    <div class="home-posts">
      {posts.map((post) => (
        <a href={post.url} class="home-post">
          <span class="home-post-title">{post.frontmatter.title}</span>
          <span class="home-post-desc">{post.frontmatter.description}</span>
          {post.frontmatter.tags && (
            <span class="home-post-tags">
              {post.frontmatter.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </span>
          )}
          <time class="mono">{formatDate(post.frontmatter.date)}</time>
        </a>
      ))}
    </div>
  </section>

</Base>

<style>
  .hero {
    padding: var(--space-xl) 0 var(--space-lg);
  }

  .hero .tagline {
    color: var(--fg);
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
  }


  /* ── Playground link ── */
  .playground-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.75rem var(--space-md);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
    margin-bottom: var(--space-lg);
    transition: border-color var(--duration) var(--ease),
                background var(--duration) var(--ease);
  }

  .playground-link:hover {
    border-color: var(--accent-color);
    background: var(--bg-elevated);
  }

  .playground-label {
    font-weight: 500;
    font-size: var(--text-body);
  }

  .playground-cta {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
  }

  section + section {
    margin-top: var(--space-xl);
  }

  .home-posts {
    display: flex;
    flex-direction: column;
  }

  .home-post {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0 var(--space-md);
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--fg-faint);
    text-decoration: none;
    color: var(--fg);
    transition: color var(--duration) var(--ease);
  }

  .home-post:first-child {
    border-top: 1px solid var(--fg-faint);
  }

  .home-post:hover {
    color: var(--accent-color);
  }

  .home-post-title {
    font-size: var(--text-body);
    font-weight: 500;
    grid-column: 1;
  }

  .home-post-desc {
    font-size: var(--text-small);
    color: var(--fg-muted);
    grid-column: 1;
    line-height: 1.5;
  }

  .home-post-tags {
    display: flex;
    gap: 0.375rem;
    grid-column: 1;
    flex-wrap: wrap;
    margin-top: 0.125rem;
  }

  .home-post time,
  .home-post .mono {
    grid-column: 2;
    grid-row: 1;
    align-self: center;
  }
</style>
