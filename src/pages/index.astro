---
import Base from '../layouts/Base.astro';

// Apps: things people return to.
const apps = [
  {
    href: '/apps/tokenizer',
    title: 'Tokenizer Arena',
    tagline: 'Watch five real tokenizers shred your text differently.',
    tag: 'live',
  },
  {
    href: '/apps/pdf-lens',
    title: 'PDF Lens',
    tagline: 'Drop a PDF, get clean text + token cost, all in your browser.',
    tag: 'wasm',
  },
  {
    href: '/apps/probability-xray',
    title: 'Probability X-ray',
    tagline: 'Chat with a local model, see the confidence behind every word.',
    tag: 'webgpu',
  },
  {
    href: '/apps/gguf-inspect',
    title: 'GGUF Inspect',
    tagline: 'Paste a GGUF URL. Get architecture, quantization, and memory fit.',
    tag: 'llama.cpp',
  },
];

// Lab: educational demos.
const lab = [
  {
    href: '/lab/microgpt',
    title: 'microGPT Trainer',
    tagline: 'Train a tiny transformer live, watch every component learn.',
  },
  {
    href: '/lab/watch-model-think',
    title: 'Watch a Model Think',
    tagline: 'Step through GPT-2 token by token: features, calibration, loops.',
  },
];
---

<Base
  title="Amaljith Kuttamath"
  description="AI Engineer. I ship small, sharp tools that make language models legible: tokenizers, PDF parsers, probability views, GGUF inspection."
>
  <section class="intro animate-in">
    <h1 class="tagline">
      I build small tools to make language models legible &mdash; what they see,
      how sure they are, and where they break.
    </h1>
    <p class="cred">
      Everything below runs in your browser. Nothing you paste leaves the page.
    </p>
  </section>

  <section class="lane animate-in animate-in-delay-1" aria-labelledby="lane-apps">
    <div class="lane-head">
      <h2 id="lane-apps" class="lane-label">Apps</h2>
      <span class="lane-hint">things you'll use again</span>
    </div>
    <div class="apps-grid">
      {apps.map((a) => (
        <a href={a.href} class="app-card">
          <div class="app-card-head">
            <span class="app-title">{a.title}</span>
            <span class="app-tag">{a.tag}</span>
          </div>
          <p class="app-tagline">{a.tagline}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="lane animate-in animate-in-delay-2" aria-labelledby="lane-radar">
    <div class="lane-head">
      <h2 id="lane-radar" class="lane-label">Radar</h2>
      <span class="lane-hint">a daily read of the AI field</span>
    </div>
    <a href="/radar" class="radar-strip">
      <div class="radar-strip-main">
        <span class="live-dot" aria-hidden="true"></span>
        <span class="radar-title">AI Radar</span>
        <span class="radar-sub">
          ~30 sources collected, scored, graded, one digest per day
        </span>
      </div>
      <span class="radar-cta">Open board &rarr;</span>
    </a>
  </section>

  <section class="lane animate-in animate-in-delay-2" aria-labelledby="lane-lab">
    <div class="lane-head">
      <h2 id="lane-lab" class="lane-label">Lab</h2>
      <span class="lane-hint">experiments, one idea each</span>
    </div>
    <div class="lab-list">
      {lab.map((l) => (
        <a href={l.href} class="lab-item">
          <span class="lab-title">{l.title}</span>
          <span class="lab-tagline">{l.tagline}</span>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .intro {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .tagline {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.35;
    color: var(--fg);
    max-width: 560px;
    margin: 0 0 0.75rem;
  }

  .cred {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    letter-spacing: 0.01em;
    margin: 0;
  }

  /* ── Lane ── */
  .lane {
    margin-bottom: var(--space-xl);
  }

  .lane-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .lane-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    margin: 0;
  }

  .lane-hint {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    text-transform: lowercase;
  }

  /* ── Apps grid ── */
  .apps-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .app-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--fg);
    transition: border-color var(--duration) var(--ease),
                background var(--duration) var(--ease);
  }

  .app-card:hover {
    border-color: var(--accent-color);
    background: var(--bg-hover);
  }

  .app-card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }

  .app-title {
    font-size: var(--text-body);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .app-tag {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    text-transform: lowercase;
    letter-spacing: 0.02em;
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: 100px;
    padding: 0.05rem 0.5rem;
    flex-shrink: 0;
  }

  .app-tagline {
    font-size: var(--text-small);
    color: var(--fg-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Radar strip ── */
  .radar-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem var(--space-md);
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--fg);
    transition: border-color var(--duration) var(--ease),
                background var(--duration) var(--ease);
  }

  .radar-strip:hover {
    border-color: var(--signal);
    background: var(--bg-hover);
  }

  .radar-strip-main {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    min-width: 0;
  }

  .live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal);
    display: inline-block;
    animation: pulse 3s ease-in-out infinite;
    flex-shrink: 0;
    align-self: center;
  }

  .radar-title {
    font-size: var(--text-body);
    font-weight: 600;
  }

  .radar-sub {
    font-size: var(--text-small);
    color: var(--fg-muted);
  }

  .radar-cta {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  /* ── Lab list ── */
  .lab-list {
    display: flex;
    flex-direction: column;
  }

  .lab-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--fg-faint);
    text-decoration: none;
    color: var(--fg);
    transition: color var(--duration) var(--ease);
  }

  .lab-item:first-child {
    border-top: 1px solid var(--fg-faint);
  }

  .lab-item:hover {
    color: var(--accent-color);
  }

  .lab-title {
    font-size: var(--text-body);
    font-weight: 500;
    flex-shrink: 0;
  }

  .lab-tagline {
    font-size: var(--text-small);
    color: var(--fg-muted);
    text-align: right;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .apps-grid {
      grid-template-columns: 1fr;
    }

    .radar-strip {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .lab-item {
      flex-direction: column;
      gap: 0.15rem;
    }

    .lab-tagline {
      text-align: left;
    }
  }
</style>
