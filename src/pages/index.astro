---
import Base from '../layouts/Base.astro';

const allPosts = import.meta.glob('./work/*.md', { eager: true }) as Record<string, any>;

const astroPosts = [
  {
    frontmatter: {
      title: "Watch a Language Model Think",
      date: "2026-04-01",
      description: "I used sparse autoencoders to look inside GPT-2. I found interpretable concepts, feature loops, and a temperature feature that fires correctly while the model gets the answer wrong.",
      tags: ["interpretability", "SAE", "interactive"],
      thread: "interpretability",
      type: "experiment",
      featured: true,
    },
    url: '/work/watch-model-think',
  },
];

const posts = [
  ...Object.entries(allPosts)
    .map(([path, mod]) => ({ ...mod, url: '/work/' + path.replace('./work/', '').replace('.md', '') })),
  ...astroPosts,
].sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

// Pick featured posts: one from each thread, prioritize featured flag
const threads = [...new Set(posts.map((p) => p.frontmatter.thread).filter(Boolean))];
const featured = threads
  .map((t) => {
    const threadPosts = posts.filter((p) => p.frontmatter.thread === t);
    return threadPosts.find((p) => p.frontmatter.featured) || threadPosts[0];
  })
  .filter(Boolean)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

// Installable tools
const tools = posts.filter(
  (p) => p.frontmatter.type === 'tool' && p.frontmatter.install
);

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---

<Base title="Amaljith Kuttamath">
  <section class="hero animate-in">
    <h1 class="hero-headline">I study how language models fail and build tools to catch it.</h1>
    <p class="hero-sub">AI Engineer, 7 years. I design agents for production and research LLM trust at the architectural level.</p>
    <div class="hero-instrument" id="hero-instrument" title="A real character-bigram language model, training live in this tab.">
      <canvas id="inst-spark" width="120" height="22" aria-hidden="true"></canvas>
      <span class="inst-read" id="inst-read">live &middot; warming up&hellip;</span>
      <span class="inst-names" id="inst-names" aria-hidden="true"></span>
    </div>
  </section>

  <section class="now animate-in animate-in-delay-1">
    <div class="section-label">Now</div>
    <a href="/trust-bench" class="now-card">
      <div class="now-head">
        <span class="now-title">Trust Bench</span>
        <span class="status-pill">in progress</span>
      </div>
      <p>Open-source profiler that looks inside LLMs to find failure modes benchmarks miss. Next: training sparse autoencoders on Qwen3.5's hybrid DeltaNet layers.</p>
    </a>
  </section>

  <section class="animate-in animate-in-delay-1">
    <div class="section-header">
      <span class="section-label">Writing</span>
      <a href="/blog" class="section-link">all &rarr;</a>
    </div>
    <div class="home-posts">
      {featured.map((post) => (
        <a href={post.url} class="home-post">
          <div class="home-post-main">
            <span class="home-post-title">{post.frontmatter.title}</span>
            <span class="home-post-desc">{post.frontmatter.description}</span>
          </div>
          <time class="mono">{formatDate(post.frontmatter.date)}</time>
        </a>
      ))}
    </div>
  </section>

  <section class="animate-in animate-in-delay-2">
    <div class="section-label">Tools</div>
    <div class="tools-grid">
      {tools.map((tool) => (
        <a href={tool.url} class="tool-card">
          <span class="tool-name">{tool.url.split('/').pop()}</span>
          <span class="tool-desc">{tool.frontmatter.description.split('.')[0]}</span>
          <code class="tool-install">{Object.values(tool.frontmatter.install)[0] as string}</code>
        </a>
      ))}
    </div>
  </section>

  <a href="/playground" class="playground-link animate-in animate-in-delay-2">
    <span class="playground-label">Playground</span>
    <span class="playground-cta">Train a transformer, race tokenizers, chat with a local model &rarr;</span>
  </a>
</Base>

<script is:inline>
// Hero instrument: a character-bigram language model training live in this tab.
// Real gradient descent on real data, ~3KB of JS, no downloads.
(function () {
  var NAMES = 'emma,olivia,ava,isabella,sophia,charlotte,mia,amelia,harper,evelyn,abigail,emily,elizabeth,mila,ella,avery,sofia,camila,aria,scarlett,victoria,madison,luna,grace,chloe,penelope,layla,riley,zoey,nora,lily,eleanor,hannah,lillian,addison,aubrey,ellie,stella,natalie,zoe,leah,hazel,violet,aurora,savannah,audrey,brooklyn,bella,claire,skylar,lucy,paisley,everly,anna,caroline,nova,genesis,emilia,kennedy,samantha,maya,willow,kinsley,naomi,aaliyah,elena,sarah,ariana,allison,gabriella,alice,madelyn,cora,ruby,eva,serenity,autumn,adeline,hailey,gianna,valentina,isla,eliana,quinn,ivy,sadie,piper,lydia,alexa,josephine,emery,julia,delilah,arianna,vivian,kaylee,sophie,brielle,madeline'.split(',');
  var readEl = document.getElementById('inst-read');
  var namesEl = document.getElementById('inst-names');
  var canvas = document.getElementById('inst-spark');
  if (!readEl || !canvas) return;
  var ctx = canvas.getContext('2d');
  var V = 27; // a-z + boundary
  var W = new Float32Array(V * V); // logits
  var idx = function (c) { return c === '.' ? 0 : c.charCodeAt(0) - 96; };

  // training pairs
  var pairs = [];
  for (var n = 0; n < NAMES.length; n++) {
    var w = '.' + NAMES[n] + '.';
    for (var i = 0; i < w.length - 1; i++) pairs.push([idx(w[i]), idx(w[i + 1])]);
  }

  var probs = new Float32Array(V);
  function rowProbs(a) {
    var mx = -1e9, j;
    for (j = 0; j < V; j++) if (W[a * V + j] > mx) mx = W[a * V + j];
    var sum = 0;
    for (j = 0; j < V; j++) { probs[j] = Math.exp(W[a * V + j] - mx); sum += probs[j]; }
    for (j = 0; j < V; j++) probs[j] /= sum;
    return probs;
  }

  function trainStep(lr) {
    var loss = 0, B = 64;
    for (var b = 0; b < B; b++) {
      var pr = pairs[(Math.random() * pairs.length) | 0];
      var a = pr[0], t = pr[1], p = rowProbs(a);
      loss += -Math.log(p[t] + 1e-9);
      for (var j = 0; j < V; j++) W[a * V + j] -= lr * (p[j] - (j === t ? 1 : 0));
    }
    return loss / B;
  }

  function sampleName() {
    var out = '', a = 0;
    for (var i = 0; i < 12; i++) {
      var p = rowProbs(a), r = Math.random(), cum = 0, next = 0;
      for (var j = 0; j < V; j++) { cum += p[j]; if (r < cum) { next = j; break; } }
      if (next === 0) break;
      out += String.fromCharCode(96 + next);
      a = next;
    }
    return out.length > 1 ? out : sampleName();
  }

  var hist = [];
  function drawSpark() {
    var w = canvas.width, h = canvas.height;
    ctx.clearRect(0, 0, w, h);
    if (hist.length < 2) return;
    var mx = hist[0], mn = hist[hist.length - 1];
    ctx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--signal').trim() || '#d9a13b';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    for (var i = 0; i < hist.length; i++) {
      var x = (i / (hist.length - 1)) * (w - 2) + 1;
      var y = 2 + ((hist[i] - mn) / (mx - mn + 1e-9)) * (h - 5);
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.stroke();
  }

  var step = 0, MAX = 400;
  var reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function updateNames() {
    namesEl.textContent = '“' + sampleName() + ', ' + sampleName() + ', ' + sampleName() + '”';
  }

  if (reduced) {
    // No animation: train silently, render the end state once.
    var loss;
    for (step = 0; step < MAX; step++) { loss = trainStep(0.5); if (step % 10 === 0) hist.push(loss); }
    drawSpark();
    readEl.textContent = 'live · bigram model trained in this tab · loss ' + loss.toFixed(2);
    updateNames();
    return;
  }

  function tick() {
    if (step < MAX) {
      var loss;
      for (var k = 0; k < 4 && step < MAX; k++) { loss = trainStep(0.5); step++; }
      if (step % 8 === 0 || step >= MAX) {
        hist.push(loss);
        drawSpark();
        readEl.textContent = 'live · training a bigram model in this tab · step ' + step + ' · loss ' + loss.toFixed(2);
        if (step % 40 === 0) updateNames();
      }
      requestAnimationFrame(tick);
    } else {
      readEl.textContent = 'live · bigram model trained in this tab · loss ' + hist[hist.length - 1].toFixed(2) + ' · sampling:';
      updateNames();
      setInterval(updateNames, 2400);
    }
  }
  requestAnimationFrame(tick);
})();
</script>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .hero-headline {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.4;
    max-width: 520px;
    margin: 0 0 0.5rem;
  }

  .hero-sub {
    font-size: var(--text-body);
    color: var(--fg-muted);
    line-height: 1.6;
    max-width: 500px;
    margin: 0;
  }

  /* Live instrument: a real model training in this tab */
  .hero-instrument {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: var(--space-lg);
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    flex-wrap: wrap;
  }
  .hero-instrument canvas {
    flex-shrink: 0;
    opacity: 0.9;
  }
  .inst-read::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--signal);
    margin-right: 0.5rem;
    vertical-align: 1px;
  }
  .inst-names {
    color: var(--fg);
    letter-spacing: 0.02em;
  }

  /* ── Section labels ── */
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin-bottom: 0.75rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.75rem;
  }

  .section-link {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .section-link:hover {
    color: var(--accent-color);
  }

  /* ── Now card ── */
  .now {
    margin-bottom: var(--space-xl);
  }

  .now-card {
    display: block;
    padding: var(--space-md) var(--space-lg);
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .now-card:hover {
    border-color: var(--accent-color);
    background: var(--bg-hover);
  }

  .now-head {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }

  .now-title {
    font-size: var(--text-subsection);
    font-weight: 500;
  }

  .status-pill {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--signal);
    padding: 0.1rem 0.4rem;
    border: 1px solid color-mix(in srgb, var(--signal) 50%, transparent);
    border-radius: 100px;
  }

  .now-card p {
    font-size: var(--text-small);
    color: var(--fg-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Writing section ── */
  section + section {
    margin-top: var(--space-xl);
  }

  .home-posts {
    display: flex;
    flex-direction: column;
  }

  .home-post {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--fg-faint);
    text-decoration: none;
    color: var(--fg);
    transition: color var(--duration) var(--ease);
  }

  .home-post:first-child {
    border-top: 1px solid var(--fg-faint);
  }

  .home-post:hover {
    color: var(--accent-color);
  }

  .home-post-main {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .home-post-title {
    font-size: var(--text-body);
    font-weight: 500;
  }

  .home-post-desc {
    font-size: var(--text-small);
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .home-post time {
    flex-shrink: 0;
    font-size: var(--text-tag);
    margin-top: 0.125rem;
  }

  /* ── Tools grid ── */
  .tools-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: var(--space-xl);
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    padding: 0.75rem var(--space-md);
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .tool-card:hover {
    border-color: var(--accent-color);
    background: var(--bg-hover);
  }

  .tool-name {
    font-size: var(--text-body);
    font-weight: 500;
  }

  .tool-desc {
    font-size: var(--text-small);
    color: var(--fg-muted);
    margin: 0.15rem 0 0.4rem;
    line-height: 1.4;
  }

  .tool-install {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--success);
  }

  /* ── Playground link ── */
  .playground-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.75rem var(--space-md);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
    margin-top: var(--space-lg);
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .playground-link:hover {
    border-color: var(--accent-color);
    background: var(--bg-elevated);
  }

  .playground-label {
    font-weight: 500;
    font-size: var(--text-body);
  }

  .playground-cta {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }

    .playground-link {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
