---
import Base from '../layouts/Base.astro';

const allPosts = import.meta.glob('./work/*.md', { eager: true }) as Record<string, any>;

// Manually include .astro interactive posts that aren't in the glob
const astroPosts = [
  {
    frontmatter: {
      title: "Watch a Language Model Think",
      date: "2026-04-01",
      description: "I used sparse autoencoders to look inside GPT-2. I found interpretable concepts, feature loops, and a temperature feature that fires correctly while the model gets the answer wrong.",
      tags: ["interpretability", "SAE", "interactive"],
      thread: "interpretability",
      type: "experiment",
      featured: true,
    },
    url: '/work/watch-model-think',
  },
];

const posts = [
  ...Object.entries(allPosts)
    .map(([path, mod]) => ({ ...mod, url: '/work/' + path.replace('./work/', '').replace('.md', '') })),
  ...astroPosts,
].sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const threads = [
  { id: 'trust', label: 'Trust & Safety' },
  { id: 'interpretability', label: 'Interpretability' },
  { id: 'architecture', label: 'Architecture' },
  { id: 'tools', label: 'Tools' },
];

const postsByThread = new Map<string, typeof posts>();
for (const thread of threads) {
  postsByThread.set(
    thread.id,
    posts.filter((p) => p.frontmatter.thread === thread.id)
  );
}

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const typeColors: Record<string, { label: string; color: string; border: string }> = {
  experiment: { label: 'Experiment', color: 'var(--accent-color)', border: 'rgba(184,122,80,0.2)' },
  'deep-dive': { label: 'Deep Dive', color: '#6b8ab8', border: 'rgba(107,138,184,0.2)' },
  tool: { label: 'Tool', color: '#5a9a6e', border: 'rgba(90,154,110,0.2)' },
};

const threadBorderColors: Record<string, string> = {
  trust: 'rgba(184,122,80,0.3)',
  interpretability: 'rgba(184,122,80,0.3)',
  architecture: 'rgba(184,122,80,0.3)',
  tools: 'rgba(90,154,110,0.3)',
};
---

<Base title="Blog | Amaljith Kuttamath" description="Writing about LLM internals, trust, and what I learn building things.">
  <div class="blog-header animate-in">
    <h1>Writing</h1>
  </div>

  <div class="tab-bar animate-in animate-in-delay-1">
    {threads.map((thread, i) => (
      <button
        class={`tab ${i === 0 ? 'active' : ''}`}
        data-tab={thread.id}
      >
        {thread.label}
        <span class="tab-count">{postsByThread.get(thread.id)?.length}</span>
      </button>
    ))}
  </div>

  {threads.map((thread, i) => {
    const threadPosts = postsByThread.get(thread.id) || [];
    const featured = threadPosts.find((p) => p.frontmatter.featured) || threadPosts[0];
    const rest = threadPosts.filter((p) => p !== featured);
    const borderColor = threadBorderColors[thread.id];

    return (
      <div
        class={`tab-content animate-in animate-in-delay-1 ${i === 0 ? 'active' : ''}`}
        data-tab-content={thread.id}
      >
        <div class="thread-line" style={`border-left-color: ${borderColor};`}>
          {featured && (
            <a href={featured.url} class="featured-card">
              <div class="featured-main">
                <div class="featured-meta">
                  {(() => {
                    const t = typeColors[featured.frontmatter.type] || typeColors.experiment;
                    return (
                      <span class="type-badge" style={`color: ${t.color}; border-color: ${t.border};`}>
                        {t.label}
                      </span>
                    );
                  })()}
                  <time class="mono">{formatDate(featured.frontmatter.date)}</time>
                </div>
                <h2>{featured.frontmatter.title}</h2>
                <p>{featured.frontmatter.description}</p>
                {featured.frontmatter.tags && (
                  <div class="blog-tags">
                    {featured.frontmatter.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
                {featured.frontmatter.install && (
                  <div class="install-buttons">
                    {Object.entries(featured.frontmatter.install).map(([key, cmd]) => (
                      <span class={`install-btn ${key === 'brew' ? 'install-primary' : ''}`}>
                        <code>{cmd as string}</code>
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          )}

          {rest.map((post) => {
            const t = typeColors[post.frontmatter.type] || typeColors.experiment;
            return (
              <a href={post.url} class="compact-item">
                <div class="compact-left">
                  <span
                    class="type-badge-sm"
                    style={`color: ${t.color}; border-color: ${t.border};`}
                  >
                    {post.frontmatter.type === 'experiment' ? 'EXP' : post.frontmatter.type === 'deep-dive' ? 'DEEP DIVE' : 'TOOL'}
                  </span>
                  <span class="compact-title">{post.frontmatter.title}</span>
                </div>
                <time class="mono">{formatDate(post.frontmatter.date)}</time>
              </a>
            );
          })}
        </div>
      </div>
    );
  })}
</Base>

<script is:inline>
  document.querySelectorAll('.tab').forEach((tab) => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      const id = tab.getAttribute('data-tab');
      document.querySelectorAll('.tab-content').forEach((c) => c.classList.remove('active'));
      document.querySelector(`[data-tab-content="${id}"]`)?.classList.add('active');
    });
  });
</script>

<style>
  .blog-header {
    padding: var(--space-2xl) 0 var(--space-lg);
  }

  .blog-header h1 {
    font-family: var(--font-serif);
    font-size: var(--text-page-title);
    font-weight: 500;
    letter-spacing: -0.03em;
  }

  /* Tab bar */
  .tab-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--fg-faint);
    margin-bottom: var(--space-xl);
  }

  .tab {
    padding: 0.6rem 1.25rem;
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--fg-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .tab:hover {
    color: var(--fg);
  }

  .tab.active {
    color: var(--accent-color);
    border-bottom-color: var(--accent-color);
  }

  .tab-count {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    opacity: 0.5;
  }

  /* Tab content */
  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  /* Thread line */
  .thread-line {
    border-left: 2px solid var(--fg-faint);
    padding-left: var(--space-lg);
  }

  /* Featured card */
  .featured-card {
    display: block;
    padding: var(--space-lg);
    background: var(--bg-elevated);
    border-radius: 8px;
    border: 1px solid var(--fg-faint);
    text-decoration: none;
    color: var(--fg);
    margin-bottom: 0.75rem;
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .featured-card:hover {
    border-color: var(--accent-color);
    background: var(--bg-hover);
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .featured-meta time {
    font-size: var(--text-tag);
    color: var(--fg-muted);
  }

  .featured-card h2 {
    font-family: var(--font-serif);
    font-size: var(--text-subsection);
    font-weight: 500;
    margin: 0 0 0.35rem;
    line-height: 1.4;
  }

  .featured-card p {
    color: var(--fg-muted);
    font-size: var(--text-small);
    margin: 0 0 0.5rem;
    line-height: 1.5;
  }

  /* Type badges */
  .type-badge {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.4rem;
    border: 1px solid;
    border-radius: 100px;
  }

  .type-badge-sm {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    text-transform: uppercase;
    padding: 0.1rem 0.3rem;
    border: 1px solid;
    border-radius: 100px;
    flex-shrink: 0;
  }

  /* Tags */
  .blog-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  /* Install buttons */
  .install-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .install-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.6rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--fg-faint);
    border-radius: 6px;
  }

  .install-btn code {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--fg-muted);
  }

  .install-primary {
    background: rgba(90, 154, 110, 0.08);
    border-color: rgba(90, 154, 110, 0.15);
  }

  .install-primary code {
    color: #5a9a6e;
  }

  /* Compact items */
  .compact-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    text-decoration: none;
    color: var(--fg);
    transition: color var(--duration) var(--ease);
  }

  .compact-item:last-child {
    border-bottom: none;
  }

  .compact-item:hover {
    color: var(--accent-color);
  }

  .compact-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .compact-title {
    font-size: var(--text-small);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .compact-item time {
    flex-shrink: 0;
    font-size: var(--text-tag);
    color: var(--fg-muted);
  }

  /* Responsive */
  @media (max-width: 600px) {
    .tab-bar {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .tab {
      padding: 0.5rem 0.75rem;
      font-size: var(--text-tag);
      white-space: nowrap;
    }

    .thread-line {
      padding-left: var(--space-md);
    }

    .featured-card {
      padding: var(--space-md);
    }

    .compact-title {
      max-width: 200px;
    }
  }
</style>
