---
import Base from '../layouts/Base.astro';

// Data source: https://github.com/amaljithkuttamath/ai-radar
// The dashboard is intentionally client-rendered so the page always reflects the very
// latest digest without a site rebuild. Each fetch has a graceful fallback in the DOM.
const RADAR_REPO = 'amaljithkuttamath/ai-radar';
const RAW = `https://raw.githubusercontent.com/${RADAR_REPO}/main`;
---

<Base
  title="AI Radar | Amaljith Kuttamath"
  description="A daily radar over AI research, releases, and social signal. Two-stage pipeline: collect the corpus, distill the signal."
>
  <section class="radar-hero">
    <div class="radar-title-row">
      <h1 class="radar-title">AI Radar</h1>
      <span class="radar-live" aria-live="polite">
        <span class="radar-live-dot" aria-hidden="true"></span>
        <span class="radar-live-label">live</span>
      </span>
    </div>
    <p class="radar-lede">
      A daily radar over AI research, releases, and social signal. Collect the corpus,
      distill the signal, surface what moved.
      <a href={`https://github.com/${RADAR_REPO}`} target="_blank" rel="noopener noreferrer">
        Source on GitHub &rarr;
      </a>
    </p>
  </section>

  <!-- Stat strip — filled by JS from state.json + latest digest metadata -->
  <section class="radar-strip animate-in animate-in-delay-1" aria-label="Radar summary">
    <div class="strip-cell">
      <span class="strip-label">window</span>
      <span class="strip-value" id="strip-window">—</span>
    </div>
    <div class="strip-cell">
      <span class="strip-label">tracked</span>
      <span class="strip-value" id="strip-tracked">—</span>
    </div>
    <div class="strip-cell">
      <span class="strip-label">rising</span>
      <span class="strip-value" id="strip-rising">—</span>
    </div>
    <div class="strip-cell">
      <span class="strip-label">last digest</span>
      <span class="strip-value" id="strip-updated">—</span>
    </div>
  </section>

  <!-- Rising panel: items with streak >= 3 and rising mag_history. -->
  <section class="radar-rising animate-in animate-in-delay-1" aria-label="Rising items">
    <div class="section-header">
      <span class="section-label">Rising</span>
      <span class="section-hint">streak &ge; 3 &middot; magnitude trending up</span>
    </div>
    <div id="rising-body" class="rising-body">
      <div class="loading">Loading&hellip;</div>
    </div>
  </section>

  <!-- Latest digest, rendered client-side from markdown. -->
  <section class="radar-latest animate-in animate-in-delay-2" aria-label="Latest digest">
    <div class="section-header">
      <span class="section-label">Latest digest</span>
      <a
        id="latest-source"
        class="section-link"
        href={`https://github.com/${RADAR_REPO}/blob/main/reports/`}
        target="_blank"
        rel="noopener noreferrer"
      >on github &rarr;</a>
    </div>
    <article id="latest-body" class="latest-body">
      <div class="loading">Loading digest&hellip;</div>
    </article>
  </section>

  <!-- Archive: past digests. -->
  <section class="radar-archive animate-in animate-in-delay-2" aria-label="Digest archive">
    <div class="section-header">
      <span class="section-label">Archive</span>
      <span class="section-hint" id="archive-count"></span>
    </div>
    <div id="archive-body" class="archive-body">
      <div class="loading">Loading&hellip;</div>
    </div>
  </section>

  <script type="module" define:vars={{ RAW, RADAR_REPO }}>
    // ─────────────────────────────────────────────────────────────────────────
    // Data loading. Three fetches in parallel; each renders independently so a
    // slow or failing source never blocks the others.
    // ─────────────────────────────────────────────────────────────────────────

    // Runtime dependency: marked (markdown -> HTML). Loaded from CDN so the site
    // bundle stays lean. Pinned to a specific major to avoid API surprises.
    const MARKED_URL = 'https://cdn.jsdelivr.net/npm/marked@12.0.2/lib/marked.esm.js';

    const $ = (id) => document.getElementById(id);

    const renderErr = (host, msg) => {
      host.innerHTML = `<div class="loading err">${msg}</div>`;
    };

    // ─── Latest digest ──────────────────────────────────────────────────────
    (async () => {
      const host = $('latest-body');
      try {
        const [{ marked }, res] = await Promise.all([
          import(MARKED_URL),
          fetch(`${RAW}/reports/latest.md`, { cache: 'no-store' }),
        ]);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        let md = await res.text();

        // The latest.md has a radar:nav header (prev/index/newest) meant for the
        // github rendering. On the dashboard we already show the archive below,
        // so strip that block for a cleaner read.
        md = md.replace(/<!-- radar:nav -->[\s\S]*?<!-- \/radar:nav -->\n*/g, '');

        // Extract the report date from the "# AI Radar — YYYY-MM-DD" header so
        // the stat strip can show "last digest: 2h ago" without a second fetch.
        const dateMatch = md.match(/^#\s*AI Radar\s*[—-]\s*(\d{4}-\d{2}-\d{2})/m);
        if (dateMatch) {
          const d = new Date(dateMatch[1] + 'T13:00:00Z');
          const hoursAgo = Math.round((Date.now() - d.getTime()) / 3600000);
          $('strip-updated').textContent = hoursAgo < 24
            ? `${hoursAgo}h ago`
            : `${Math.floor(hoursAgo / 24)}d ago`;
          // Update the "on github" link to the specific dated digest so the
          // reader can jump straight to the source view of what they're reading.
          $('latest-source').href = `https://github.com/${RADAR_REPO}/blob/main/reports/${dateMatch[1]}-digest.md`;
        }

        marked.setOptions({ gfm: true, breaks: false });
        host.innerHTML = marked.parse(md);

        // Open external links in a new tab so the reader doesn't lose the page.
        host.querySelectorAll('a[href^="http"]').forEach((a) => {
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
        });
      } catch (err) {
        renderErr(host, `Couldn't load the latest digest (${err.message}). Try again in a moment.`);
      }
    })();

    // ─── State: rising panel + summary strip ───────────────────────────────
    (async () => {
      const risingHost = $('rising-body');
      try {
        const res = await fetch(`${RAW}/data/state.json`, { cache: 'no-store' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const state = await res.json();

        const entries = Object.entries(state);
        $('strip-tracked').textContent = String(entries.length);

        // Rising = seen for >= 3 consecutive runs AND mag_history trending up.
        // Uses the same definition as distill/delta.py's story_arcs() so what
        // shows here matches what the digest calls out as story arcs.
        const rising = entries
          .map(([id, snap]) => {
            const history = snap.mag_history || [];
            if ((snap.streak || 0) < 3 || history.length < 2) return null;
            const first = history[0];
            const last = history[history.length - 1];
            if (last <= first) return null;
            const pct = ((last - first) / Math.max(first, 0.01)) * 100;
            return { id, snap, pct, history };
          })
          .filter(Boolean)
          .sort((a, b) => b.pct - a.pct)
          .slice(0, 8);

        $('strip-rising').textContent = String(rising.length);
        // Window is not in state.json; read it from the collect-corpus cron env
        // via a constant here. If we later expose window in state, replace this.
        $('strip-window').textContent = '48h';

        if (rising.length === 0) {
          risingHost.innerHTML = `<div class="empty">No items on a rising streak in the current window. Come back after the next run.</div>`;
          return;
        }

        // Build sparklines from mag_history (min-max normalized to 8 unicode blocks).
        const BLOCKS = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];
        const spark = (h) => {
          if (!h || h.length === 0) return '';
          const min = Math.min(...h);
          const max = Math.max(...h);
          const range = max - min || 1;
          return h.map((v) => BLOCKS[Math.min(7, Math.floor(((v - min) / range) * 7))]).join('');
        };

        risingHost.innerHTML = rising.map(({ snap, pct, history }) => `
          <a class="rising-row" href="${snap.url}" target="_blank" rel="noopener noreferrer">
            <span class="rising-title">${escapeHtml(snap.title || '(untitled)')}</span>
            <span class="rising-metrics">
              <span class="rising-spark" title="${history.length}-run magnitude history">${spark(history)}</span>
              <span class="rising-pct">+${Math.round(pct)}%</span>
              <span class="rising-streak">${snap.streak} runs</span>
            </span>
          </a>
        `).join('');
      } catch (err) {
        renderErr(risingHost, `Couldn't load state (${err.message}).`);
        $('strip-tracked').textContent = '—';
        $('strip-rising').textContent = '—';
      }
    })();

    // ─── Archive: prior digests ─────────────────────────────────────────────
    (async () => {
      const host = $('archive-body');
      try {
        const res = await fetch(`${RAW}/reports/README.md`, { cache: 'no-store' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const md = await res.text();

        // The README is an auto-generated table: | 2026-07-02 | teaser… |
        const rows = [];
        for (const line of md.split('\n')) {
          const m = line.match(/^\|\s*\[(\d{4}-\d{2}-\d{2})\]\([^)]+\)\s*\|\s*(.+?)\s*\|\s*$/);
          if (m) rows.push({ date: m[1], teaser: m[2].replace(/…$/, '').trim() });
        }

        if (rows.length === 0) {
          host.innerHTML = `<div class="empty">No prior digests yet.</div>`;
          return;
        }

        // Skip the most recent (it's already shown as "latest digest" above).
        const past = rows.slice(1);
        $('archive-count').textContent = `${past.length} prior digest${past.length === 1 ? '' : 's'}`;

        host.innerHTML = past.slice(0, 30).map((row) => `
          <a class="archive-row" href="https://github.com/${RADAR_REPO}/blob/main/reports/${row.date}-digest.md" target="_blank" rel="noopener noreferrer">
            <time class="mono archive-date">${row.date}</time>
            <span class="archive-teaser">${escapeHtml(row.teaser)}</span>
          </a>
        `).join('');
      } catch (err) {
        renderErr(host, `Couldn't load the archive (${err.message}).`);
      }
    })();

    // ─── Utilities ──────────────────────────────────────────────────────────
    function escapeHtml(s) {
      return String(s || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }
  </script>
</Base>

<style>
  /* ── Radar hero ─────────────────────────────────────────────────────── */
  .radar-hero {
    padding: var(--space-2xl) 0 var(--space-lg);
  }

  .radar-title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }

  .radar-title {
    font-family: var(--font-serif);
    font-size: var(--text-page-title);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .radar-live {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .radar-live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--signal);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--signal) 55%, transparent);
    animation: radar-pulse 1.8s ease-out infinite;
  }

  /* Two-stage pulse: expands outward, fades to nothing. More visible on a dark ground
     than the previous version, which was near-invisible against the surrounding text. */
  @keyframes radar-pulse {
    0%   { box-shadow: 0 0 0 0 color-mix(in srgb, var(--signal) 55%, transparent); }
    70%  { box-shadow: 0 0 0 8px color-mix(in srgb, var(--signal) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--signal) 0%, transparent); }
  }

  .radar-live-label {
    color: var(--signal);
  }

  .radar-lede {
    font-size: var(--text-body);
    color: var(--fg-muted);
    line-height: 1.6;
    max-width: 560px;
    margin: var(--space-sm) 0 0;
  }

  .radar-lede a {
    color: var(--fg-muted);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--fg-muted) 40%, transparent);
    text-underline-offset: 2px;
  }

  .radar-lede a:hover { color: var(--fg); }

  /* ── Stat strip ─────────────────────────────────────────────────────── */
  .radar-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--fg-faint);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: var(--space-xl);
  }

  .strip-cell {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.75rem var(--space-md);
    background: var(--bg);
  }

  .strip-label {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
  }

  .strip-value {
    font-family: var(--font-mono);
    font-size: var(--text-body-lg);
    color: var(--fg);
    font-weight: 500;
  }

  /* ── Section headers (mirrors index.astro's) ────────────────────────── */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.75rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
  }

  .section-hint,
  .section-link {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .section-link:hover { color: var(--accent-color); }

  /* ── Rising panel ───────────────────────────────────────────────────── */
  .radar-rising { margin-bottom: var(--space-xl); }

  .rising-body {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--fg-faint);
  }

  .rising-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--fg-faint);
    text-decoration: none;
    color: var(--fg);
    transition: color var(--duration) var(--ease);
  }

  .rising-row:hover { color: var(--accent-color); }

  .rising-title {
    font-size: var(--text-body);
    font-weight: 500;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rising-metrics {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
  }

  .rising-spark {
    color: var(--signal);
    letter-spacing: 0.05em;
  }

  .rising-pct {
    color: var(--signal);
    min-width: 3.5rem;
    text-align: right;
  }

  .rising-streak {
    color: var(--fg-muted);
    min-width: 4rem;
    text-align: right;
  }

  /* ── Latest digest (typography for rendered markdown) ───────────────── */
  .radar-latest { margin-bottom: var(--space-xl); }

  .latest-body {
    font-size: var(--text-body);
    line-height: 1.7;
    color: var(--fg);
  }

  .latest-body :global(h1) {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.015em;
    margin: 0 0 var(--space-md);
  }

  .latest-body :global(h2) {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin: var(--space-xl) 0 var(--space-sm);
    font-weight: 400;
  }

  .latest-body :global(h3) {
    font-family: var(--font-sans);
    font-size: var(--text-subsection);
    font-weight: 500;
    margin: var(--space-lg) 0 var(--space-sm);
  }

  .latest-body :global(p) {
    margin: 0 0 var(--space-md);
    color: var(--fg-muted);
  }

  .latest-body :global(ul),
  .latest-body :global(ol) {
    padding-left: var(--space-md);
    margin: 0 0 var(--space-md);
  }

  .latest-body :global(li) {
    margin: 0.25rem 0;
    color: var(--fg-muted);
  }

  .latest-body :global(li) :global(a):first-child {
    color: var(--fg);
    font-weight: 500;
  }

  .latest-body :global(a) {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--fg) 30%, transparent);
    text-underline-offset: 2px;
    transition: text-decoration-color var(--duration) var(--ease);
  }

  .latest-body :global(a:hover) {
    text-decoration-color: var(--fg);
  }

  .latest-body :global(strong) {
    color: var(--fg);
    font-weight: 500;
  }

  .latest-body :global(hr) {
    border: none;
    border-top: 1px solid var(--fg-faint);
    margin: var(--space-xl) 0;
  }

  .latest-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--bg-elevated);
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
  }

  .latest-body :global(blockquote) {
    border-left: 2px solid var(--fg-faint);
    padding-left: var(--space-md);
    color: var(--fg-muted);
    margin: 0 0 var(--space-md);
  }

  /* ── Archive ────────────────────────────────────────────────────────── */
  .archive-body {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--fg-faint);
  }

  .archive-row {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: var(--space-md);
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--fg-faint);
    text-decoration: none;
    color: var(--fg);
    transition: color var(--duration) var(--ease);
  }

  .archive-row:hover { color: var(--accent-color); }

  .archive-date {
    color: var(--fg-muted);
    font-size: var(--text-tag);
    letter-spacing: 0.03em;
  }

  .archive-teaser {
    font-size: var(--text-small);
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .archive-row:hover .archive-teaser { color: var(--fg); }

  /* ── Loading / empty / error states ─────────────────────────────────── */
  .loading,
  .empty {
    padding: 0.65rem 0;
    font-family: var(--font-mono);
    font-size: var(--text-small);
    color: var(--fg-muted);
    letter-spacing: 0.03em;
    border-bottom: 1px solid var(--fg-faint);
  }

  .loading.err { color: var(--danger); }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .radar-strip {
      grid-template-columns: repeat(2, 1fr);
    }
    .rising-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }
    .rising-title { white-space: normal; }
    .rising-metrics {
      width: 100%;
      justify-content: flex-start;
    }
    .rising-pct, .rising-streak { min-width: auto; }
    .archive-row {
      grid-template-columns: 4rem 1fr;
    }
  }
</style>
