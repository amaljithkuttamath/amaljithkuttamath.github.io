---
import Base from '../layouts/Base.astro';

// Public intelligence instrument over the ai-radar corpus.
//
// Design frame (see consultation synthesis, 2026-07-02): the page is an
// *instrument*, not a newsletter. Observed signals dominate; the model's
// synthesis is subordinate to the ranked board and is clearly labeled as
// machine opinion over observed data.
//
// Data flow: client-side, three parallel fetches. Zero coupling to the
// ai-radar repo build — this page always reflects the latest committed
// state without a site rebuild.
const RADAR_REPO = 'amaljithkuttamath/ai-radar';
const RAW = `https://raw.githubusercontent.com/${RADAR_REPO}/main`;
---

<Base
  title="AI Radar | Amaljith Kuttamath"
  description="A live intelligence view of AI research, releases, and social signal. Collect the corpus, distill the signal, expose the state of the field."
>
  <!-- Break out of the site's 700px reading column so the board has real
       estate. The BRIEF prose (below) stays in a narrow measure for
       readability; only the instrument surfaces get the wider canvas.
       See the "widen the container" tradeoff in the consultation. -->
  <div class="radar-canvas">

  <!-- ── HERO ─────────────────────────────────────────────────────── -->
  <section class="radar-hero">
    <div class="hero-row">
      <h1 class="hero-title">AI Radar</h1>
      <span class="live-indicator" aria-live="polite">
        <span class="live-dot" aria-hidden="true"></span>
        <span class="live-label">live</span>
      </span>
    </div>
    <p class="hero-lede">
      An automated pipeline scans new AI papers, models, repos, and lab posts
      every day, scores each item for relevance, and writes a short brief.
      The brief below is today's machine-generated summary; the board under
      it is the ranked evidence behind it.
      <a href={`https://github.com/${RADAR_REPO}`} target="_blank" rel="noopener noreferrer">
        method &amp; source &rarr;
      </a>
    </p>
  </section>

  <!-- ── STATUS BAR ───────────────────────────────────────────────── -->
  <!-- Three numbers a cold reader can parse without a legend:
       how many items are tracked, how many rank high today, and how
       fresh the data is. -->
  <section class="status-bar animate-in animate-in-delay-1" aria-label="System status">
    <div class="status-cell">
      <span class="status-label">tracked</span>
      <span class="status-value" id="status-tracked">–</span>
    </div>
    <div class="status-cell">
      <span class="status-label">high signal</span>
      <span class="status-value" id="status-high">–</span>
    </div>
    <div class="status-cell">
      <span class="status-label">updated</span>
      <span class="status-value" id="status-sync">–</span>
    </div>
  </section>

  <!-- ── BRIEF ────────────────────────────────────────────────────── -->
  <!-- The daily digest is verbose machine prose that repeats every item
       two or three times. We do not reprint the newsletter. We parse it:
       the one-paragraph top-line leads, the "new today" list follows,
       and the full raw digest sits behind a toggle for anyone who wants
       the model's complete commentary. -->
  <section class="brief animate-in animate-in-delay-1" aria-label="Synthesized brief">
    <div class="section-head">
      <span class="section-label">brief</span>
      <span class="section-hint" id="brief-attribution">machine synthesis · attribution loading</span>
    </div>
    <article id="brief-body" class="brief-body">
      <div class="loading">loading brief&hellip;</div>
    </article>
  </section>

  <!-- ── THE BOARD ────────────────────────────────────────────────── -->
  <!-- Ranked evidence behind the brief. Columns only exist when the
       data behind them exists: the trend column shows a sparkline once
       an item has multi-day history, and reads "new" until then.
       No evidence stacks, streak chips, or tape until the pipeline
       actually produces that data. Every element earns its space. -->
  <section class="board animate-in animate-in-delay-2" aria-label="Ranked list of tracked items">
    <div class="section-head">
      <span class="section-label">evidence</span>
      <div class="board-controls" id="board-controls">
        <button class="board-sort" data-sort="score" data-active="true">top rated</button>
        <button class="board-sort" data-sort="age" data-active="false">newest</button>
        <button class="board-sort board-toggle" id="board-toggle" data-active="false">show all</button>
      </div>
    </div>
    <!-- Source filter chips, rendered from the data with live counts. -->
    <div class="board-filters" id="board-filters" role="group" aria-label="Filter by source"></div>
    <div class="board-header" role="row" aria-hidden="true">
      <span class="col-score">score</span>
      <span class="col-item">item</span>
      <span class="col-trend">trend</span>
      <span class="col-age">seen</span>
    </div>
    <div id="board-body" class="board-body">
      <div class="loading">loading board&hellip;</div>
    </div>
    <div class="board-more-wrap">
      <button class="board-more" id="board-more" style="display:none">show 20 more</button>
    </div>
    <p class="board-foot" id="board-foot"></p>
  </section>

  <!-- ── RUN LOG ──────────────────────────────────────────────────── -->
  <!-- Dated pipeline runs. A utility drawer, closed by default: the
       history matters for accountability, not for the first read. -->
  <section class="run-log animate-in animate-in-delay-2" aria-label="Historical run log">
    <details class="run-log-drawer">
      <summary class="run-log-summary">
        <span class="section-label">run log</span>
        <span class="section-hint" id="run-log-count">loading&hellip;</span>
      </summary>
      <div id="run-log-body" class="run-log-body">
        <div class="loading">loading&hellip;</div>
      </div>
    </details>
  </section>

  </div><!-- /radar-canvas -->

  <script type="module" define:vars={{ RAW, RADAR_REPO }}>
    // ═════════════════════════════════════════════════════════════════
    // AI Radar — v2 instrument view
    //
    // Three primary fetches run in parallel on load. Each hydrates its
    // section independently so a slow or failing source never blocks the
    // others. Sparkline scales are shared across rows (Opus honesty fix
    // — auto-scaling per row exaggerates noise into drama).
    // ═════════════════════════════════════════════════════════════════

    const MARKED_URL = 'https://cdn.jsdelivr.net/npm/marked@12.0.2/lib/marked.esm.js';
    const $ = (id) => document.getElementById(id);

    const showErr = (host, msg) => {
      host.innerHTML = `<div class="loading err">${msg}</div>`;
    };

    function escapeHtml(s) {
      return String(s || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function hoursAgo(iso) {
      const t = new Date(iso).getTime();
      if (!isFinite(t)) return null;
      return Math.round((Date.now() - t) / 3600000);
    }

    function fmtAge(hours) {
      if (hours == null) return '–';
      if (hours < 24) return `${hours}h`;
      const d = Math.floor(hours / 24);
      return d < 30 ? `${d}d` : `${Math.floor(d / 7)}w`;
    }

    // ─── Data holders shared across the three fetches ────────────
    // We normalize state.json into a Board Row shape here, then
    // whichever fetch finishes last populates the board.
    const STATE = { rows: null, latestMd: null, indexRows: null, todayDate: null };

    // ═════════════════════════════════════════════════════════════════
    // Fetch 1: state.json → board rows + status bar
    // ═════════════════════════════════════════════════════════════════
    (async () => {
      try {
        const res = await fetch(`${RAW}/data/state.json`, { cache: 'no-store' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const state = await res.json();

        const entries = Object.entries(state);
        $('status-tracked').textContent = String(entries.length);

        // Rows are the tracked items. Escalating = streak >= 3 with
        // rising magnitude (only possible once multi-day history exists).
        const rows = entries.map(([id, snap]) => {
          const history = Array.isArray(snap.mag_history) ? snap.mag_history : [];
          const first = history[0] || 0;
          const last = history[history.length - 1] || snap.mag || 0;
          const escalating = (snap.streak || 0) >= 3 && last > first;
          const pct = first > 0 ? ((last - first) / first) * 100 : 0;
          return {
            id,
            title: snap.title || '(untitled)',
            url: snap.url || '',
            score: snap.score || 0,
            mag: snap.mag || last,
            magHistory: history,
            streak: snap.streak || 1,
            firstSeen: snap.first_seen || null,
            escalating,
            pct,
          };
        });

        $('status-high').textContent = String(rows.filter((r) => r.score >= 3).length);

        STATE.rows = rows;
        renderBoardIfReady();
      } catch (err) {
        showErr($('board-body'), `Could not load state (${err.message})`);
        $('status-tracked').textContent = '–';
        $('status-high').textContent = '–';
      }
    })();

    // ═════════════════════════════════════════════════════════════════
    // Fetch 2: reports/latest.md → BRIEF + today's date + status window
    // ═════════════════════════════════════════════════════════════════
    (async () => {
      const briefHost = $('brief-body');
      try {
        const [{ marked }, res] = await Promise.all([
          import(MARKED_URL),
          fetch(`${RAW}/reports/latest.md`, { cache: 'no-store' }),
        ]);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        let md = await res.text();

        // Strip the radar:nav header that only makes sense on GitHub.
        md = md.replace(/<!-- radar:nav -->[\s\S]*?<!-- \/radar:nav -->\n*/g, '');

        // Extract the report date from the "# AI Radar — YYYY-MM-DD" header.
        const dateMatch = md.match(/^#\s*AI Radar\s*[—-]\s*(\d{4}-\d{2}-\d{2})/m);
        if (dateMatch) {
          STATE.todayDate = dateMatch[1];
          const dHours = hoursAgo(dateMatch[1] + 'T13:00:00Z');
          $('status-sync').textContent = fmtAge(dHours) + ' ago';
        }

        // ── Attribution ───────────────────────────────────────────
        // The digest.md prompt doesn't yet embed the generating model
        // by name — that's a follow-up PR on the ai-radar side. Until
        // then, we honestly attribute it to the workflow's default
        // backend (GitHub Models · gpt-4.1) and flag the timestamp.
        // NOTE: when digest.md is updated to include a footer line
        // like "Synthesized by <model> at <ISO>", parse it here.
        const attributionText = STATE.todayDate
          ? `machine synthesis · github models (gpt-4.1) · ${STATE.todayDate}`
          : 'machine synthesis · github models (gpt-4.1)';
        $('brief-attribution').textContent = attributionText;

        marked.setOptions({ gfm: true, breaks: false });
        // Strip the top-level H1 from the digest — the section header
        // "brief" already frames it, and repeating "AI Radar — 2026-07-02"
        // inside a page already titled AI Radar is diary redundancy.
        md = md.replace(/^#\s*AI Radar[^\n]*\n/, '');

        // ── Structured render ─────────────────────────────────────
        // The digest repeats every item in three places (sections,
        // insights, action items). Surface only the two parts that
        // carry unique information: the top-line paragraph and the
        // "new today" list. The full digest stays available behind a
        // toggle. If the format ever changes and parsing fails, fall
        // back to rendering the whole thing.
        const topline = md.match(/\*\*Top-line:?\*\*\s*\n+([\s\S]*?)\n\s*---/);
        const newToday = md.match(/\*\*New today\*\*\s*\n([\s\S]*?)(?:\n\s*---|\n\s*\*\*|\n###)/);

        if (topline) {
          const newItems = newToday
            ? newToday[1].split('\n')
                .map((l) => l.replace(/^\s*[-*]\s*/, '').trim())
                .filter(Boolean)
            : [];
          briefHost.innerHTML = `
            <p class="brief-lede">${marked.parseInline(topline[1].trim())}</p>
            ${newItems.length ? `
              <div class="brief-new-label">new today</div>
              <ul class="brief-new">
                ${newItems.map((item) => `<li>${marked.parseInline(item)}</li>`).join('')}
              </ul>` : ''}
            <details class="brief-full">
              <summary>full digest</summary>
              <div class="brief-full-body">${marked.parse(md)}</div>
            </details>`;
        } else {
          briefHost.innerHTML = marked.parse(md);
        }

        // Open external links in a new tab.
        briefHost.querySelectorAll('a[href^="http"]').forEach((a) => {
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
        });

        renderBoardIfReady();
      } catch (err) {
        showErr(briefHost, `Could not load brief (${err.message}).`);
      }
    })();

    // ═════════════════════════════════════════════════════════════════
    // Fetch 3: reports/README.md → run log
    // ═════════════════════════════════════════════════════════════════
    (async () => {
      try {
        const res = await fetch(`${RAW}/reports/README.md`, { cache: 'no-store' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const md = await res.text();

        const rows = [];
        for (const line of md.split('\n')) {
          const m = line.match(/^\|\s*\[(\d{4}-\d{2}-\d{2})\]\([^)]+\)\s*\|\s*(.+?)\s*\|\s*$/);
          if (m) rows.push({ date: m[1], teaser: m[2].replace(/…$/, '').trim() });
        }

        STATE.indexRows = rows;
        renderRunLog();
      } catch (err) {
        showErr($('run-log-body'), `Could not load run log (${err.message}).`);
      }
    })();

    function renderRunLog() {
      const host = $('run-log-body');
      if (!STATE.indexRows || STATE.indexRows.length === 0) {
        host.innerHTML = `<div class="empty">no runs recorded yet</div>`;
        return;
      }
      // Skip the newest (it's the current BRIEF above) and cap at 14.
      // Older runs live in the repo; this drawer is a recency check,
      // not an archive.
      const past = STATE.indexRows.slice(1, 15);
      $('run-log-count').textContent = `${STATE.indexRows.length - 1} prior run${STATE.indexRows.length - 1 === 1 ? '' : 's'}`;
      host.innerHTML = past.map((row) => `
        <a class="run-row" href="https://github.com/${RADAR_REPO}/blob/main/reports/${row.date}-digest.md"
           target="_blank" rel="noopener noreferrer">
          <time class="mono run-date">${row.date}</time>
          <span class="run-teaser">${escapeHtml(row.teaser)}</span>
        </a>
      `).join('');
    }

    // ═════════════════════════════════════════════════════════════════
    // THE BOARD
    // ═════════════════════════════════════════════════════════════════

    let currentSort = 'score';
    let showAll = false;
    let filterGroup = 'all';
    // Open with a short, high-signal list. Ten rows is scannable;
    // "show more" and "show all" are one click away.
    const HIGH_SCORE = 3;
    const FIRST_PAGE = 10;
    const PAGE = 20;
    let visibleCount = FIRST_PAGE;

    // Source groups, derived from the id prefix. This is the one
    // grouping the data actually supports; topic tags would be guesses
    // from titles and belong in the pipeline, not the client.
    const SOURCE_GROUPS = {
      papers:      ['arxiv', 'hfpaper'],
      models:      ['hfmodel', 'hfdataset'],
      repos:       ['ghrepo'],
      'lab posts': ['blog'],
    };

    function groupOf(id) {
      const prefix = id.split(':')[0].toLowerCase();
      for (const [group, prefixes] of Object.entries(SOURCE_GROUPS)) {
        if (prefixes.includes(prefix)) return group;
      }
      return 'other';
    }

    function renderBoardIfReady() {
      if (!STATE.rows) return;
      renderFilters();
      renderBoard(currentSort);
    }

    // Filter chips with live counts, computed over the current score
    // pool so the numbers always match what the board can show.
    function renderFilters() {
      const host = $('board-filters');
      const pool = showAll ? STATE.rows : STATE.rows.filter((r) => r.score >= HIGH_SCORE);
      const counts = {};
      pool.forEach((r) => {
        const g = groupOf(r.id);
        counts[g] = (counts[g] || 0) + 1;
      });
      const groups = ['all', ...Object.keys(SOURCE_GROUPS), ...(counts.other ? ['other'] : [])];
      host.innerHTML = groups.map((g) => {
        const n = g === 'all' ? pool.length : (counts[g] || 0);
        if (g !== 'all' && n === 0) return '';
        return `<button class="filter-chip" data-group="${g}"
          data-active="${g === filterGroup}">${g} <span class="chip-count">${n}</span></button>`;
      }).join('');
      host.querySelectorAll('.filter-chip').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          filterGroup = btn.getAttribute('data-group');
          visibleCount = FIRST_PAGE;
          renderBoardIfReady();
        });
      });
    }

    function sparkline(history, sharedMax) {
      const BLOCKS = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];
      // Shared max across the whole board so trajectories are comparable
      // row-to-row instead of each row dramatizing its own noise.
      const max = sharedMax || Math.max(...history, 1);
      return history.map((v) => {
        const idx = Math.min(7, Math.max(0, Math.floor((v / max) * 7)));
        return BLOCKS[idx];
      }).join('');
    }

    // The trend cell only claims a trajectory when one exists. A single
    // reading is labeled "new", not dressed up as a chart.
    function trendCell(r, sharedMax) {
      if (!r.magHistory || r.magHistory.length < 2) {
        return '<span class="trend-new" title="first reading, no history yet">new</span>';
      }
      const hasDelta = Math.abs(r.pct) > 0.5;
      const deltaStr = !hasDelta ? ''
        : r.pct > 0 ? `▲${Math.round(r.pct)}%`
        : `▼${Math.round(Math.abs(r.pct))}%`;
      const hot = r.escalating ? ' spark-hot' : '';
      const chip = r.escalating ? '<span class="chip chip-hot">rising</span>' : '';
      return `<span class="spark${hot}">${sparkline(r.magHistory, sharedMax)}</span>
        <span class="spark-delta">${deltaStr}</span>${chip}`;
    }

    function renderBoard(sort) {
      const host = $('board-body');
      if (!STATE.rows) return;
      const all = STATE.rows.slice();
      // Default view is high-signal only; "show all" reveals everything.
      let pool = showAll ? all : all.filter((r) => r.score >= HIGH_SCORE);
      if (filterGroup !== 'all') pool = pool.filter((r) => groupOf(r.id) === filterGroup);
      const cmp = {
        score: (a, b) => b.score - a.score || b.mag - a.mag,
        age:   (a, b) => (b.firstSeen || '').localeCompare(a.firstSeen || '') || b.score - a.score,
      }[sort] || ((a, b) => b.score - a.score);
      pool.sort(cmp);

      // The trend column only exists when the corpus has trajectories
      // to show. With a young pipeline nearly every row has a single
      // reading, and a column of identical "new" labels is noise, not
      // information. Suppress the whole column until at least a few
      // items have real multi-day history. Computed (and applied) before
      // the empty-pool early return below so the static header's column
      // layout never goes stale against the current filter/sort state.
      const withHistory = pool.filter((r) => r.magHistory && r.magHistory.length > 1).length;
      const showTrend = withHistory >= 3;
      document.querySelector('.board').classList.toggle('no-trend', !showTrend);

      const shown = pool.slice(0, visibleCount);
      if (shown.length === 0) {
        host.innerHTML = `<div class="empty">no items match the current filters.</div>`;
        $('board-foot').textContent = '';
        $('board-more').style.display = 'none';
        return;
      }

      // Shared sparkline max: one scale across the board.
      const sharedMax = Math.max(
        1,
        ...shown.flatMap((r) => (r.magHistory && r.magHistory.length ? r.magHistory : [r.mag || 0])),
      );

      host.innerHTML = shown.map((r) => `<a class="board-row ${r.escalating ? 'row-escalating' : ''}"
                    href="${escapeHtml(r.url)}"
                    target="_blank" rel="noopener noreferrer"
                    role="row">
          <span class="col-score" title="model relevance score, 0 to 5">${r.score}<span class="score-slash">/5</span></span>
          <span class="col-item">
            <span class="item-title">${escapeHtml(r.title)}</span>
            <span class="item-meta">${escapeHtml(sourceLabel(r.id))}</span>
          </span>
          ${showTrend ? `<span class="col-trend">${trendCell(r, sharedMax)}</span>` : ''}
          <span class="col-age mono">${r.firstSeen ? fmtAge(hoursAgo(r.firstSeen + 'T00:00:00Z')) : '–'}</span>
        </a>`).join('');

      const remaining = pool.length - shown.length;
      const more = $('board-more');
      if (remaining > 0) {
        more.style.display = '';
        more.textContent = `show ${Math.min(PAGE, remaining)} more (${remaining} left)`;
      } else {
        more.style.display = 'none';
      }

      const scopeStr = filterGroup === 'all' ? '' : ` in ${filterGroup}`;
      $('board-foot').textContent = showAll
        ? `showing ${shown.length} of ${pool.length}${scopeStr}, all scores`
        : `showing ${shown.length} of ${pool.length}${scopeStr}, ranked by model score. Items scoring below ${HIGH_SCORE} are hidden.`;
    }

    function sourceLabel(id) {
      const prefix = id.split(':')[0].toLowerCase();
      return {
        arxiv: 'arxiv',
        hfpaper: 'hf · paper',
        hfmodel: 'hf · model',
        hfdataset: 'hf · dataset',
        ghrepo: 'github',
        blog: 'lab blog',
      }[prefix] || prefix;
    }

    // ─── Sort + filter control wiring ────────────────────────────
    document.querySelectorAll('.board-sort[data-sort]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        currentSort = btn.getAttribute('data-sort');
        visibleCount = FIRST_PAGE;
        document.querySelectorAll('.board-sort[data-sort]').forEach((b) => {
          b.setAttribute('data-active', b === btn ? 'true' : 'false');
        });
        renderBoardIfReady();
      });
    });

    $('board-toggle').addEventListener('click', (e) => {
      e.preventDefault();
      showAll = !showAll;
      visibleCount = FIRST_PAGE;
      const t = $('board-toggle');
      t.setAttribute('data-active', String(showAll));
      t.textContent = showAll ? 'top only' : 'show all';
      renderBoardIfReady();
    });

    $('board-more').addEventListener('click', (e) => {
      e.preventDefault();
      visibleCount += PAGE;
      renderBoard(currentSort);
    });
  </script>
</Base>

<style is:global>
  /*
     is:global here is deliberate: half the DOM on this page is
     generated by client-side JS after hydration (board rows, sort
     chips). Astro's default scoped styles apply data-astro-cid-*
     attributes only to elements Astro rendered at build time, so
     dynamically-inserted elements would miss the scoping and appear
     unstyled. Going global for this one page keeps JS-generated markup
     consistent with the static markup.

     The class names are all radar-specific (board-row, item-title,
     etc.) so leakage into other pages is not a concern.

     ══════════════════════════════════════════════════════════════════
     Canvas: escape the site's 700px reading column for the instrument
     surfaces, but keep the BRIEF prose in a comfortable measure.
     ══════════════════════════════════════════════════════════════════ */

  .radar-canvas {
    /* Break out of the parent .container's max-width so the board can
       breathe. We negative-margin against the site container. The board
       goes to ~1024px; the BRIEF prose is still comfortable because it
       has its own .brief-body max-width below. */
    margin-left:  calc((100vw - min(1024px, 100vw - 2rem)) / 2 - 50vw + 50%);
    margin-right: calc((100vw - min(1024px, 100vw - 2rem)) / 2 - 50vw + 50%);
    width: min(1024px, 100vw - 2rem);
    max-width: 1024px;
  }

  @media (max-width: 900px) {
    /* On smaller viewports, don't force width; fall back to container. */
    .radar-canvas {
      margin-left: 0;
      margin-right: 0;
      width: 100%;
      max-width: 100%;
    }
  }

  /* ── Hero ─────────────────────────────────────────────────────── */

  .radar-hero {
    padding: var(--space-2xl) 0 var(--space-lg);
  }

  .hero-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: var(--text-page-title);
    font-weight: 500;
