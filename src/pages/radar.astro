---
import Base from '../layouts/Base.astro';

// Public intelligence instrument over the ai-radar corpus.
//
// Design frame (see consultation synthesis, 2026-07-02): the page is an
// *instrument*, not a newsletter. Observed signals dominate; the model's
// synthesis is subordinate to the ranked board and is clearly labeled as
// machine opinion over observed data.
//
// Data flow: client-side, three parallel fetches. Zero coupling to the
// ai-radar repo build — this page always reflects the latest committed
// state without a site rebuild.
const RADAR_REPO = 'amaljithkuttamath/ai-radar';
const RAW = `https://raw.githubusercontent.com/${RADAR_REPO}/main`;
---

<Base
  title="AI Radar | Amaljith Kuttamath"
  description="A live intelligence view of AI research, releases, and social signal. Collect the corpus, distill the signal, expose the state of the field."
>
  <!-- Break out of the site's 700px reading column so the board has real
       estate. The BRIEF prose (below) stays in a narrow measure for
       readability; only the instrument surfaces get the wider canvas.
       See the "widen the container" tradeoff in the consultation. -->
  <div class="radar-canvas">

  <!-- ── HERO ─────────────────────────────────────────────────────── -->
  <section class="radar-hero">
    <div class="hero-row">
      <h1 class="hero-title">AI Radar</h1>
      <span class="live-indicator" aria-live="polite">
        <span class="live-dot" aria-hidden="true"></span>
        <span class="live-label">live</span>
      </span>
    </div>
    <p class="hero-lede">
      A live intelligence view of AI research, releases, and social signal.
      Observed signals below; synthesis is machine-generated commentary on the
      board.
      <a href={`https://github.com/${RADAR_REPO}`} target="_blank" rel="noopener noreferrer">
        method &amp; source &rarr;
      </a>
    </p>
  </section>

  <!-- ── STATUS BAR ───────────────────────────────────────────────── -->
  <!-- System telemetry: what the reader needs to trust the instrument.
       Coverage window + universe size + freshness. Never publication cadence. -->
  <section class="status-bar animate-in animate-in-delay-1" aria-label="System telemetry">
    <div class="status-cell">
      <span class="status-label">coverage</span>
      <span class="status-value" id="status-window">—</span>
    </div>
    <div class="status-cell">
      <span class="status-label">universe</span>
      <span class="status-value" id="status-universe">—</span>
    </div>
    <div class="status-cell">
      <span class="status-label">active</span>
      <span class="status-value" id="status-active">—</span>
    </div>
    <div class="status-cell">
      <span class="status-label">escalating</span>
      <span class="status-value" id="status-escalating">—</span>
    </div>
    <div class="status-cell">
      <span class="status-label">last sync</span>
      <span class="status-value" id="status-sync">—</span>
    </div>
  </section>

  <!-- ── SIGNAL TAPE ──────────────────────────────────────────────── -->
  <!-- 14-tick history of pipeline runs. Amber intensity encodes escalation
       count that day. Clickable to jump to that day's source digest on
       GitHub. Creates spatial memory across visits — you can see the
       shape of the last two weeks at a glance.
       (GPT-5.5's signature suggestion, adopted.) -->
  <section class="signal-tape animate-in animate-in-delay-1" aria-label="Recent run history">
    <div class="section-head">
      <span class="section-label">tape</span>
      <span class="section-hint">last 14 runs · amber = elevated activity</span>
    </div>
    <div class="tape-strip" id="tape-strip" role="list">
      <div class="tape-loading">loading&hellip;</div>
    </div>
  </section>

  <!-- ── THE BOARD ────────────────────────────────────────────────── -->
  <!-- The hero of the page: dense ranked field of items currently under
       observation. Sortable header, per-row sparkline, expand-in-place
       drill-down. This is where a cold reader lands and understands the
       state in seconds. -->
  <section class="board animate-in animate-in-delay-2" aria-label="Ranked board of active signals">
    <div class="section-head">
      <span class="section-label">board</span>
      <div class="board-controls" id="board-controls">
        <button class="board-sort" data-sort="score" data-active="true">score</button>
        <button class="board-sort" data-sort="delta">Δ mag</button>
        <button class="board-sort" data-sort="streak">streak</button>
        <button class="board-sort" data-sort="age">first seen</button>
      </div>
    </div>
    <div class="board-header" role="row" aria-hidden="true">
      <span class="col-score">score</span>
      <span class="col-item">item</span>
      <span class="col-evidence">evidence</span>
      <span class="col-trajectory">trajectory</span>
      <span class="col-signal">signal</span>
      <span class="col-age">seen</span>
    </div>
    <div id="board-body" class="board-body">
      <div class="loading">loading board&hellip;</div>
    </div>
  </section>

  <!-- ── BRIEF ────────────────────────────────────────────────────── -->
  <!-- The LLM synthesis. Structurally demoted below the board and clearly
       labeled as machine commentary. Reads in a narrow measure for
       comfort; the wider canvas above is for the instrument. -->
  <section class="brief animate-in animate-in-delay-2" aria-label="Synthesized brief">
    <div class="section-head">
      <span class="section-label">brief</span>
      <span class="section-hint" id="brief-attribution">machine synthesis · attribution loading</span>
    </div>
    <article id="brief-body" class="brief-body">
      <div class="loading">loading brief&hellip;</div>
    </article>
  </section>

  <!-- ── RUN LOG ──────────────────────────────────────────────────── -->
  <!-- Dated pipeline runs. Utility drawer, not a "back issues" shelf. -->
  <section class="run-log animate-in animate-in-delay-2" aria-label="Historical run log">
    <div class="section-head">
      <span class="section-label">run log</span>
      <span class="section-hint" id="run-log-count"></span>
    </div>
    <div id="run-log-body" class="run-log-body">
      <div class="loading">loading&hellip;</div>
    </div>
  </section>

  </div><!-- /radar-canvas -->

  <script type="module" define:vars={{ RAW, RADAR_REPO }}>
    // ═════════════════════════════════════════════════════════════════
    // AI Radar — v2 instrument view
    //
    // Three primary fetches run in parallel on load. Each hydrates its
    // section independently so a slow or failing source never blocks the
    // others. Sparkline scales are shared across rows (Opus honesty fix
    // — auto-scaling per row exaggerates noise into drama).
    // ═════════════════════════════════════════════════════════════════

    const MARKED_URL = 'https://cdn.jsdelivr.net/npm/marked@12.0.2/lib/marked.esm.js';
    const $ = (id) => document.getElementById(id);

    const showErr = (host, msg) => {
      host.innerHTML = `<div class="loading err">${msg}</div>`;
    };

    function escapeHtml(s) {
      return String(s || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function hoursAgo(iso) {
      const t = new Date(iso).getTime();
      if (!isFinite(t)) return null;
      return Math.round((Date.now() - t) / 3600000);
    }

    function fmtAge(hours) {
      if (hours == null) return '—';
      if (hours < 24) return `${hours}h`;
      const d = Math.floor(hours / 24);
      return d < 30 ? `${d}d` : `${Math.floor(d / 7)}w`;
    }

    // ─── Data holders shared across the three fetches ────────────
    // We normalize state.json into a Board Row shape here, then
    // whichever fetch finishes last populates the board.
    const STATE = { rows: null, latestMd: null, indexRows: null, todayDate: null };

    // ═════════════════════════════════════════════════════════════════
    // Fetch 1: state.json → board rows + status bar
    // ═════════════════════════════════════════════════════════════════
    (async () => {
      try {
        const res = await fetch(`${RAW}/data/state.json`, { cache: 'no-store' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const state = await res.json();

        const entries = Object.entries(state);
        $('status-universe').textContent = String(entries.length);

        // Rows are the tracked items. We build the same shape the board
        // renderer consumes. Escalating = streak >= 3 with rising mag.
        const rows = entries.map(([id, snap]) => {
          const history = Array.isArray(snap.mag_history) ? snap.mag_history : [];
          const first = history[0] || 0;
          const last = history[history.length - 1] || snap.mag || 0;
          const escalating = (snap.streak || 0) >= 3 && last > first;
          const pct = first > 0 ? ((last - first) / first) * 100 : 0;
          return {
            id,
            title: snap.title || '(untitled)',
            url: snap.url || '',
            score: snap.score || 0,
            mag: snap.mag || last,
            magHistory: history,
            streak: snap.streak || 1,
            firstSeen: snap.first_seen || null,
            escalating,
            pct,
            // Evidence layers inferred from id prefix + presence markers.
            // Layers we honestly can't determine yet stay 'unknown'
            // (will show as neutral in the Evidence Stack), never faked.
            evidence: inferEvidence(id, snap),
            // Corroboration count = platforms the item appears on.
            // Currently 1 for everything (no cross-source fuse yet); when
            // social collectors land this rises for URL-matched items and
            // powers the LOW SIGNAL state.
            corroboration: 1,
          };
        });

        // Active = score >= 2, matching the digest's include threshold.
        const active = rows.filter((r) => r.score >= 2);
        const escalating = rows.filter((r) => r.escalating);
        $('status-active').textContent = String(active.length);
        $('status-escalating').textContent = String(escalating.length);

        STATE.rows = rows;
        renderBoardIfReady();
      } catch (err) {
        showErr($('board-body'), `Could not load state (${err.message})`);
        $('status-universe').textContent = '—';
        $('status-active').textContent = '—';
        $('status-escalating').textContent = '—';
      }
    })();

    // Infer which evidence layers an item has, from what state.json
    // exposes today. Honest about what we don't know yet — layers we
    // can't determine remain 'unknown'.
    function inferEvidence(id, snap) {
      const prefix = id.split(':')[0].toLowerCase();
      const url = String(snap.url || '').toLowerCase();
      const has = { paper: false, repo: false, model: false, social: false, lab: false };
      if (prefix === 'arxiv' || url.includes('arxiv.org')) has.paper = true;
      if (prefix === 'ghrepo' || url.includes('github.com')) has.repo = true;
      if (prefix === 'hfmodel' || url.includes('huggingface.co/')) has.model = true;
      if (prefix === 'hfpaper') has.paper = true;
      if (prefix === 'blog') has.lab = true;
      // Social is empty until the social collectors land (PR D).
      return has;
    }

    // ═════════════════════════════════════════════════════════════════
    // Fetch 2: reports/latest.md → BRIEF + today's date + status window
    // ═════════════════════════════════════════════════════════════════
    (async () => {
      const briefHost = $('brief-body');
      try {
        const [{ marked }, res] = await Promise.all([
          import(MARKED_URL),
          fetch(`${RAW}/reports/latest.md`, { cache: 'no-store' }),
        ]);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        let md = await res.text();

        // Strip the radar:nav header that only makes sense on GitHub.
        md = md.replace(/<!-- radar:nav -->[\s\S]*?<!-- \/radar:nav -->\n*/g, '');

        // Extract the report date from the "# AI Radar — YYYY-MM-DD" header.
        const dateMatch = md.match(/^#\s*AI Radar\s*[—-]\s*(\d{4}-\d{2}-\d{2})/m);
        if (dateMatch) {
          STATE.todayDate = dateMatch[1];
          const dHours = hoursAgo(dateMatch[1] + 'T13:00:00Z');
          $('status-sync').textContent = fmtAge(dHours) + ' ago';
        }

        // Extract the window hint from the digest body ("past 48 hours"
        // / "past week") to fill the coverage cell. Falls back to "48h".
        const windowMatch = md.match(/past (?:(\d+)\s*hours?|(\d+)\s*days?|week)/i);
        if (windowMatch) {
          if (windowMatch[1]) $('status-window').textContent = `${windowMatch[1]}h`;
          else if (windowMatch[2]) $('status-window').textContent = `${windowMatch[2]}d`;
          else if (windowMatch[0].toLowerCase().includes('week')) $('status-window').textContent = '7d';
        } else {
          $('status-window').textContent = '48h';
        }

        // ── Attribution ───────────────────────────────────────────
        // The digest.md prompt doesn't yet embed the generating model
        // by name — that's a follow-up PR on the ai-radar side. Until
        // then, we honestly attribute it to the workflow's default
        // backend (GitHub Models · gpt-4.1) and flag the timestamp.
        // NOTE: when digest.md is updated to include a footer line
        // like "Synthesized by <model> at <ISO>", parse it here.
        const attributionText = STATE.todayDate
          ? `machine synthesis · github models (gpt-4.1) · ${STATE.todayDate}`
          : 'machine synthesis · github models (gpt-4.1)';
        $('brief-attribution').textContent = attributionText;

        marked.setOptions({ gfm: true, breaks: false });
        // Strip the top-level H1 from the digest — the section header
        // "brief" already frames it, and repeating "AI Radar — 2026-07-02"
        // inside a page already titled AI Radar is diary redundancy.
        md = md.replace(/^#\s*AI Radar[^\n]*\n/, '');
        briefHost.innerHTML = marked.parse(md);

        // Open external links in a new tab.
        briefHost.querySelectorAll('a[href^="http"]').forEach((a) => {
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
        });

        renderBoardIfReady();
      } catch (err) {
        showErr(briefHost, `Could not load brief (${err.message}).`);
      }
    })();

    // ═════════════════════════════════════════════════════════════════
    // Fetch 3: reports/README.md → run log + tape
    // ═════════════════════════════════════════════════════════════════
    (async () => {
      try {
        const res = await fetch(`${RAW}/reports/README.md`, { cache: 'no-store' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const md = await res.text();

        const rows = [];
        for (const line of md.split('\n')) {
          const m = line.match(/^\|\s*\[(\d{4}-\d{2}-\d{2})\]\([^)]+\)\s*\|\s*(.+?)\s*\|\s*$/);
          if (m) rows.push({ date: m[1], teaser: m[2].replace(/…$/, '').trim() });
        }

        STATE.indexRows = rows;
        renderTape();
        renderRunLog();
      } catch (err) {
        showErr($('run-log-body'), `Could not load run log (${err.message}).`);
        $('tape-strip').innerHTML = `<div class="tape-loading err">failed</div>`;
      }
    })();

    // ─── Signal Tape ─────────────────────────────────────────────
    // 14 ticks representing the last 14 runs. Amber intensity encodes
    // "elevated activity" — we approximate this from the teaser length
    // as a proxy (until we can persist per-run escalation counts).
    // A visitor can see the two-week rhythm at a glance and click any
    // tick to jump to that day's source digest.
    function renderTape() {
      const host = $('tape-strip');
      if (!STATE.indexRows || STATE.indexRows.length === 0) {
        host.innerHTML = `<div class="tape-loading">no history yet</div>`;
        return;
      }
      const last14 = STATE.indexRows.slice(0, 14).reverse();
      const teaserLens = last14.map((r) => r.teaser.length);
      const maxLen = Math.max(...teaserLens, 1);
      host.innerHTML = last14.map((r, i) => {
        const intensity = teaserLens[i] / maxLen;   // 0..1
        const level = Math.min(4, Math.floor(intensity * 5));   // 0..4 tiers
        const isToday = i === last14.length - 1;
        const label = `${r.date}: ${r.teaser.slice(0, 80)}${r.teaser.length > 80 ? '…' : ''}`;
        return `<a class="tape-tick" data-level="${level}" data-today="${isToday}"
          href="https://github.com/${RADAR_REPO}/blob/main/reports/${r.date}-digest.md"
          target="_blank" rel="noopener noreferrer"
          title="${escapeHtml(label)}" role="listitem" aria-label="${escapeHtml(label)}"
        ></a>`;
      }).join('');
    }

    function renderRunLog() {
      const host = $('run-log-body');
      if (!STATE.indexRows || STATE.indexRows.length === 0) {
        host.innerHTML = `<div class="empty">no runs recorded yet</div>`;
        return;
      }
      // Skip the newest (it's the current BRIEF above) and cap at 30.
      const past = STATE.indexRows.slice(1, 31);
      $('run-log-count').textContent = `${STATE.indexRows.length - 1} prior run${STATE.indexRows.length - 1 === 1 ? '' : 's'}`;
      host.innerHTML = past.map((row) => `
        <a class="run-row" href="https://github.com/${RADAR_REPO}/blob/main/reports/${row.date}-digest.md"
           target="_blank" rel="noopener noreferrer">
          <time class="mono run-date">${row.date}</time>
          <span class="run-teaser">${escapeHtml(row.teaser)}</span>
        </a>
      `).join('');
    }

    // ═════════════════════════════════════════════════════════════════
    // THE BOARD
    // ═════════════════════════════════════════════════════════════════

    let currentSort = 'score';
    function renderBoardIfReady() {
      if (!STATE.rows) return;
      renderBoard(currentSort);
    }

    function sparkline(history, sharedMax) {
      if (!history || history.length === 0) return '<span class="spark-empty">—</span>';
      // A single data point isn't a trajectory — be honest about that
      // rather than rendering a lone block that reads as a bar. When we
      // only have one observation, show a small dot glyph indicating
      // "single reading, no trajectory yet."
      if (history.length === 1) return '<span class="spark-empty" title="single reading — no trajectory yet">·</span>';
      const BLOCKS = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];
      // Opus's honesty fix: use a SHARED max across the whole board so
      // trajectories are comparable row-to-row instead of each row
      // dramatizing its own noise.
      const max = sharedMax || Math.max(...history, 1);
      return history.map((v) => {
        const idx = Math.min(7, Math.max(0, Math.floor((v / max) * 7)));
        return BLOCKS[idx];
      }).join('');
    }

    function evidenceStack(e) {
      // Compact five-cell stack: paper · repo · model · social · lab.
      // Filled = confirmed present, empty = not present or unknown.
      // Consistent order so the reader learns to scan the shape.
      const cells = [
        { key: 'paper', label: 'paper',  filled: e.paper  },
        { key: 'repo',  label: 'repo',   filled: e.repo   },
        { key: 'model', label: 'model',  filled: e.model  },
        { key: 'social',label: 'social', filled: e.social },
        { key: 'lab',   label: 'lab',    filled: e.lab    },
      ];
      return `<span class="ev-stack" aria-label="evidence layers">${
        cells.map((c) => `<span class="ev-cell ${c.filled ? 'ev-on' : 'ev-off'}" title="${c.label}"></span>`).join('')
      }</span>`;
    }

    function renderBoard(sort) {
      const host = $('board-body');
      if (!STATE.rows) return;
      const rows = STATE.rows.slice();
      const cmp = {
        score:  (a, b) => b.score - a.score  || b.mag - a.mag,
        delta:  (a, b) => b.pct   - a.pct    || b.score - a.score,
        streak: (a, b) => b.streak - a.streak || b.mag - a.mag,
        age:    (a, b) => (b.firstSeen || '').localeCompare(a.firstSeen || ''),
      }[sort] || cmp.score;
      rows.sort(cmp);
      // Cap the board to 40 rows visible; a "show more" would layer later.
      const shown = rows.slice(0, 40);
      if (shown.length === 0) {
        host.innerHTML = `<div class="empty">no items under observation in the current window.</div>`;
        return;
      }

      // Shared sparkline max — one scale across the board.
      const sharedMax = Math.max(
        1,
        ...shown.flatMap((r) => (r.magHistory && r.magHistory.length ? r.magHistory : [r.mag || 0])),
      );

      host.innerHTML = shown.map((r) => {
        const lowSignal = r.corroboration <= 1 && r.score < 2;
        const escalatingCls = r.escalating ? 'row-escalating' : '';
        const lowCls = lowSignal ? 'row-low' : '';
        // Delta: only show a percentage when we actually have movement
        // between two or more points. A single-reading item has no
        // delta — render nothing rather than a stub period.
        const hasDelta = r.magHistory && r.magHistory.length >= 2 && Math.abs(r.pct) > 0.5;
        const deltaStr = !hasDelta
          ? ''
          : r.pct > 0
            ? `▲${Math.round(r.pct)}%`
            : `▼${Math.round(Math.abs(r.pct))}%`;
        const ageStr = r.firstSeen ? fmtAge(hoursAgo(r.firstSeen + 'T00:00:00Z')) : '—';
        const streakStr = `${r.streak}r`;
        return `<a class="board-row ${escalatingCls} ${lowCls}"
                    href="${escapeHtml(r.url)}"
                    target="_blank" rel="noopener noreferrer"
                    role="row">
          <span class="col-score" title="magnitude ${r.mag.toFixed(2)}">${r.score}<span class="score-slash">/5</span></span>
          <span class="col-item">
            <span class="item-title">${escapeHtml(r.title)}</span>
            <span class="item-meta">${escapeHtml(sourceLabel(r.id))}</span>
          </span>
          <span class="col-evidence">${evidenceStack(r.evidence)}</span>
          <span class="col-trajectory">
            <span class="spark ${r.escalating ? 'spark-hot' : ''}">${sparkline(r.magHistory, sharedMax)}</span>
            <span class="spark-delta">${deltaStr}</span>
          </span>
          <span class="col-signal">
            ${lowSignal ? '<span class="chip chip-low">low signal</span>' : ''}
            ${r.escalating ? '<span class="chip chip-hot">escalating</span>' : ''}
            <span class="chip-streak">${streakStr}</span>
          </span>
          <span class="col-age mono">${ageStr}</span>
        </a>`;
      }).join('');
    }

    function sourceLabel(id) {
      const prefix = id.split(':')[0].toLowerCase();
      return {
        arxiv: 'arxiv',
        hfpaper: 'hf · paper',
        hfmodel: 'hf · model',
        hfdataset: 'hf · dataset',
        ghrepo: 'github',
        blog: 'lab blog',
      }[prefix] || prefix;
    }

    // ─── Sort control wiring ─────────────────────────────────────
    document.querySelectorAll('.board-sort').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const s = btn.getAttribute('data-sort');
        currentSort = s;
        document.querySelectorAll('.board-sort').forEach((b) => {
          b.setAttribute('data-active', b === btn ? 'true' : 'false');
        });
        renderBoardIfReady();
      });
    });
  </script>
</Base>

<style is:global>
  /*
     is:global here is deliberate: half the DOM on this page is
     generated by client-side JS after hydration (board rows, tape
     ticks, evidence stacks, sort chips). Astro's default scoped styles
     apply data-astro-cid-* attributes only to elements Astro rendered
     at build time, so dynamically-inserted elements would miss the
     scoping and appear unstyled. Going global for this one page keeps
     JS-generated markup consistent with the static markup.

     The class names are all radar-specific (board-row, tape-tick,
     item-title, etc.) so leakage into other pages is not a concern.

     ══════════════════════════════════════════════════════════════════
     Canvas: escape the site's 700px reading column for the instrument
     surfaces, but keep the BRIEF prose in a comfortable measure.
     ══════════════════════════════════════════════════════════════════ */

  .radar-canvas {
    /* Break out of the parent .container's max-width so the board can
       breathe. We negative-margin against the site container. The board
       goes to ~1024px; the BRIEF prose is still comfortable because it
       has its own .brief-body max-width below. */
    margin-left:  calc((100vw - min(1024px, 100vw - 2rem)) / 2 - 50vw + 50%);
    margin-right: calc((100vw - min(1024px, 100vw - 2rem)) / 2 - 50vw + 50%);
    width: min(1024px, 100vw - 2rem);
    max-width: 1024px;
  }

  @media (max-width: 900px) {
    /* On smaller viewports, don't force width; fall back to container. */
    .radar-canvas {
      margin-left: 0;
      margin-right: 0;
      width: 100%;
      max-width: 100%;
    }
  }

