---
import Base from '../../layouts/Base.astro';
---

<Base title="Local Chat | Amaljith Kuttamath" description="Chat with a language model running entirely in your browser. No server, no API, nothing you type leaves this page. SmolLM2 on WebGPU via Transformers.js.">
  <div class="lc">
    <div class="lc-head">
      <h1>Chat with a Local Model</h1>
      <p>This is a real language model running entirely in your browser. No server, no API key, no data leaving this page. The weights download once from the Hugging Face CDN, get cached by your browser, and run on your GPU via WebGPU. It is a small model, so it is confidently wrong about plenty of things, which is half the lesson.</p>
    </div>

    <div class="lc-loader" id="loader">
      <div class="lc-loader-row">
        <select class="lc-select" id="model-select">
          <option value="HuggingFaceTB/SmolLM2-135M-Instruct" data-size="~120 MB">SmolLM2-135M (fast download, dimmer)</option>
          <option value="HuggingFaceTB/SmolLM2-360M-Instruct" data-size="~280 MB" selected>SmolLM2-360M (better answers)</option>
        </select>
        <button class="lc-btn" id="load-btn">Load model (~280 MB)</button>
        <span class="lc-device" id="device-badge"></span>
      </div>
      <div class="lc-progress" id="progress" style="display:none">
        <div class="lc-progress-bar" id="progress-bar"></div>
        <span class="lc-progress-text" id="progress-text">starting&hellip;</span>
      </div>
    </div>

    <div class="lc-thread" id="thread" style="display:none"></div>

    <form class="lc-inputrow" id="input-row" style="display:none">
      <input type="text" class="lc-textinput" id="user-input" placeholder="Say something to the model&hellip;" autocomplete="off" />
      <button type="submit" class="lc-btn" id="send-btn">Send</button>
    </form>

    <div class="lc-stats" id="stats"></div>

    <div class="lc-note">
      <strong>What you're looking at:</strong> a 4-bit quantized SmolLM2 running through <a href="https://huggingface.co/docs/transformers.js" target="_blank" rel="noopener noreferrer">Transformers.js</a> and ONNX Runtime Web, accelerated by WebGPU when your browser supports it (falls back to WASM, slower). Frontier models are roughly a thousand times bigger, which is why this one feels like chatting with a well-read goldfish. The architecture is the same. The difference is scale.
    </div>
  </div>
</Base>

<style>
  .lc { max-width: 760px; margin: 0 auto; }
  .lc-head { margin-bottom: var(--space-lg); }
  .lc-head h1 { font-size: var(--text-page-title); font-weight: 600; margin-bottom: 4px; }
  .lc-head p { color: var(--fg-muted); font-size: var(--text-small); line-height: 1.6; }

  .lc-loader {
    background: var(--bg-elevated); border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md); padding: 14px 16px; margin-bottom: var(--space-md);
  }
  .lc-loader-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .lc-select {
    background: var(--bg); color: var(--fg); border: 1px solid var(--fg-faint);
    padding: 6px 10px; border-radius: var(--radius-sm);
    font-family: var(--font-sans); font-size: var(--text-small);
  }
  :global(.lc-btn) {
    background: var(--accent-color); color: #fff; border: none;
    padding: 7px 18px; border-radius: var(--radius-sm); cursor: pointer;
    font-family: var(--font-sans); font-size: var(--text-small);
    transition: opacity var(--duration) var(--ease);
  }
  :global(.lc-btn:hover) { opacity: 0.85; }
  :global(.lc-btn:disabled) { opacity: 0.4; cursor: default; }
  .lc-device {
    font-family: var(--font-mono); font-size: var(--text-label);
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--fg-muted);
  }
  .lc-progress {
    margin-top: 12px; position: relative; height: 22px;
    background: var(--bg); border: 1px solid var(--fg-faint); border-radius: var(--radius-full);
    overflow: hidden;
  }
  .lc-progress-bar {
    position: absolute; inset: 0; width: 0%;
    background: var(--accent-color); opacity: 0.35;
    transition: width 0.2s ease;
  }
  .lc-progress-text {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: var(--text-label); color: var(--fg);
  }

  .lc-thread {
    display: flex; flex-direction: column; gap: 10px;
    margin-bottom: var(--space-md); min-height: 120px;
  }
  :global(.lc-msg) {
    max-width: 85%; padding: 8px 14px; border-radius: var(--radius-md);
    font-size: var(--text-small); line-height: 1.6; white-space: pre-wrap;
    word-break: break-word;
  }
  :global(.lc-msg.user) {
    align-self: flex-end;
    background: var(--accent-subtle); color: var(--fg);
    border: 1px solid color-mix(in srgb, var(--accent-color) 30%, transparent);
  }
  :global(.lc-msg.assistant) {
    align-self: flex-start;
    background: var(--bg-elevated); border: 1px solid var(--fg-faint); color: var(--fg);
  }
  :global(.lc-msg.assistant.thinking::after) {
    content: '\258B'; animation: lc-blink 1s steps(1) infinite;
    color: var(--accent-color);
  }
  @keyframes lc-blink { 50% { opacity: 0; } }

  .lc-inputrow { display: flex; gap: 10px; margin-bottom: 8px; }
  .lc-textinput {
    flex: 1; background: var(--bg-elevated); color: var(--fg);
    border: 1px solid var(--fg-faint); border-radius: var(--radius-sm);
    padding: 8px 12px; font-family: var(--font-sans); font-size: var(--text-small);
    transition: border-color var(--duration) var(--ease);
  }
  .lc-textinput:focus { outline: none; border-color: var(--accent-color); }

  .lc-stats {
    font-family: var(--font-mono); font-size: var(--text-label);
    color: var(--fg-muted); min-height: 1.4em; margin-bottom: var(--space-md);
  }

  .lc-note {
    padding: 10px 14px;
    background: var(--bg-elevated); border: 1px solid var(--fg-faint);
    border-radius: var(--radius-sm); font-size: var(--text-small);
    color: var(--fg-muted); line-height: 1.7;
  }
  .lc-note strong { color: var(--fg); }
</style>

<script is:inline type="module">
import { pipeline, TextStreamer, env } from 'https://cdn.jsdelivr.net/npm/@huggingface/transformers@3';

env.allowLocalModels = false;

const loadBtn = document.getElementById('load-btn');
const modelSelect = document.getElementById('model-select');
const deviceBadge = document.getElementById('device-badge');
const progress = document.getElementById('progress');
const progressBar = document.getElementById('progress-bar');
const progressText = document.getElementById('progress-text');
const thread = document.getElementById('thread');
const inputRow = document.getElementById('input-row');
const userInput = document.getElementById('user-input');
const sendBtn = document.getElementById('send-btn');
const statsEl = document.getElementById('stats');

// Probe actual GPU capability, not just API presence: some browsers expose
// navigator.gpu with no adapter behind it, and some adapters lack fp16.
let gpuAdapter = null;
try { gpuAdapter = navigator.gpu ? await navigator.gpu.requestAdapter() : null; } catch (e) { gpuAdapter = null; }
const hasWebGPU = !!gpuAdapter;
const hasF16 = hasWebGPU && gpuAdapter.features.has('shader-f16');
deviceBadge.textContent = hasWebGPU ? ('webgpu available' + (hasF16 ? '' : ' (no fp16)')) : 'no webgpu · wasm fallback (slow)';

modelSelect.addEventListener('change', () => {
  const opt = modelSelect.selectedOptions[0];
  loadBtn.textContent = 'Load model (' + opt.dataset.size + ')';
});

let generator = null;
let generating = false;
const messages = [
  { role: 'system', content: 'You are a small helpful language model running locally in the browser on a portfolio site. Keep answers short and friendly.' },
];

function addMsg(role, text) {
  const el = document.createElement('div');
  el.className = 'lc-msg ' + role;
  el.textContent = text;
  thread.appendChild(el);
  el.scrollIntoView({ behavior: 'smooth', block: 'end' });
  return el;
}

loadBtn.addEventListener('click', async () => {
  loadBtn.disabled = true;
  modelSelect.disabled = true;
  progress.style.display = 'block';

  // Try configs in order of preference; q4f16 only on GPUs that support fp16 shaders.
  const attempts = [];
  if (hasWebGPU && hasF16) attempts.push({ device: 'webgpu', dtype: 'q4f16' });
  if (hasWebGPU) attempts.push({ device: 'webgpu', dtype: 'q4' });
  attempts.push({ device: 'wasm', dtype: 'q8' });

  let activeDevice = null;
  const errors = [];
  for (const cfg of attempts) {
    const fileProgress = {};
    try {
      generator = await pipeline('text-generation', modelSelect.value, {
        dtype: cfg.dtype,
        device: cfg.device,
        progress_callback: (p) => {
          if (p.status === 'progress' && p.file) {
            fileProgress[p.file] = { loaded: p.loaded || 0, total: p.total || 0 };
            let loaded = 0, total = 0;
            for (const f of Object.values(fileProgress)) { loaded += f.loaded; total += f.total; }
            if (total > 0) {
              progressBar.style.width = Math.min(100, (loaded / total) * 100) + '%';
              progressText.textContent = (loaded / 1048576).toFixed(0) + ' / ' + (total / 1048576).toFixed(0) + ' MB (' + cfg.device + ' ' + cfg.dtype + ')';
            }
          } else if (p.status === 'ready') {
            progressText.textContent = 'compiling for ' + cfg.device + '…';
          }
        },
      });
      activeDevice = cfg.device + ' ' + cfg.dtype;
      break;
    } catch (err) {
      errors.push(cfg.device + '/' + cfg.dtype + ': ' + (err && err.message || err));
      generator = null;
      progressBar.style.width = '0%';
      progressText.textContent = cfg.device + ' ' + cfg.dtype + ' failed, trying next config…';
    }
  }

  if (!generator) {
    progressText.textContent = 'all configs failed — ' + errors.join(' | ');
    loadBtn.disabled = false;
    modelSelect.disabled = false;
    return;
  }
  deviceBadge.textContent = activeDevice;

  progress.style.display = 'none';
  document.getElementById('loader').style.display = 'none';
  thread.style.display = 'flex';
  inputRow.style.display = 'flex';
  addMsg('assistant', 'Hi! I’m a tiny model running on your ' + (hasWebGPU ? 'GPU' : 'CPU') + '. Ask me something. Keep your expectations proportional to my parameter count.');
  userInput.focus();
});

inputRow.addEventListener('submit', async (e) => {
  e.preventDefault();
  const text = userInput.value.trim();
  if (!text || generating || !generator) return;

  generating = true;
  sendBtn.disabled = true;
  userInput.value = '';
  addMsg('user', text);
  messages.push({ role: 'user', content: text });

  const el = addMsg('assistant', '');
  el.classList.add('thinking');

  let reply = '';
  let tokenCount = 0;
  const t0 = performance.now();
  const streamer = new TextStreamer(generator.tokenizer, {
    skip_prompt: true,
    skip_special_tokens: true,
    callback_function: (chunk) => {
      reply += chunk;
      tokenCount++;
      el.textContent = reply;
      el.scrollIntoView({ block: 'end' });
      const dt = (performance.now() - t0) / 1000;
      if (dt > 0.3) statsEl.textContent = (tokenCount / dt).toFixed(1) + ' tokens/sec on ' + deviceBadge.textContent;
    },
  });

  try {
    await generator(messages, { max_new_tokens: 256, do_sample: true, temperature: 0.7, top_p: 0.9, streamer });
    messages.push({ role: 'assistant', content: reply });
  } catch (err) {
    el.textContent = 'generation failed: ' + (err && err.message || err);
  }

  el.classList.remove('thinking');
  generating = false;
  sendBtn.disabled = false;
  userInput.focus();
});
</script>
