---
import Base from '../layouts/Base.astro';

const allPosts = import.meta.glob('./work/*.md', { eager: true }) as Record<string, any>;
const projectPosts = Object.entries(allPosts)
  .map(([path, mod]) => ({ ...mod, url: '/work/' + path.replace('./work/', '').replace('.md', '') }))
  .filter((p) => p.frontmatter.project === 'trust-bench')
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

const formatDateLong = (date: string) =>
  new Date(date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<Base
  title="Trust Bench | Amaljith Kuttamath"
  description="Open-source LLM trustworthiness profiler. Profile failure modes, diagnose root causes, apply targeted fixes."
>
  <div class="project-page animate-in">
    <!-- Header -->
    <header class="project-header">
      <div class="project-meta-row">
        <span class="status-pill">in progress</span>
        <a href="https://github.com/amaljithkuttamath/trust-bench" target="_blank" rel="noopener noreferrer" class="repo-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          <span>trust-bench</span>
        </a>
      </div>
      <h1>Trust Bench</h1>
      <p class="project-pitch">Open-source profiler that looks inside LLMs to find failure modes benchmarks miss. Profile, diagnose, repair.</p>
    </header>

    <!-- The thesis -->
    <section class="project-thesis">
      <p>Every LLM evaluation tool scores outputs. None of them tell you <em>why</em> a model fails. Trust Bench connects profiling, diagnosis, and repair into a single loop: extract trust signals from model internals, evaluate against peer-reviewed safety benchmarks, apply targeted fixes, verify they worked.</p>
      <p>Starting with Qwen3.5's hybrid attention architecture (alternating DeltaNet + GQA), which nobody has studied for trust properties. Training sparse autoencoders on these layers to find interpretable failure features.</p>
    </section>

    <!-- Progress timeline -->
    <section class="timeline-section">
      <div class="section-label">Progress</div>

      <div class="project-timeline">
        {projectPosts.map((post, i) => (
          <a href={post.url} class="timeline-entry">
            <div class="timeline-dot-col">
              <div class:list={['timeline-dot', { 'timeline-dot-latest': i === 0 }]} />
              {i < projectPosts.length - 1 && <div class="timeline-line" />}
            </div>
            <div class="timeline-content">
              <time class="mono">{formatDate(post.frontmatter.date)}</time>
              <span class="timeline-title">{post.frontmatter.title}</span>
              <span class="timeline-desc">{post.frontmatter.description}</span>
              {post.frontmatter.tags && (
                <div class="timeline-tags">
                  {post.frontmatter.tags.slice(0, 3).map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>

      {projectPosts.length === 0 && (
        <p class="empty-note">First entry coming soon.</p>
      )}
    </section>

    <!-- What's next -->
    <section class="next-section">
      <div class="section-label">What's next</div>
      <div class="next-card">
        <div class="next-items">
          <div class="next-item">
            <span class="next-marker">01</span>
            <div>
              <span class="next-item-title">SAE on DeltaNet layers</span>
              <span class="next-item-desc">Train sparse autoencoders on Qwen3.5's linear attention layers. Find interpretable features that predict trust failures.</span>
            </div>
          </div>
          <div class="next-item">
            <span class="next-marker">02</span>
            <div>
              <span class="next-item-title">Hybrid attention trust comparison</span>
              <span class="next-item-desc">Compare trust signal patterns between DeltaNet and GQA layers. Do different attention types fail differently?</span>
            </div>
          </div>
          <div class="next-item">
            <span class="next-marker">03</span>
            <div>
              <span class="next-item-title">Repair loop</span>
              <span class="next-item-desc">Apply RepE activation steering and Constitutional AI techniques. Profile before and after. Did the fix work?</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="arch-section">
      <div class="section-label">Architecture</div>
      <div class="arch-stages">
        <div class="arch-stage">
          <span class="arch-num">1</span>
          <div>
            <span class="arch-stage-title">Extract</span>
            <span class="arch-stage-desc">Pull trust signals from model internals. Entropy, layer activations, attention patterns, separated by attention type.</span>
          </div>
        </div>
        <div class="arch-connector">&darr;</div>
        <div class="arch-stage">
          <span class="arch-num">2</span>
          <div>
            <span class="arch-stage-title">Evaluate</span>
            <span class="arch-stage-desc">Score across TrustLLM dimensions: truthfulness, safety, fairness, robustness, privacy, machine ethics.</span>
          </div>
        </div>
        <div class="arch-connector">&darr;</div>
        <div class="arch-stage">
          <span class="arch-num">3</span>
          <div>
            <span class="arch-stage-title">Improve</span>
            <span class="arch-stage-desc">Apply targeted techniques (calibration, RepE steering, Constitutional AI). Re-evaluate. Close the loop.</span>
          </div>
        </div>
      </div>
    </section>
  </div>
</Base>

<style>
  .project-page {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  /* ── Header ── */
  .project-header {
    margin-bottom: var(--space-xl);
  }

  .project-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .status-pill {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-color);
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--accent-color);
    border-radius: 100px;
  }

  .repo-link {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    text-decoration: none;
    transition: color var(--duration) var(--ease);
  }

  .repo-link:hover {
    color: var(--accent-color);
  }

  .project-header h1 {
    font-family: var(--font-serif);
    font-size: var(--text-page-title);
    font-weight: 500;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .project-pitch {
    font-size: var(--text-body-lg);
    color: var(--fg-muted);
    line-height: 1.7;
    max-width: 560px;
    margin: 0;
  }

  /* ── Thesis ── */
  .project-thesis {
    margin-bottom: var(--space-xl);
    padding: var(--space-lg);
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
  }

  .project-thesis p {
    font-size: var(--text-body);
    color: var(--fg-muted);
    line-height: 1.8;
    margin: 0;
  }

  .project-thesis p + p {
    margin-top: 1rem;
  }

  .project-thesis em {
    font-family: var(--font-serif);
    color: var(--fg);
  }

  /* ── Section labels ── */
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin-bottom: 0.75rem;
  }

  /* ── Timeline ── */
  .timeline-section {
    margin-bottom: var(--space-xl);
  }

  .project-timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-entry {
    display: flex;
    gap: var(--space-md);
    text-decoration: none;
    color: var(--fg);
    padding: 0.5rem 0;
    transition: color var(--duration) var(--ease);
  }

  .timeline-entry:hover {
    color: var(--accent-color);
  }

  .timeline-entry:hover .timeline-title {
    color: var(--accent-color);
  }

  .timeline-dot-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.25rem;
    flex-shrink: 0;
    width: 1rem;
  }

  .timeline-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--fg-muted);
    flex-shrink: 0;
  }

  .timeline-dot-latest {
    background: var(--accent-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-color) 15%, transparent);
  }

  .timeline-line {
    width: 1px;
    flex: 1;
    background: var(--fg-faint);
    margin-top: 0.35rem;
  }

  .timeline-content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-bottom: var(--space-md);
  }

  .timeline-content time {
    font-size: var(--text-tag);
  }

  .timeline-title {
    font-size: var(--text-body);
    font-weight: 500;
    transition: color var(--duration) var(--ease);
  }

  .timeline-desc {
    font-size: var(--text-small);
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .timeline-tags {
    display: flex;
    gap: 0.25rem;
    margin-top: 0.25rem;
  }

  .empty-note {
    font-size: var(--text-small);
    color: var(--fg-muted);
    font-style: italic;
  }

  /* ── What's next ── */
  .next-section {
    margin-bottom: var(--space-xl);
  }

  .next-card {
    padding: var(--space-lg);
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
  }

  .next-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .next-item {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .next-marker {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
    flex-shrink: 0;
    padding-top: 0.1rem;
  }

  .next-item div {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .next-item-title {
    font-size: var(--text-body);
    font-weight: 500;
  }

  .next-item-desc {
    font-size: var(--text-small);
    color: var(--fg-muted);
    line-height: 1.5;
  }

  /* ── Architecture ── */
  .arch-section {
    margin-bottom: var(--space-xl);
  }

  .arch-stages {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .arch-stage {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    padding: 0.75rem var(--space-md);
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    width: 100%;
  }

  .arch-num {
    font-family: var(--font-mono);
    font-size: var(--text-section);
    font-weight: 500;
    color: var(--accent-color);
    flex-shrink: 0;
    line-height: 1;
    padding-top: 0.15rem;
  }

  .arch-stage div {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .arch-stage-title {
    font-size: var(--text-body);
    font-weight: 500;
  }

  .arch-stage-desc {
    font-size: var(--text-small);
    color: var(--fg-muted);
    line-height: 1.5;
  }

  .arch-connector {
    font-size: var(--text-small);
    color: var(--fg-muted);
    padding: 0.25rem 0;
    padding-left: 2.25rem;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .project-header h1 {
      font-size: var(--text-section);
    }
  }
</style>
