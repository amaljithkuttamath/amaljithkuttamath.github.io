---
import Base from '../layouts/Base.astro';
---

<Base title="microGPT Playground — Amaljith Kuttamath" description="Watch a tiny GPT learn to generate names — one character at a time, live in your browser.">
  <div class="pg">
    <div class="pg-head">
      <h1>microGPT Playground</h1>
      <p>This is a tiny GPT — the same architecture behind ChatGPT, Claude, and every other large language model — running entirely in your browser. It starts knowing nothing. You'll watch it learn, from random noise to inventing plausible human names, by training on 500 real names one character at a time. Every card below shows a different piece of the model's brain as it learns.</p>
      <p style="margin-top:8px">Read the <a href="/work/understanding-llms" style="color:var(--accent-color)">full explanation</a> of how every piece works.</p>
      <div class="pg-howto">
        <strong>How to use:</strong> Hit <strong>Train</strong> to start training automatically, or <strong>Step</strong> to advance one step at a time and watch each piece update. The cards below show what happens inside the model at every step. Tweak the knobs, hit <strong>Reset</strong>, and train again to see how they change the result.
      </div>
    </div>

    <div class="pg-controls" id="controls"></div>
    <textarea id="custom-text" class="pg-textarea" placeholder="One item per line..." style="display:none"></textarea>

    <!-- Fixed dashboard grid — nothing moves -->
    <div class="dash">
      <!-- Row 1: Story + progress -->
      <div class="card card-wide" id="card-story">
        <div class="card-title">What is the model doing?</div>
        <div id="story-content" class="story-content">Press <strong>Train</strong> or <strong>Step</strong> to start</div>
      </div>

      <!-- FORWARD PASS — data flows through the model -->
      <div class="phase-label" id="phase-forward">
        <span class="phase-tag">Forward Pass</span>
        <span class="phase-desc">Data flows through the model to make a prediction</span>
        <span class="phase-arrow">&#x2193;</span>
      </div>

      <div class="card card-wide" id="card-input">
        <div class="card-step">1</div>
        <div class="card-title">Turning Characters into Numbers <span class="card-hint">The model represents each character as a list of 16 numbers called an embedding</span></div>
        <div id="input-content"></div>
      </div>

      <div class="card card-wide" id="card-attention">
        <div class="card-step">2</div>
        <div class="card-title">Which Characters Matter? <span class="card-hint">The attention mechanism decides which earlier characters are relevant for predicting the next one</span></div>
        <div id="attn-content"></div>
      </div>

      <div class="card" id="card-mlp">
        <div class="card-step">3</div>
        <div class="card-title">Thinking It Through <span class="card-hint">64 neurons activate or stay silent based on the patterns they detect</span></div>
        <div id="mlp-content"></div>
      </div>

      <div class="card" id="card-output">
        <div class="card-step">4</div>
        <div class="card-title">Making a Prediction <span class="card-hint">The model assigns a probability to every possible next character</span></div>
        <svg id="output-svg"></svg>
        <div id="output-verdict" class="verdict"></div>
      </div>

      <!-- BACKWARD PASS — learning from mistakes -->
      <div class="phase-label" id="phase-backward">
        <span class="phase-tag phase-tag-back">Backward Pass</span>
        <span class="phase-desc">Error flows back through the model — each component learns how to improve</span>
        <span class="phase-arrow">&#x2191;</span>
      </div>

      <div class="card" id="card-loss">
        <div class="card-step" style="background:#6a3">5</div>
        <div class="card-title">How Wrong Was It? <span class="card-hint">The loss measures the gap between what the model predicted and the right answer</span></div>
        <div style="display:flex;gap:20px;flex-wrap:wrap;align-items:flex-start">
          <div style="flex:1;min-width:250px"><svg id="loss-svg"></svg></div>
          <div id="loss-explain" class="loss-explain"></div>
        </div>
      </div>

      <div class="card card-wide" id="card-update">
        <div class="card-step" style="background:#6a3">6</div>
        <div class="card-title">Learning from the Mistake <span class="card-hint">The optimizer adjusts each of the <span id="param-count-inline"></span> weights to make the model a little less wrong next time</span></div>
        <div id="update-content" class="stats-grid"></div>
      </div>

      <!-- RESULT -->
      <div class="phase-label">
        <span class="phase-tag phase-tag-result">Result</span>
        <span class="phase-desc">What can the model generate after this training?</span>
      </div>

      <div class="card" id="card-samples">
        <div class="card-title">Generated Names <span class="card-hint">These names are invented from scratch, not copied from training data</span></div>
        <pre id="samples-content" class="samples"></pre>
      </div>

      <div class="card" id="card-stats">
        <div class="card-title">Model Stats</div>
        <div id="stats-content" class="stats-grid"></div>
      </div>
    </div>
  </div>
</Base>

<style>
  .pg { max-width: 1100px; margin: 0 auto; }
  .pg-head { margin-bottom: var(--space-lg); }
  .pg-head h1 { font-size: var(--text-page-title); font-weight: 600; margin-bottom: 4px; }
  .pg-head p { color: var(--fg-muted); font-size: var(--text-small); line-height: 1.6; }
  .pg-howto {
    margin-top: 10px; padding: 10px 14px;
    background: var(--bg-elevated); border: 1px solid var(--fg-faint);
    border-radius: var(--radius-sm); font-size: var(--text-small);
    color: var(--fg-muted); line-height: 1.7;
  }
  .pg-howto strong { color: var(--fg); }

  .pg-controls {
    display: flex; flex-direction: column; gap: 10px;
    background: var(--bg-elevated); padding: 12px 16px;
    border-radius: var(--radius-md); margin-bottom: var(--space-md);
    border: 1px solid var(--fg-faint);
  }
  :global(.ctrl-row) {
    display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
  }
  :global(.ctrl-section) {
    border-top: 1px solid var(--fg-faint); padding-top: 8px;
  }
  :global(.ctrl-heading) {
    font-size: var(--text-label); font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.06em; margin-bottom: 8px; color: var(--fg);
  }
  :global(.ctrl-grid) {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px;
  }
  :global(.pg-knob) {
    display: flex; flex-direction: column; gap: 2px; cursor: default;
  }
  :global(.knob-name) {
    font-size: var(--text-small); font-weight: 600; color: var(--fg);
  }
  :global(.knob-desc) {
    font-size: var(--text-label); color: var(--fg-muted); line-height: 1.4;
  }
  :global(.knob-control) {
    display: flex; align-items: center; gap: 6px; margin-top: 2px;
  }
  :global(.knob-control input[type="range"]) { flex: 1; }
  :global(.knob-val) {
    font-family: var(--font-mono); font-size: var(--text-label);
    color: var(--fg); min-width: 36px; text-align: right;
  }
  :global(.pg-input) {
    width: 70px; background: var(--bg); color: var(--fg);
    border: 1px solid var(--fg-faint); border-radius: var(--radius-sm);
    padding: 4px 6px; font-family: var(--font-mono); font-size: var(--text-small);
    text-align: center;
  }
  .pg-textarea {
    width: 100%; height: 60px; background: var(--bg-elevated); color: var(--fg);
    border: 1px solid var(--fg-faint); border-radius: var(--radius-sm);
    padding: 8px; font-family: var(--font-mono); font-size: var(--text-small);
    margin-bottom: var(--space-md); resize: vertical;
  }

  /* Fixed dashboard grid */
  .dash {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .card {
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    min-height: 180px;
    overflow: hidden;
  }
  .card-wide { grid-column: 1 / -1; min-height: auto; }
  .card-title {
    font-size: var(--text-small);
    font-weight: 600;
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .card-hint {
    display: block;
    font-weight: 400;
    color: var(--fg-muted);
    font-size: var(--text-label);
    margin-top: 2px;
  }

  /* Step numbers */
  :global(.card-step) {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--accent-color); color: var(--bg);
    font-size: 0.7rem; font-weight: 700;
    float: left; margin-right: 8px; margin-top: 1px;
  }

  /* Phase labels between cards */
  .phase-label {
    grid-column: 1 / -1;
    display: flex; align-items: center; gap: 10px;
    padding: 8px 0;
  }
  .phase-tag {
    font-size: var(--text-label); font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--accent-color); color: var(--bg);
    padding: 3px 10px; border-radius: var(--radius-full);
    white-space: nowrap;
  }
  .phase-tag-back { background: #6a3; }
  .phase-tag-result { background: var(--fg-muted); }
  .phase-desc { font-size: var(--text-label); color: var(--fg-muted); }
  .phase-arrow { color: var(--fg-muted); font-size: 1rem; }

  /* Loss explanation */
  :global(.loss-explain) {
    font-size: var(--text-small); color: var(--fg-muted);
    line-height: 1.7; min-width: 180px;
    font-family: var(--font-mono);
  }

  /* Story card */
  .story-content {
    font-family: var(--font-mono);
    font-size: var(--text-small);
    line-height: 2;
  }
  :global(.ch) {
    display: inline-block; padding: 2px 6px; margin: 0 1px;
    border-radius: 4px; background: var(--accent-subtle); color: var(--accent-color);
    font-weight: 600; font-size: 0.9rem;
  }
  :global(.ch-active) { background: var(--accent-color); color: var(--bg); }
  :global(.ch-target) { background: var(--accent-color); color: var(--bg); opacity: 0.6; }
  :global(.right) { color: #6a6; font-weight: 600; }
  :global(.wrong) { color: #b55; font-weight: 600; }
  :global(.arrow) { color: var(--fg-muted); margin: 0 6px; }

  /* Loss chart */
  #card-loss { min-height: 200px; }
  #card-loss svg { width: 100%; height: 160px; }

  /* Input (embedding) */
  :global(.emb-row) { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  :global(.emb-label) { font-size: 0.7rem; color: var(--fg-muted); width: 80px; flex-shrink: 0; text-align: right; }
  :global(.emb-bar) { height: 18px; display: flex; gap: 1px; }
  :global(.emb-cell) { width: 16px; height: 18px; border-radius: 2px; }

  /* Attention */
  #card-attention { min-height: 220px; }

  /* MLP */
  :global(.mlp-bar-row) { display: flex; gap: 1px; align-items: flex-end; height: 80px; }
  :global(.mlp-bar) { width: 6px; border-radius: 1px 1px 0 0; }
  :global(.mlp-info) { font-size: 0.75rem; color: var(--fg-muted); margin-top: 6px; }

  /* Output */
  #card-output { min-height: 220px; }
  #card-output svg { width: 100%; height: 150px; }
  .verdict {
    font-size: var(--text-small);
    margin-top: 6px;
    font-family: var(--font-mono);
    min-height: 1.5em;
  }

  /* Samples */
  .samples {
    font-size: 0.9rem; color: var(--accent-color);
    line-height: 2; min-height: 120px;
    white-space: pre-wrap;
  }

  /* Stats */
  .stats-grid {
    display: grid; grid-template-columns: auto 1fr;
    gap: 4px 12px; font-size: var(--text-small);
    font-family: var(--font-mono);
  }
  :global(.stat-label) { color: var(--fg-muted); }
  :global(.stat-value) { color: var(--fg); }

  /* Buttons */
  :global(.pg-btn) {
    background: var(--accent-color); color: #fff; border: none;
    padding: 6px 16px; border-radius: var(--radius-sm); cursor: pointer;
    font-family: var(--font-sans); font-size: var(--text-small);
    transition: opacity 0.2s;
  }
  :global(.pg-btn:hover) { opacity: 0.85; }
  :global(.pg-btn.stop) { background: #b33; }
  :global(.pg-label) { font-size: var(--text-label); color: var(--fg-muted); display: flex; align-items: center; gap: 4px; }
  :global(.pg-select) {
    background: var(--bg-elevated); color: var(--fg); border: 1px solid var(--fg-faint);
    padding: 4px 8px; border-radius: var(--radius-sm); font-family: var(--font-sans); font-size: var(--text-label);
  }

  :global(.dash svg text) { fill: var(--fg); font-family: var(--font-sans); }
  :global(.dash svg .axis text) { font-size: 0.6rem; fill: var(--fg-muted); }
  :global(.dash svg .axis line), :global(.dash svg .axis path) { stroke: var(--fg-faint); }

  @media (max-width: 768px) {
    .dash { grid-template-columns: 1fr; }
    .card-wide { grid-column: 1; }
  }
</style>

<script is:inline src="https://d3js.org/d3.v7.min.js"></script>
<script is:inline>
// ============================================================
//  microGPT Playground
// ============================================================

// === PRNG ===
var _seed = 42;
function seedRandom(s) { _seed = s; }
function rng() {
  var t = _seed += 0x6D2B79F5;
  t = Math.imul(t ^ (t >>> 15), t | 1);
  t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
  return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
}
function gaussRng() {
  var u, v, s;
  do { u = 2*rng()-1; v = 2*rng()-1; s = u*u+v*v; } while (s >= 1 || s === 0);
  return u * Math.sqrt(-2*Math.log(s)/s);
}

// === Autograd ===
function V(data, ch, lg) { this.data=data; this.grad=0; this._ch=ch||[]; this._lg=lg||[]; }
V.prototype.add=function(o){o=o instanceof V?o:new V(o);return new V(this.data+o.data,[this,o],[1,1])};
V.prototype.mul=function(o){o=o instanceof V?o:new V(o);return new V(this.data*o.data,[this,o],[o.data,this.data])};
V.prototype.pow=function(n){return new V(this.data**n,[this],[n*this.data**(n-1)])};
V.prototype.log=function(){return new V(Math.log(this.data),[this],[1/this.data])};
V.prototype.exp=function(){var e=Math.exp(this.data);return new V(e,[this],[e])};
V.prototype.relu=function(){return new V(Math.max(0,this.data),[this],[this.data>0?1:0])};
V.prototype.neg=function(){return this.mul(-1)};
V.prototype.sub=function(o){o=o instanceof V?o:new V(o);return this.add(o.neg())};
V.prototype.div=function(o){o=o instanceof V?o:new V(o);return this.mul(o.pow(-1))};
V.prototype.backward=function(){
  var topo=[],vis=new Set();
  function build(v){if(!vis.has(v)){vis.add(v);for(var c of v._ch)build(c);topo.push(v)}}
  build(this);this.grad=1;
  for(var i=topo.length-1;i>=0;i--){var v=topo[i];for(var j=0;j<v._ch.length;j++)v._ch[j].grad+=v._lg[j]*v.grad}
};

// === Model ===
function vadd(a,b){return a.map(function(ai,i){return ai.add(b[i])})}
function linear(x,w){return w.map(function(wo){var s=wo[0].mul(x[0]);for(var i=1;i<x.length;i++)s=s.add(wo[i].mul(x[i]));return s})}
function softmax(L){var mx=-1e30;for(var i=0;i<L.length;i++)if(L[i].data>mx)mx=L[i].data;var ex=L.map(function(v){return v.sub(mx).exp()});var t=ex[0];for(var i=1;i<ex.length;i++)t=t.add(ex[i]);return ex.map(function(e){return e.div(t)})}
function rmsn(x){var ms=x[0].mul(x[0]);for(var i=1;i<x.length;i++)ms=ms.add(x[i].mul(x[i]));return x.map(function(xi){return xi.mul(ms.mul(1/x.length).add(1e-5).pow(-0.5))})}

var NL=1,NE=16,BS=16,NH=4,HD=4;
function mat(r,c,std){std=std||.08;return Array.from({length:r},function(){return Array.from({length:c},function(){return new V(gaussRng()*std)})})}
function initModel(){
  var sd={wte:mat(vocabSize,NE),wpe:mat(BS,NE),lm_head:mat(vocabSize,NE)};
  for(var i=0;i<NL;i++){sd['l'+i+'qw']=mat(NE,NE);sd['l'+i+'kw']=mat(NE,NE);sd['l'+i+'vw']=mat(NE,NE);sd['l'+i+'ow']=mat(NE,NE);sd['l'+i+'f1']=mat(4*NE,NE);sd['l'+i+'f2']=mat(NE,4*NE)}
  return sd;
}

function gpt(tid,pid,ks,vs,sd){
  var te=sd.wte[tid],pe=sd.wpe[pid],x=vadd(te,pe);x=rmsn(x);
  var inter={tokEmb:te.map(function(v){return v.data}),posEmb:pe.map(function(v){return v.data}),combined:x.map(function(v){return v.data}),layers:[]};
  for(var li=0;li<NL;li++){
    var info={attnW:[]},xr=x;x=rmsn(x);
    var q=linear(x,sd['l'+li+'qw']),k=linear(x,sd['l'+li+'kw']),v=linear(x,sd['l'+li+'vw']);
    ks[li].push(k);vs[li].push(v);
    var xa=[];
    for(var h=0;h<NH;h++){var hs=h*HD,qh=q.slice(hs,hs+HD);
      var kh=ks[li].map(function(ki){return ki.slice(hs,hs+HD)});
      var vh=vs[li].map(function(vi){return vi.slice(hs,hs+HD)});
      var al=kh.map(function(kt){var d=qh[0].mul(kt[0]);for(var j=1;j<HD;j++)d=d.add(qh[j].mul(kt[j]));return d.mul(1/Math.sqrt(HD))});
      var aw=softmax(al);info.attnW.push(aw.map(function(w){return w.data}));
      for(var j=0;j<HD;j++){var o=aw[0].mul(vh[0][j]);for(var t=1;t<vh.length;t++)o=o.add(aw[t].mul(vh[t][j]));xa.push(o)}}
    x=vadd(linear(xa,sd['l'+li+'ow']),xr);
    var xr2=x;x=rmsn(x);
    var mh=linear(x,sd['l'+li+'f1']);info.preRelu=mh.map(function(v){return v.data});
    mh=mh.map(function(v){return v.relu()});info.postRelu=mh.map(function(v){return v.data});
    x=vadd(linear(mh,sd['l'+li+'f2']),xr2);inter.layers.push(info)}
  var logits=linear(x,sd.lm_head);inter.logits=logits.map(function(v){return v.data});
  return{logits:logits,intermediates:inter};
}

// === Data ===
var NAMES="emma,olivia,ava,isabella,sophia,charlotte,mia,amelia,harper,evelyn,abigail,emily,elizabeth,mila,ella,avery,sofia,camila,aria,scarlett,victoria,madison,luna,grace,chloe,penelope,layla,riley,zoey,nora,lily,eleanor,hannah,lillian,addison,aubrey,ellie,stella,natalie,zoe,leah,hazel,violet,aurora,savannah,audrey,brooklyn,bella,claire,skylar,lucy,paisley,everly,anna,caroline,nova,genesis,emilia,kennedy,samantha,maya,willow,kinsley,naomi,aaliyah,elena,sarah,ariana,allison,gabriella,alice,madelyn,cora,ruby,eva,serenity,autumn,adeline,hailey,gianna,valentina,isla,eliana,quinn,nevaeh,ivy,sadie,piper,lydia,alexa,josephine,emery,julia,delilah,arianna,vivian,kaylee,sophie,brielle,madeline,peyton,rylee,clara,hadley,melanie,mackenzie,reagan,adalynn,liliana,aubree,jade,katherine,isabelle,natalia,raelynn,maria,athena,ximena,arya,leilani,taylor,faith,rose,kylie,alexandra,mary,margaret,lyla,ashley,amaya,eliza,brianna,bailey,andrea,khloe,jasmine,melody,iris,isabel,norah,annabelle,valeria,emerson,adalyn,ryleigh,eden,emersyn,anastasia,kayla,alyssa,juliana,charlie,esther,ariel,cecilia,valerie,alina,molly,reese,aliyah,lilly,parker,finley,morgan,sydney,jordyn,eloise,trinity,daisy,kimberly,lauren,genevieve,sara,arabella,harmony,elise,remi,teagan,alexis,london,sloane,laila,lucia,diana,juliette,sienna,elliana,londyn,ayla,callie,gracie,josie,amara,jocelyn,daniela,everleigh,mya,rachel,summer,alana,brooke,alaina,mckenzie,catherine,amy,presley,journee,rosalie,ember,brynlee,rowan,joanna,paige,rebecca,ana,sawyer,mariah,nicole,brooklynn,payton,marley,fiona,georgia,lila,harley,adelyn,alivia,noelle,gemma,vanessa,journey,makayla,angelina,adaline,catalina,alayna,julianna,leila,lola,adriana,june,juliet,jayla,river,tessa,lia,dakota,delaney,selena,blakely,ada,camille,zara,malia,hope,samara,vera,mckenna,briella,izabella,hayden,raegan,michelle,angela,ruth,freya,kamila,vivienne,aspen,olive,kendall,elaina,thea,kali,destiny,amiyah,evangeline,cali,blake,elsie,juniper,alexandria,myla,ariella,kate,mariana