---
import Base from '../../layouts/Base.astro';
import { PROVIDERS } from '../../lib/chitti/providers';
import { sourcesByCategory } from '../../lib/chitti/tools';

const SOURCE_GROUPS = sourcesByCategory();
const SOURCE_COUNT = SOURCE_GROUPS.reduce((n, g) => n + g.sources.length, 0);
import indicatorsData from '../../data/worldbank/indicators.json';

// Curated indicators flattened for the client-side id → name lookup used in
// citations. Passed in as a JSON island so the runtime script can enrich ids.
const indicatorMap: Record<string, string> = {};
for (const topic of Object.keys(indicatorsData as Record<string, [string, string][]>)) {
  for (const [id, name] of (indicatorsData as Record<string, [string, string][]>)[topic]) {
    indicatorMap[id] = name;
  }
}

const PRESETS = [
  'Which countries reduced child mortality the most since 2000?',
  'How has global life expectancy changed since 1960, by region?',
  'Compare GDP per capita of India, China, and Brazil since 1990',
  'What does GDP per capita (PPP) actually measure, and why does PPP matter?',
];
---

<Base
  title="Chitti · Amaljith Kuttamath"
  description="Ask about the world, get real numbers — charted, cited, and computed live from World Bank, Our World in Data, and IMF APIs. Browser-only, bring your own key."
  ogImage="/images/chitti-og.png"
>
  <!-- PWA: make Chitti installable, scoped to /apps/chitti/ only (not the
       whole portfolio). Manifest + Apple/standalone metas live in <head>. -->
  <Fragment slot="head">
    <link rel="manifest" href="/apps/chitti/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/apps/chitti/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Chitti" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  </Fragment>

  <div class="ch">
    <!-- Header -->
    <header class="ch-head">
      <div class="ch-title-row">
        <h1>Chitti</h1>
        <div class="ch-badges">
          <span class="badge">world bank</span>
          <span class="badge">browser-only</span>
          <span class="badge">byok</span>
          <span class="badge">cited</span>
        </div>
        <!-- Dashboards entry point: opens the saved-dashboards view. The count
             appears only once at least one dashboard exists. -->
        <button type="button" class="ch-dash-nav" id="ch-dash-nav" aria-label="Open dashboards">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          <span>Dashboards</span>
          <span class="ch-dash-nav-count" id="ch-dash-nav-count" hidden></span>
        </button>
      </div>
      <p class="ch-subtitle">Real answers about the world, charted and cited.</p>
    </header>

    <!-- Setup / empty state: shown only while the thread is empty. Holds the
         suggested-question chips and the BYOK connection panel. The actual
         message input is the always-present bottom composer (#ch-composer);
         the #ch-ask form below stays in the DOM (visually collapsed) purely as
         the submit target the composer delegates to, so all the existing
         submit/read-question plumbing keeps working unchanged. -->
    <section class="ch-console" id="ch-console">
      <div class="ch-welcome">
        <h2 class="ch-welcome-title">Ask about the world</h2>
        <p class="ch-welcome-sub">
          Real numbers from the World Bank, charted and cited — or a plain
          prose answer when a chart isn't the point. Start with a question,
          or try one of these.
        </p>
      </div>
      <form class="ch-ask" id="ch-ask" autocomplete="off">
        <textarea
          id="ch-q"
          class="ch-q"
          rows="2"
          placeholder="Which countries reduced child mortality the most since 2000?"
          spellcheck="false"
        ></textarea>
        <div class="ch-ask-foot">
          <div class="ch-chips" id="ch-chips">
            {PRESETS.map((p) => (
              <button type="button" class="ch-chip" data-q={p}>{p}</button>
            ))}
          </div>
        </div>
      </form>
    </section>

    <template id="ch-turn-template">
      <div class="ch-turn">
        <!-- Shared-answer banner (backlog #15): shown only when this turn was
             restored from a #share= permalink, never on a live run. Muted, not
             amber — this is a frozen snapshot, not a fresh verified answer. Its
             text is set by renderShareBanner(); the link clears the fragment. -->
        <div class="ch-share-banner" style="display:none" role="note"></div>

        <!-- The user's question, shown chat-style at the top of the turn. -->
        <p class="ch-turn-q" style="display:none"></p>

        <!-- Status line (loading/error only; success reads from the answer).
             role="status" (polite live region) so the run's progress and its
             final "Done"/error is announced without a screen-reader user
             watching the screen. The streaming trace below is NOT a live
             region — it re-renders wholesale each frame and would spam. -->
        <div class="ch-status" style="display:none" role="status" aria-live="polite" aria-atomic="true">
          <span class="ch-status-dot" aria-hidden="true"></span>
          <span class="ch-status-msg">Planning…</span>
          <!-- Stop control: shown only while THIS turn is running. A real button
               (keyboard-reachable, focus-visible), mono/muted to match the
               receipt style — never amber. Clicking aborts the turn; the run
               ends in an honest "stopped by you" state and the state change is
               announced through this same polite status line. -->
          <button type="button" class="ch-stop" style="display:none" aria-label="Stop this run">stop</button>
        </div>

        <!-- The agent's work comes first — reasoning, then answer, reading
             top to bottom like the work actually happened. Collapsed to a
             single line: the summary shows the live step while running,
             then the step/token/cost totals; expanding reveals the full
             receipt-style trace. -->
        <details class="ch-panel" style="display:none">
          <summary class="ch-panel-sum">
            <span class="ch-panel-dot"></span>
            <span class="ch-panel-label">Working…</span>
            <span class="ch-render-flag" style="display:none">rendering…</span>
            <span class="ch-panel-meta">
              <span class="ch-rail-total" style="display:none"></span>
              <span class="ch-rail-model"></span>
            </span>
          </summary>
          <div class="ch-rail-body">
            <div class="ch-trace"></div>
          </div>
        </details>

        <!-- The answer, after the reasoning. A <div>, not <p>, because
             explanation answers render markdown (paragraphs/lists) as
             block elements. -->
        <section class="ch-answer" style="display:none" role="region" aria-label="Answer">
          <div class="ch-finding"></div>
          <!-- Answer-level verification cue: hidden on a genuine pass (the amber
               VERIFIED stamp lives in the trace receipt), a muted dashed tag on
               "could not verify", and a muted dotted tag on "verification
               unavailable". Built by renderVerification(); never amber. -->
          <div class="ch-verify" style="display:none"></div>
        </section>

        <!-- Chart: full width, mounts live while the agent works. Hidden
             (ch-canvas-pending) until render_chart actually produces one. -->
        <div class="ch-canvas ch-canvas-pending">
          <figure class="ch-chart-card">
            <figcaption class="ch-chart-head">
              <span class="ch-chart-title"></span>
              <span class="ch-chart-unit"></span>
            </figcaption>
            <!-- Canvas is opaque to assistive tech; role="img" + a computed
                 aria-label (set in renderChart) give it a text summary. -->
            <div class="ch-chart" role="img"></div>
          </figure>
        </div>

        <!-- Supporting evidence: raw data + citations, below the chart. -->
        <section class="ch-meta" style="display:none">
          <details class="ch-data" style="display:none">
            <!-- The CSV button lives in the disclosure body, not the <summary>:
                 an interactive control nested inside another (the summary is
                 itself a button) is invalid and unreachable for some AT. -->
            <summary>Raw data (<span class="ch-data-count">0</span> rows)</summary>
            <div class="ch-data-actions">
              <button type="button" class="ch-pin" style="display:none" aria-haspopup="dialog" aria-label="Pin this chart to a dashboard">Pin to dashboard</button>
              <button type="button" class="ch-share" style="display:none" aria-label="Copy a shareable link to this answer">Share link</button>
              <button type="button" class="ch-csv">Download CSV</button>
            </div>
            <!-- aria-live region for the "copied" confirmation, announced to
                 screen readers without moving focus. -->
            <span class="ch-share-status" role="status" aria-live="polite"></span>
            <div class="ch-table-scroll">
              <table class="ch-table"></table>
            </div>
          </details>

          <div class="ch-cite" style="display:none"></div>
        </section>
      </div>
    </template>

    <div class="ch-thread" id="ch-thread"></div>

    <!-- Unified input bar, Codex/Perplexity/Claude style: one rounded
         container with the textarea on top and a control row along the bottom.
         The model/key picker chip lives inline on the left of that row; the
         send button on the right. The config panel expands above, toggled by
         the chip (a button, not <details>, so it can live inside the form). -->
    <div class="ch-inputbar" id="ch-inputbar">
      <!-- Backdrop for the mobile bottom sheet. iOS Safari doesn't bubble
           click events from non-interactive page areas to document, so
           outside-tap-to-close needs a real element with its own listener. -->
      <div class="ch-byok-backdrop" id="ch-byok-backdrop" hidden></div>
      <div class="ch-byok" id="ch-byok" hidden role="dialog" aria-modal="true" aria-labelledby="ch-byok-title" tabindex="-1">
        <div class="ch-byok-body">
          <div class="ch-byok-head">
            <span class="ch-byok-title" id="ch-byok-title">Connect</span>
            <button type="button" class="ch-byok-close" id="ch-byok-close" aria-label="Close">✕</button>
          </div>

          <!-- Key first: the one required credential sits at the top, so the
               mobile keyboard opens under it instead of hiding it. -->
          <label class="ch-field ch-field-grow ch-byok-keyfield">
            <span class="ch-field-label">API key</span>
            <input
              type="password"
              id="ch-key"
              class="ch-input"
              placeholder="sk-… (never leaves your browser)"
              spellcheck="false"
              autocomplete="off"
            />
          </label>
          <div class="ch-byok-row ch-byok-foot">
            <label class="ch-save">
              <input type="checkbox" id="ch-save" />
              <span>Save key for this session</span>
            </label>
            <div class="ch-keylinks" id="ch-keylinks"></div>
          </div>

          <!-- Model + databases: collapsed by default (keeps the sheet short on
               mobile), auto-revealed once a key is set; the toggle opens them
               anytime (e.g. to switch provider before entering a key). -->
          <button type="button" class="ch-byok-more" id="ch-byok-more" aria-expanded="false" aria-controls="ch-byok-settings">
            <span class="ch-byok-more-caret" aria-hidden="true"></span>
            Model &amp; databases
          </button>
          <div class="ch-byok-settings" id="ch-byok-settings" hidden>
            <div class="ch-byok-row">
              <label class="ch-field ch-field-grow">
                <span class="ch-field-label">Provider</span>
                <select id="ch-provider" class="ch-select">
                  {PROVIDERS.map((p) => (
                    <option value={p.id}>{p.label}</option>
                  ))}
                </select>
              </label>
            </div>
            <p class="ch-provider-note" id="ch-provider-note" style="display:none"></p>

            <!-- Model picker: searchable + scrollable, mirroring the database
                 picker below. Shows each model's human name, a free badge,
                 context length, and prompt/completion pricing per 1M tokens
                 (from the live OpenRouter catalog; curated fallback offline).
                 The hidden <select id="ch-model"> stays the state source of
                 truth so all existing wiring keeps working unchanged. -->
            <div class="ch-byok-row ch-model-row">
              <div class="ch-modelpick" id="ch-modelpick">
                <div class="ch-modelpick-top">
                  <span class="ch-field-label" id="ch-modelpick-label">Model</span>
                  <span class="ch-modelpick-count" id="ch-modelpick-count"></span>
                </div>
                <input
                  type="search"
                  class="ch-modelpick-search"
                  id="ch-model-search"
                  placeholder="Search models…"
                  aria-label="Search models"
                  autocomplete="off"
                  spellcheck="false"
                />
                <div class="ch-modelpick-list" id="ch-modelpick-list" role="group" aria-labelledby="ch-modelpick-label"></div>
                <p class="ch-modelpick-empty" id="ch-modelpick-empty" hidden>No models match.</p>
                <select id="ch-model" class="ch-select" hidden aria-hidden="true" tabindex="-1"></select>
              </div>
            </div>

          <!-- Database picker. Hard filter: Chitti answers only from the
               selected databases. Built from the source registry (tools.ts),
               grouped by category and searchable so it scales as databases are
               added. Locked once a conversation starts; "+ new conversation"
               re-enables it. -->
          <div class="ch-byok-row ch-sources-row">
            <div class="ch-sources" id="ch-sources" role="group" aria-label="Databases Chitti can answer from">
              <div class="ch-sources-top">
                <span class="ch-field-label">Databases</span>
                <span class="ch-sources-count" id="ch-sources-count">{SOURCE_COUNT} of {SOURCE_COUNT}</span>
                <div class="ch-sources-acts">
                  <button type="button" class="ch-sources-act" id="ch-sources-all">All</button>
                  <button type="button" class="ch-sources-act" id="ch-sources-none">Clear</button>
                </div>
              </div>
              <input
                type="search"
                class="ch-sources-search"
                id="ch-sources-search"
                placeholder="Filter databases…"
                aria-label="Filter databases"
                autocomplete="off"
                spellcheck="false"
              />
              <div class="ch-sources-list" id="ch-sources-list">
                {SOURCE_GROUPS.map((g) => (
                  <div class="ch-source-group" data-cat={g.category}>
                    <div class="ch-source-cat">{g.category}</div>
                    {g.sources.map((s) => (
                      <button
                        type="button"
                        class="ch-source-item is-on"
                        data-source={s.id}
                        data-search={`${s.label} ${s.blurb} ${g.category}`.toLowerCase()}
                        aria-pressed="true"
                      >
                        <span class="ch-source-check" aria-hidden="true"></span>
                        <span class="ch-source-text">
                          <span class="ch-source-name">{s.label}</span>
                          <span class="ch-source-blurb">{s.blurb}</span>
                        </span>
                      </button>
                    ))}
                  </div>
                ))}
                <p class="ch-sources-empty" id="ch-sources-empty" hidden>No databases match.</p>
              </div>
              <p class="ch-sources-hint" id="ch-sources-hint">Chitti answers only from the selected databases.</p>
            </div>
          </div>

          <!-- Judgment calls: off by default. Each one is a second, nested
               completion billed to the user's own key, so the user opts in.
               Locks with the database picker on the first ask. -->
          <div class="ch-byok-row ch-rlm-row">
            <div class="ch-rlm" id="ch-rlm">
              <label class="ch-save">
                <input type="checkbox" id="ch-rlm-toggle" />
                <span>Let code make judgment calls</span>
              </label>
              <p class="ch-rlm-hint" id="ch-rlm-hint">
                Off by default. When on, computed steps can ask the model to classify or
                label rows. Each one is an extra call billed to your key, and its output is
                model judgment, not fetched data.
              </p>
            </div>
          </div>
          </div>
        </div>
      </div>

      <form class="ch-composer" id="ch-composer" autocomplete="off">
        <textarea
          id="ch-composer-q"
          class="ch-q"
          rows="1"
          placeholder="Ask about the world…"
          aria-label="Ask about the world"
          spellcheck="false"
        ></textarea>
        <div class="ch-composer-foot">
          <button type="button" class="ch-byok-sum" id="ch-byok-sum" aria-expanded="false" aria-controls="ch-byok">
            <span class="ch-byok-caret" aria-hidden="true"></span>
            <span class="ch-byok-state" id="ch-byok-state">openrouter · no key</span>
            <span class="ch-byok-cta" id="ch-byok-cta">Add a free key to run it</span>
          </button>
          <div class="ch-composer-actions">
            <button type="button" class="ch-new-convo" id="ch-new-convo" style="display:none">+ new question</button>
            <button type="submit" class="ch-send" id="ch-composer-btn" aria-label="Ask">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- ── Pin-to-dashboard picker ──────────────────────────────────────────
         A small modal dialog opened by a turn's "Pin to dashboard" button.
         Lists existing dashboards to pin into, plus an inline "new dashboard"
         name field. Focus is trapped while open; Escape / backdrop / close all
         dismiss it. Populated at open time by openPinPicker(). -->
    <div class="ch-pin-backdrop" id="ch-pin-backdrop" hidden></div>
    <div class="ch-pin-dialog" id="ch-pin-dialog" hidden role="dialog" aria-modal="true" aria-labelledby="ch-pin-title" tabindex="-1">
      <div class="ch-pin-head">
        <span class="ch-pin-title" id="ch-pin-title">Pin to dashboard</span>
        <button type="button" class="ch-pin-close" id="ch-pin-close" aria-label="Close">✕</button>
      </div>
      <p class="ch-pin-sub" id="ch-pin-sub">Save this chart, its data and its citations to a dashboard you can revisit.</p>
      <div class="ch-pin-list" id="ch-pin-list" role="group" aria-label="Existing dashboards"></div>
      <form class="ch-pin-new" id="ch-pin-new" autocomplete="off">
        <label class="ch-field-label" for="ch-pin-name">New dashboard</label>
        <div class="ch-pin-new-row">
          <input type="text" id="ch-pin-name" class="ch-input" placeholder="Name it…" spellcheck="false" maxlength="80" />
          <button type="submit" class="ch-pin-create" id="ch-pin-create">Create &amp; pin</button>
        </div>
      </form>
      <span class="ch-pin-status" id="ch-pin-status" role="status" aria-live="polite"></span>
    </div>

    <!-- ── Dashboards view ──────────────────────────────────────────────────
         A full-column overlay listing saved dashboards, and (on open) one
         dashboard's tile grid. Charts init lazily and are disposed on exit.
         Everything keyboard-operable; the two sub-views swap in #ch-dashview. -->
    <section class="ch-dashview" id="ch-dashview" hidden aria-label="Dashboards">
      <div class="ch-dashview-bar">
        <button type="button" class="ch-dashview-back" id="ch-dashview-back" aria-label="Back">‹ Back</button>
        <h2 class="ch-dashview-title" id="ch-dashview-title">Dashboards</h2>
        <!-- Polite live region for share/export/import confirmations, announced
             to assistive tech without moving focus. -->
        <span class="ch-dashview-status" id="ch-dashview-status" role="status" aria-live="polite"></span>
      </div>
      <!-- Hidden file input backing the "Import dashboard" button on the list
           view. A JSON file lands as a NEW local dashboard (never overwrites). -->
      <input type="file" id="ch-dash-import-file" accept="application/json,.json" hidden />
      <div class="ch-dashview-body" id="ch-dashview-body"></div>
    </section>

  </div>

  <!-- Island: curated indicator names for client-side citation enrichment -->
  <script type="application/json" id="ch-indicator-map" set:html={JSON.stringify(indicatorMap)} is:inline></script>

  <!-- PWA service-worker registration. Scoped to /apps/chitti/ so only this
       app is controlled, never the rest of the portfolio. Feature-detected,
       registered after load, and wrapped so any failure fails silently and
       never throws into the app. Skipped on plain file:// or unsupported
       contexts; localhost/https both count as secure contexts and register. -->
  <script is:inline>
    if ('serviceWorker' in navigator && location.protocol.startsWith('http')) {
      window.addEventListener('load', function () {
        try {
          navigator.serviceWorker
            .register('/apps/chitti/sw.js', { scope: '/apps/chitti/' })
            .catch(function () { /* silent: registration is best-effort */ });
        } catch (e) { /* silent */ }
      });
    }
  </script>
</Base>

<script>
  import '../../lib/chitti/ui/boot';
</script>

<style>
  /* Break out of the 700px article container, but only as far as a readable
     single-column app needs — with the trace collapsed there is no
     side-by-side split anymore, so ~1000px keeps the finding line readable
     and the chart generous without stranding content in a huge void. The
     site's shared layout wraps every page in `div.container` (max-width:
     700px); `<main>` and `.ch` itself have no width cap of their own, so the
     div is the actual constraint to override. */
  :global(div.container:has(.ch)) { max-width: min(1000px, 94vw) !important; }
  /* This is a full-height app view, not an article. Suppress the site footer
     here so its social links don't float mid-page above the composer, and let
     the container use the full viewport height. */
  /* svh, not dvh: dvh re-measures every time the mobile URL bar collapses or
     expands, so the whole column (and the docked composer with it) shifted
     up and down while scrolling — the "bar keeps floating" bug. svh is the
     stable small-viewport height: measured once, never dances. */
  :global(div.container:has(.ch)) { display: flex; flex-direction: column; min-height: 100svh; }
  :global(div.container:has(.ch) > footer) { display: none; }
  :global(div.container:has(.ch) > main) { flex: 1; display: flex; flex-direction: column; min-height: 0; }

  /* .ch is a viewport-filling column: header at the top, thread in the middle
     (grows and scrolls), composer docked at the bottom of the flow. No fixed
     positioning, so short content never strands the input over a void. */
  .ch {
    width: 100%;
    margin: 0 auto;
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    /* Accessible second-tier muted text. The base --fg-muted only just clears
       AA on the dark ground (≈4.5:1), so the app's habit of dimming small mono
       text further with `opacity` dropped receipt meta, hints, and category
       labels to ~2–3:1. This nudges --fg-muted a hair toward --fg (theme-aware:
       toward the light ink in light mode) for a genuine ≈5.5:1, and the rules
       that used opacity now use this colour with no opacity instead. */
    --ch-meta: color-mix(in srgb, var(--fg-muted) 85%, var(--fg));
    /* AA-safe danger for error text on the elevated trace ground, where the
       base --danger lands at ~4.3:1. Brightened toward --fg (theme-aware);
       still unmistakably the error red. */
    --ch-danger: color-mix(in srgb, var(--danger) 80%, var(--fg));
  }
  /* Keyboard focus is a consistent thin amber ring, offset, on every
     interactive element in the app — including the JS-built picker rows (hence
     :global). Never removed without this replacement. Pointer focus stays
     ring-free: focus-visible only fires for keyboard/AT, so a mouse user at
     100% zoom sees no change. */
  .ch :global(:is(a[href], button, input, select, textarea, summary, [tabindex]:not([tabindex='-1'])):focus-visible) {
    outline: 2px solid color-mix(in srgb, var(--signal) 65%, transparent);
    outline-offset: 2px;
  }
  /* Two-register type system, matching the rest of the site: prose (the
     question, the finding, the welcome copy) in the site's sans/serif so
     answers read like writing, and machinery (trace, badges, tables, axis
     labels, citations) in mono so the instrument-panel feel survives where
     it belongs. The old blanket `* { mono !important }` rule made the
     headline answer as hard to read as a log line — removed; every element
     below declares its own family. */
  .ch-thread { display: flex; flex-direction: column; gap: var(--space-lg); }
  /* ONE scroller: the page. The thread used to be its own overflow-y:auto
     container nested inside the scrolling page, and the various
     scrollIntoView calls alternated between moving the inner container and
     the page — which is exactly the "chat keeps jumping around" bug. Normal
     document flow + a sticky composer replaces all of that. */
  .ch-thread:not(:empty) {
    flex: 1;
    padding: var(--space-sm) 0 var(--space-lg);
  }
  .ch-turn:last-child { scroll-margin-top: var(--space-sm); }

  /* ── Header ── */
  .ch-head { margin-bottom: var(--space-lg); }
  .ch-title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .ch-head h1 { font-size: var(--text-page-title); font-weight: 600; margin-bottom: 0; }
  .ch-subtitle {
    font-family: var(--font-serif);
    font-size: var(--text-subsection);
    font-weight: 500;
    font-style: italic;
    letter-spacing: -0.01em;
    color: var(--fg-muted);
    margin: 2px 0 10px;
  }
  .ch-badges { display: flex; gap: 6px; flex-wrap: wrap; }
  .badge {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
    border: 1px solid var(--fg-faint);
    padding: 2px 8px;
    border-radius: var(--radius-full);
  }

  /* ── Ask console ──────────────────────────────────────────────────────
     Restyled to match the receipt system introduced below: same near-black
     elevated surface, 8px radius, dashed internal perforation instead of a
     solid divider. Copy, chips, and behavior are unchanged from the prior
     console — visual restyle only. */
  /* ── Unified input bar (Codex/Perplexity/Claude) ──────────────────────
     One rounded container docked at the bottom of the viewport-filling
     column: config panel (hidden) on top, then the textarea, then a control
     row with the model/key chip on the left and the send button on the right.
     Not position:fixed, so short content never strands it over a void. */
  .ch-inputbar {
    flex-shrink: 0;
    position: sticky;
    /* Clear the iPhone home indicator / gesture bar. */
    bottom: calc(12px + env(safe-area-inset-bottom, 0px));
    z-index: 5;
    margin-top: var(--space-md);
    /* OPAQUE background, not var(--bg-elevated): that token is 96%-
       transparent white, so the thread scrolled visibly through the sticky
       composer — it never read as an overlay, especially on mobile. Mix the
       elevation tint over the solid page bg instead. */
    background: color-mix(in srgb, var(--fg) 5%, var(--bg));
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 24px color-mix(in srgb, var(--bg) 60%, transparent);
    transition: border-color var(--duration) var(--ease);
    overflow: hidden;
  }
  .ch-inputbar:focus-within {
    border-color: color-mix(in srgb, var(--fg) 26%, transparent);
  }
  .ch-composer {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px var(--space-md) 8px;
  }
  .ch-composer .ch-q {
    flex: 1;
    padding: 4px 2px;
    font-size: var(--text-body);
    min-height: 0;
    max-height: 160px;
    background: transparent;
  }
  /* Bottom control row: model/key chip (left), actions (right). */
  .ch-composer-foot {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ch-composer-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ch-new-convo {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    background: transparent;
    color: var(--fg-muted);
    border: none;
    cursor: pointer;
    white-space: nowrap;
    padding: 4px 6px;
    border-radius: var(--radius-sm);
    transition: color var(--duration) var(--ease), background var(--duration) var(--ease);
  }
  .ch-new-convo:hover { color: var(--fg); background: var(--bg-hover); }
  /* Armed confirm state: emphasised in ink (not amber), a hairline outline so
     the "are you sure?" reads clearly without a colour alarm. */
  .ch-new-convo-armed {
    color: var(--fg);
    border: 1px solid var(--fg-faint);
    background: var(--bg-hover);
  }
  /* Round send button, filled with ink. */
  .ch-send {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    background: var(--fg);
    color: var(--bg);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: opacity var(--duration) var(--ease);
  }
  .ch-send:hover { opacity: 0.85; }
  .ch-send:disabled { opacity: 0.4; cursor: default; }
  .ch-send-working svg { animation: ch-spin 0.8s linear infinite; }
  @keyframes ch-spin { to { transform: rotate(360deg); } }
  /* The only rotation on the site. Under reduced motion, swap the spin for an
     opacity pulse: still reads as "working", without the rotating glyph. The
     rest of the app's motion is swept here too: the CTA shake goes, the panel
     /answer/evidence reveals keep their fade but drop the 4px travel, and the
     rubber-stamp rotation flattens. Colour/opacity feedback is untouched (the
     site-wide reduced-motion rule in global.css keeps those transitions). */
  @media (prefers-reduced-motion: reduce) {
    .ch-send-working svg { animation: ch-pulse 1.2s ease-in-out infinite; }
    @keyframes ch-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
    /* Horizontal shake on the "add a key" nudge — pure vestibular motion. */
    .ch-byok-nudge { animation: none; }
    /* Entrance reveals: fadeInReduced (global) is opacity-only, no translateY. */
    .ch-panel, .ch-answer, .ch-meta { animation-name: fadeInReduced; }
    /* The stamp's rubber-stamp tilt is decorative motion-adjacent flair. */
    :global(.ch-stamp) { transform: none; }
  }
  /* Empty state: a centered welcome that fills the space between the header
     and the docked composer. No card/box, it's an invitation, not a form. */
  .ch-console {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
  }
  .ch-welcome { max-width: 44ch; }
  .ch-welcome-title {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
  }
  .ch-welcome-sub {
    font-size: var(--text-body);
    line-height: 1.55;
    color: var(--fg-muted);
    margin: 0;
  }
  /* The #ch-ask <textarea> (#ch-q) is now only the plumbing target the bottom
     composer delegates to, never a visible input, so collapse it. */
  #ch-ask .ch-q { display: none; }
  #ch-ask { width: 100%; display: flex; justify-content: center; }
  .ch-ask-foot { padding-top: 0; width: 100%; display: flex; justify-content: center; }

  .ch-q {
    display: block;
    width: 100%;
    background: transparent;
    color: var(--fg);
    border: none;
    padding: var(--space-md) var(--space-md) 4px;
    font-family: var(--font-sans);
    font-size: var(--text-body-lg);
    line-height: 1.5;
    resize: none;
    min-height: 68px;
  }
  /* Suppress the UA outline only for pointer focus; keyboard focus keeps the
     amber focus-visible ring above, and the whole bar shows a border shift via
     .ch-inputbar:focus-within either way. */
  .ch-q:focus:not(:focus-visible) { outline: none; }
  .ch-q::placeholder { color: var(--fg-muted); opacity: 0.55; }

  .ch-ask-foot {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 10px;
    padding: 6px var(--space-md) var(--space-md);
    flex-wrap: wrap;
  }
  /* Suggestion chips in the centered empty state: wrap, centered, and read as
     tappable prompt starters. Capped width so a full column of them stays a
     tidy stack rather than one very wide row. */
  .ch-chips {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: stretch;
    max-width: 30rem;
    margin: 0 auto;
  }
  .ch-chip {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    background: var(--bg-elevated);
    color: var(--ch-meta);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    padding: 10px 16px;
    cursor: pointer;
    text-align: left;
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }
  .ch-chip:hover {
    color: var(--fg);
    border-color: color-mix(in srgb, var(--fg) 30%, transparent);
    background: var(--bg-hover);
  }
  /* ── Database picker: searchable, grouped, scrollable — scales with the
        registry (hard filter over active sources) ── */
  .ch-sources-row {
    border-top: 1px solid var(--fg-faint);
    padding-top: 12px;
  }
  .ch-sources {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }
  .ch-sources.is-locked { opacity: 0.55; }
  .ch-sources.is-locked .ch-source-item,
  .ch-sources.is-locked .ch-sources-act { cursor: not-allowed; }

  .ch-sources-top { display: flex; align-items: center; gap: 10px; }
  .ch-sources-count {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
  }
  .ch-sources-acts { margin-left: auto; display: flex; gap: 6px; }
  .ch-sources-act {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    background: transparent;
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-full);
    padding: 2px 10px;
    cursor: pointer;
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }
  .ch-sources-act:hover {
    color: var(--fg);
    border-color: color-mix(in srgb, var(--fg) 30%, transparent);
  }

  .ch-sources-search {
    width: 100%;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    padding: 7px 11px;
    font-family: var(--font-mono);
    font-size: var(--text-label);
  }
  .ch-sources-search::placeholder { color: var(--fg-muted); }
  .ch-sources-search:focus { border-color: color-mix(in srgb, var(--signal) 45%, transparent); }
  .ch-sources-search:focus:not(:focus-visible) { outline: none; }

  .ch-sources-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    max-height: 210px;
    overflow-y: auto;
    padding-right: 2px;
  }
  .ch-source-group { display: flex; flex-direction: column; }
  .ch-source-group[hidden] { display: none; }
  .ch-source-cat {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ch-meta);
    padding: 8px 2px 3px;
  }

  .ch-source-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    text-align: left;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    padding: 7px 9px;
    cursor: pointer;
    transition: background var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }
  .ch-source-item[hidden] { display: none; }
  .ch-source-item:hover { background: var(--bg-hover); }
  .ch-source-check {
    flex-shrink: 0;
    width: 15px;
    height: 15px;
    margin-top: 2px;
    border-radius: 4px;
    border: 1px solid var(--fg-faint);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .ch-source-item.is-on {
    border-color: color-mix(in srgb, var(--signal) 30%, transparent);
    background: color-mix(in srgb, var(--signal) 7%, transparent);
  }
  .ch-source-item.is-on .ch-source-check {
    border-color: var(--signal);
    background: var(--signal);
  }
  .ch-source-item.is-on .ch-source-check::after {
    content: '✓';
    color: var(--bg);
    font-size: 10px;
    line-height: 1;
  }
  .ch-source-text { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .ch-source-name {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg);
  }
  .ch-source-blurb {
    font-size: var(--text-tag);
    color: var(--ch-meta);
    line-height: 1.4;
  }

  .ch-sources-empty {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    padding: 8px 2px;
    margin: 0;
  }
  .ch-sources-empty[hidden] { display: none; }

  .ch-sources-hint {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
    margin: 0;
    text-align: left;
  }
  .ch-sources-hint.is-warn { color: var(--danger); opacity: 1; }

  /* ── Model picker: searchable, scrollable, single-select. Mirrors the
        database picker's machinery; each row surfaces the model name, a free
        badge, context length, and prompt/completion pricing. ── */
  .ch-model-row { padding-top: 4px; }
  .ch-modelpick {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }
  .ch-modelpick-top { display: flex; align-items: baseline; gap: 10px; }
  .ch-modelpick-count {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    margin-left: auto;
  }
  .ch-modelpick-search {
    width: 100%;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    padding: 7px 11px;
    font-family: var(--font-mono);
    font-size: var(--text-label);
  }
  .ch-modelpick-search::placeholder { color: var(--fg-muted); }
  .ch-modelpick-search:focus { border-color: color-mix(in srgb, var(--signal) 45%, transparent); }
  .ch-modelpick-search:focus:not(:focus-visible) { outline: none; }
  .ch-modelpick-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    max-height: 260px;
    overflow-y: auto;
    padding-right: 2px;
  }
  /* Rows below are built in JS (renderModelPicker), so their selectors must be
     :global() — Astro's scoped styles only reach server-rendered markup. */
  :global(.ch-model-group) { display: flex; flex-direction: column; }
  :global(.ch-model-group[hidden]) { display: none; }
  :global(.ch-model-cat) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ch-meta);
    padding: 8px 2px 3px;
  }
  :global(.ch-model-item) {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    text-align: left;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    padding: 7px 9px;
    cursor: pointer;
    min-width: 0;
    transition: background var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }
  :global(.ch-model-item[hidden]) { display: none; }
  :global(.ch-model-item:hover) { background: var(--bg-hover); }
  :global(.ch-model-check) {
    flex-shrink: 0;
    width: 15px;
    height: 15px;
    margin-top: 3px;
    border-radius: var(--radius-full);
    border: 1px solid var(--fg-faint);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  :global(.ch-model-item.is-on) {
    border-color: color-mix(in srgb, var(--signal) 30%, transparent);
    background: color-mix(in srgb, var(--signal) 7%, transparent);
  }
  :global(.ch-model-item.is-on .ch-model-check) {
    border-color: var(--signal);
    background: var(--signal);
  }
  :global(.ch-model-item.is-on .ch-model-check)::after {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--bg);
  }
  :global(.ch-model-text) { display: flex; flex-direction: column; gap: 3px; min-width: 0; flex: 1; }
  :global(.ch-model-namerow) { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; min-width: 0; }
  :global(.ch-model-name) {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg);
    overflow-wrap: anywhere;
  }
  :global(.ch-model-badge) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-muted);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-full);
    padding: 0 7px;
    line-height: 1.5;
  }
  :global(.ch-model-badge-free) {
    color: var(--signal);
    border-color: color-mix(in srgb, var(--signal) 45%, transparent);
    background: color-mix(in srgb, var(--signal) 8%, transparent);
  }
  :global(.ch-model-meta) {
    display: flex;
    align-items: center;
    gap: 6px 10px;
    flex-wrap: wrap;
    min-width: 0;
  }
  :global(.ch-model-id) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    overflow-wrap: anywhere;
  }
  :global(.ch-model-fact) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
  }
  :global(.ch-model-fact)::before { content: '· '; opacity: 0.6; }
  .ch-modelpick-empty {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    padding: 8px 2px;
    margin: 0;
  }
  .ch-modelpick-empty[hidden] { display: none; }

  .ch-btn {
    background: var(--fg);
    color: var(--bg);
    border: none;
    border-radius: var(--radius-md);
    padding: 10px 26px;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    flex-shrink: 0;
    transition: opacity var(--duration) var(--ease);
  }
  .ch-btn:hover { opacity: 0.85; }
  .ch-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ── BYOK: config panel (expands inside the input bar, above the textarea)
     + the compact chip that toggles it (lives in the control row) ── */
  .ch-byok {
    border-bottom: 1px solid var(--fg-faint);
    background: var(--bg);
  }
  .ch-byok[hidden] { display: none; }
  /* The chip: a small pill button showing provider · model · key state. */
  .ch-byok-sum {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    background: transparent;
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
    cursor: pointer;
    min-width: 0;
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }
  .ch-byok-sum:hover { color: var(--fg); border-color: color-mix(in srgb, var(--fg) 30%, transparent); }
  .ch-byok-caret::before { content: '▸'; color: var(--fg-muted); font-size: 0.85em; }
  .ch-byok-sum[aria-expanded='true'] .ch-byok-caret::before { content: '▾'; }
  /* The model is the whole point of this chip, so show it in full: wrap to up
     to two lines instead of truncating a distinctive slug to "…(f…". Long
     ids break anywhere so the leading (distinctive) part always survives. */
  .ch-byok-state {
    letter-spacing: 0.02em;
    text-align: left;
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow-wrap: anywhere;
    max-width: 52ch;
  }
  .ch-byok-state.ch-byok-ready { color: var(--success); }
  .ch-byok-sum.ch-byok-missing { border-color: color-mix(in srgb, var(--signal) 55%, transparent); }
  /* This is the one thing standing between a visitor and the product, so it
     reads as an action rather than a footnote: an outlined amber pill instead
     of 11px muted text that lost the page to a title already read. */
  .ch-byok-cta {
    color: var(--signal);
    letter-spacing: 0.02em;
    font-weight: 500;
    border: 1px solid color-mix(in srgb, var(--signal) 45%, transparent);
    border-radius: var(--radius-full);
    padding: 2px 10px;
  }
  .ch-byok-nudge { animation: ch-nudge 0.35s var(--ease); }
  @keyframes ch-nudge {
    0%, 100% { transform: translateX(0); }
    30% { transform: translateX(-4px); }
    60% { transform: translateX(4px); }
  }

  .ch-byok-body { padding: 4px var(--space-md) var(--space-md); }
  .ch-byok-backdrop { display: none; }
  .ch-byok-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 0 4px;
  }
  .ch-byok-title {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
  }
  .ch-byok-close {
    background: transparent;
    border: none;
    color: var(--fg-muted);
    font-size: 15px;
    line-height: 1;
    padding: 6px 8px;
    margin-right: -8px;
    cursor: pointer;
    border-radius: var(--radius-sm);
  }
  .ch-byok-close:hover { color: var(--fg); background: var(--bg-hover); }
  .ch-byok-row { display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end; }
  .ch-byok-foot { margin-top: 10px; justify-content: space-between; align-items: center; }

  /* Key-first disclosure: model + databases collapse behind this toggle. */
  .ch-byok-keyfield { margin-top: 2px; }
  .ch-byok-more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    padding: 4px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    transition: color var(--duration) var(--ease);
  }
  .ch-byok-more:hover { color: var(--fg); }
  .ch-byok-more-caret::before { content: '▸'; font-size: 0.85em; }
  .ch-byok-more[aria-expanded='true'] .ch-byok-more-caret::before { content: '▾'; }
  .ch-byok-settings { display: flex; flex-direction: column; gap: 10px; margin-top: 10px; }
  .ch-byok-settings[hidden] { display: none; }
  .ch-field { display: flex; flex-direction: column; gap: 4px; min-width: 150px; }
  .ch-field-grow { flex: 1; min-width: 220px; }
  .ch-field-label {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
  }
  .ch-select, .ch-input {
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-sm);
    padding: 8px 10px;
    font-family: var(--font-mono);
    font-size: var(--text-small);
    transition: border-color var(--duration) var(--ease);
  }
  .ch-select:focus, .ch-input:focus { border-color: var(--accent-color); }
  .ch-select:focus:not(:focus-visible), .ch-input:focus:not(:focus-visible) { outline: none; }
  .ch-input::placeholder { color: var(--fg-muted); opacity: 0.6; }

  .ch-save {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    cursor: pointer;
  }
  .ch-save input { accent-color: var(--signal); }

  .ch-rlm-row { display: block; }
  .ch-rlm { display: flex; flex-direction: column; gap: 6px; }
  .ch-rlm.is-locked { opacity: 0.55; }
  .ch-rlm.is-locked .ch-save { cursor: not-allowed; }
  .ch-rlm-hint {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    line-height: 1.5;
    color: var(--fg-muted);
  }

  .ch-keylinks { display: flex; gap: 12px; flex-wrap: wrap; }
  :global(.ch-keylink) {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  :global(.ch-keylink:hover) { color: var(--fg); }
  :global(.ch-keylink-free) {
    color: var(--signal);
    font-weight: 500;
    text-decoration-color: var(--signal);
  }
  :global(.ch-keylink-free:hover) { color: var(--signal); opacity: 0.8; }

  .ch-provider-note {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--signal);
    margin: 10px 0 0;
  }

  /* ── Status line ── */
  /* The user's question, chat-style, at the top of each turn. Every turn
     stays as full readable history, no collapsing. A left ink rule marks it
     as the user's line, distinct from the agent's answer below. */
  .ch-turn-q {
    font-family: var(--font-sans);
    font-size: var(--text-subsection);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg);
    line-height: 1.4;
    margin: 0 0 var(--space-md);
    padding-left: var(--space-md);
    border-left: 2px solid var(--fg);
  }
  /* Space between stacked turns in the history thread. */
  .ch-turn + .ch-turn { margin-top: var(--space-3xl); border-top: 1px solid var(--fg-faint); padding-top: var(--space-2xl); }
  .ch-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--fg-muted);
    margin: 0 2px var(--space-md);
  }
  .ch-status-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--fg-muted); flex-shrink: 0; }
  .ch-status-loading { background: var(--signal); animation: pulse 1.6s ease-in-out infinite; }
  .ch-status-ok { background: var(--success); }
  .ch-status-error { background: var(--danger); }
  /* A user-stop is terminal but NOT a failure: a muted dot, no pulse, no red. */
  .ch-status-stopped { background: var(--fg-muted); }
  /* The stop control on a running turn: mono/muted, quiet until hovered, never
     amber. Pushed to the end of the status row. Keyboard focus is handled by
     the shared :focus-visible rule above (it targets `button`). */
  .ch-stop {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    background: transparent;
    color: var(--fg-muted);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-sm);
    padding: 1px 8px;
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }
  .ch-stop:hover { color: var(--fg); border-color: var(--fg-muted); background: var(--bg-hover); }
  .ch-stop:disabled { opacity: 0.5; cursor: default; }

  /* ── Agent trace: one collapsed line, expandable ──────────────────────
     The trace no longer competes with the answer for space. Collapsed, it
     is a single quiet row: status dot, live step name (or step count once
     done), and model/token/cost metadata right-aligned. Open, it reveals
     the full receipt-style timeline below. */
  .ch-panel {
    margin-bottom: var(--space-md);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    background: var(--bg-elevated);
    animation: fadeIn 0.3s var(--ease);
  }
  .ch-panel-sum {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px var(--space-md);
    cursor: pointer;
    list-style: none;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--ch-meta);
    min-width: 0;
  }
  .ch-panel-sum::-webkit-details-marker { display: none; }
  .ch-panel-sum::before { content: '▸'; color: var(--fg-muted); font-size: 0.85em; flex-shrink: 0; }
  .ch-panel[open] .ch-panel-sum::before { content: '▾'; }
  .ch-panel-sum:hover { color: var(--fg); }
  .ch-panel-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--fg-muted);
    flex-shrink: 0;
  }
  .ch-panel-dot-running { background: var(--signal); animation: pulse 1.2s ease-in-out infinite; }
  .ch-panel-dot-ok { background: var(--success); }
  .ch-panel-dot-error { background: var(--danger); }
  .ch-panel-label {
    color: var(--fg);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }
  .ch-panel-meta {
    margin-left: auto;
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    font-size: var(--text-tag);
    color: var(--ch-meta);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ch-rail-model { letter-spacing: 0.02em; }
  .ch-rail-body {
    padding: var(--space-sm) var(--space-md) var(--space-md);
    border-top: 1px dashed var(--fg-faint);
  }
  .ch-render-flag {
    color: var(--signal);
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    letter-spacing: 0.02em;
    animation: pulse 1.4s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* Trace timeline: a rail with one dot per tool call, receipt line-items.
     Live-event rendering logic lands in a follow-up pass; this pass only
     supplies the container + row/dot/meta styling it will populate. */
  .ch-trace {
    position: relative;
    display: flex;
    flex-direction: column;
    max-height: 420px;
    overflow-y: auto;
    padding-left: 2px;
  }
  .ch-trace::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 10px;
    bottom: 10px;
    width: 1px;
    background: var(--fg-faint);
  }
  /* NOTE on :global() below: every element in this trace timeline (rows,
     dots, name/arg spans, the stamp, …) is created at runtime via
     document.createElement inside renderTrace()/renderFiles(), not written
     in this component's template. Astro's scoped CSS only tags elements
     that exist in the static template with the component's data-astro-cid
     attribute; JS-created nodes never get it. An un-global()'d selector like
     `.ch-trace-dot { ... }` compiles to `.ch-trace-dot[data-astro-cid-xxx]`,
     which then never matches these nodes — the dot silently renders at 0×0
     with no color. All selectors for elements populated by renderTrace() /
     renderFiles() must stay wrapped in :global() for this reason. */
  :global(.ch-trace-row) {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    align-items: start;
    padding: 10px 0 10px 18px;
  }
  :global(.ch-trace-row + .ch-trace-row) {
    border-top: 1px dashed var(--fg-faint);
  }
  :global(.ch-trace-dot) {
    position: absolute;
    left: 0;
    top: 11px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--fg-muted);
    box-shadow: 0 0 0 3px var(--bg-elevated);
  }
  :global(.ch-trace-ok .ch-trace-dot) { background: var(--success); }
  :global(.ch-trace-error .ch-trace-dot) { background: var(--danger); }
  :global(.ch-trace-running .ch-trace-dot) {
    background: var(--signal);
    box-shadow: 0 0 0 3px var(--bg-elevated), 0 0 6px 1px var(--signal);
    animation: pulse 1.2s ease-in-out infinite;
  }
  :global(.ch-trace-body) { min-width: 0; display: flex; flex-direction: column; gap: 1px; }
  :global(.ch-trace-head) { display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap; min-width: 0; }
  /* Real per-line timestamp, captured at the moment the event arrived. */
  :global(.ch-trace-ts) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
    flex-shrink: 0;
  }
  :global(.ch-trace-sep) { font-family: var(--font-mono); font-size: var(--text-tag); color: var(--ch-meta); }
  :global(.ch-trace-name) {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    font-weight: 500;
    color: var(--fg);
  }
  :global(.ch-trace-running .ch-trace-name) { color: var(--signal); }
  :global(.ch-trace-arg) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
    overflow-wrap: break-word;
  }
  :global(.ch-trace-detail) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
  }
  :global(.ch-trace-error .ch-trace-detail) { color: var(--ch-danger); }

  /* ── Nested llm() child receipts (RLM recursion) ─────────────────────────
     A recursive llm() call inside execute_js renders as an indented child
     line-item under its execute_js parent: same receipt aesthetic (dark,
     JetBrains Mono), a smaller dot, and a subtle elbow connector back to the
     rail, so the depth-1 recursion is legible without shouting. Amber stays
     reserved for the in-flight dot (shared with every other running step). */
  :global(.ch-trace-nested) {
    padding: 7px 0 7px 40px;
    border-top: none;
  }
  /* No dashed separator directly above a child — the connector already ties it
     to the parent; keep the child group visually tight. */
  :global(.ch-trace-row + .ch-trace-nested) { border-top: none; }
  :global(.ch-trace-nested)::before {
    content: '';
    position: absolute;
    left: 12px;
    top: -2px;
    height: 18px;
    width: 12px;
    border-left: 1px solid var(--fg-faint);
    border-bottom: 1px solid var(--fg-faint);
    border-bottom-left-radius: 5px;
  }
  :global(.ch-trace-nested .ch-trace-dot) {
    left: 22px;
    top: 12px;
    width: 5px;
    height: 5px;
  }
  :global(.ch-trace-nested .ch-trace-name) {
    font-size: var(--text-tag);
    opacity: 0.92;
  }
  :global(.ch-trace-nested .ch-trace-arg) { font-style: italic; }

  /* Provenance label on a model-derived (llm()-produced) write_file: an
     amber-dashed chip, deliberately quiet, that keeps derived artifacts from
     ever reading as fetched data. */
  :global(.ch-trace-derived) {
    align-self: flex-start;
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    letter-spacing: 0.02em;
    color: var(--fg-muted);
    padding: 1px 6px;
    border: 1px dashed color-mix(in srgb, var(--signal) 45%, var(--fg-faint));
    border-radius: var(--radius-sm);
  }

  /* ── Search-receipt card ────────────────────────────────────────────────
     find_series shows its work: a compact card on a darker ground reading
     "N databases → K candidates → top match: <name> (source) — matched
     'gdp' → 'economy'". Mono for the machinery, Newsreader italic for the
     matched indicator's human name, amber (--signal) reserved for the two
     things that matter most — the counts and the synonym expansions. */
  :global(.ch-receipt) {
    margin-top: 6px;
    padding: 8px 10px;
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-left: 2px solid color-mix(in srgb, var(--signal) 55%, transparent);
    border-radius: var(--radius-sm);
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  :global(.ch-receipt-stats) {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
  }
  :global(.ch-receipt-num) {
    color: var(--signal);
    font-weight: 600;
  }
  :global(.ch-receipt-arrow) {
    color: var(--ch-meta);
  }
  :global(.ch-receipt-toplabel) {
    color: var(--ch-meta);
  }
  :global(.ch-receipt-match) {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 7px;
  }
  :global(.ch-receipt-name) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-label);
    color: var(--fg);
    line-height: 1.25;
  }
  :global(.ch-receipt-source) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
    white-space: nowrap;
  }
  :global(.ch-receipt-source)::before { content: '('; }
  :global(.ch-receipt-source)::after { content: ')'; }
  :global(.ch-receipt-terms) {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
  }
  :global(.ch-receipt-lead) { color: var(--ch-meta); }
  :global(.ch-receipt-syn) {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    color: var(--ch-meta);
  }
  :global(.ch-receipt-term) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    /* A hair stronger than --ch-meta: the term sits on a lighter chip fill, so
       the plain meta tone would land at ~4.4:1 against it. */
    color: color-mix(in srgb, var(--fg-muted) 65%, var(--fg));
    background: color-mix(in srgb, var(--fg-faint) 60%, transparent);
    border-radius: var(--radius-sm);
    padding: 0 4px;
  }
  :global(.ch-receipt-term-syn) {
    color: var(--signal);
    background: color-mix(in srgb, var(--signal) 12%, transparent);
  }

  /* Completed steps settle quietly — dimmed, not struck through. The old
     strike-through made every finished line read as an error/cancellation
     and left the whole rail illegible once a run completed. */
  /* Dim the (bright --fg) tool name so a finished row recedes; the arg is
     already muted and dimming it too dropped it below AA on the panel ground,
     so it keeps its --ch-meta colour and the settled look still reads from the
     name fading back toward the muted register. */
  :global(.ch-trace-ok .ch-trace-name) {
    opacity: 0.65;
  }
  /* Error/retry line-items: restyled to read as a torn/crossed-out receipt
     entry — a void line-item — rather than a generic red banner. The
     underlying retry behavior (agent.ts's single automatic retry, driven by
     `runVerify`'s critique) is unchanged; this is presentation only. A
     failed step gets a harder, danger-colored strike-through (vs. the softer
     faint one on a normal completed step) plus a jagged left notch cut into
     the row, echoing the receipt's torn-edge motif used at the top of the
     rail. The "not verified — retrying" note (added as a `.ch-trace-detail`
     for the verify step above) is what carries the automatic-retry message —
     no separate banner element. */
  :global(.ch-trace-error) {
    background-image: repeating-linear-gradient(
      -45deg,
      transparent 0 3px,
      color-mix(in srgb, var(--danger) 10%, transparent) 3px 6px
    );
    background-position: 0 0;
    background-size: 10px 100%;
    background-repeat: no-repeat;
  }
  :global(.ch-trace-error .ch-trace-name),
  :global(.ch-trace-error .ch-trace-arg) {
    text-decoration: line-through;
    text-decoration-color: var(--danger);
    text-decoration-thickness: 1.5px;
    color: var(--ch-danger);
  }
  :global(.ch-trace-meta-col) {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1px;
  }
  :global(.ch-trace-meta) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
    white-space: nowrap;
  }
  /* Per-step token count, receipt-style, right-aligned under the duration. */
  :global(.ch-trace-tokens) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
    white-space: nowrap;
  }

  /* Ink-stamped VERIFIED badge — the single most distinctive beat in the
     receipt design. Amber, rotated like a rubber stamp, only ever rendered
     on a genuine verifier pass (never on a failed attempt before retry). */
  :global(.ch-stamp) {
    display: inline-block;
    align-self: flex-start;
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--signal);
    border: 2px solid var(--signal);
    border-radius: var(--radius-sm);
    padding: 2px 8px;
    transform: rotate(-8deg);
    opacity: 0.9;
  }

  /* Could-not-verify receipt in the trace: an honest counterpart to the stamp.
     No amber, no ink-stamp flourish — a plain muted verdict with the flagged
     issues in an expandable detail. The "verification unavailable" note reuses
     .ch-trace-detail with this modifier for a slightly firmer muted tone. */
  :global(.ch-verify-receipt) {
    align-self: flex-start;
    margin-top: 4px;
  }
  :global(.ch-verify-verdict) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    /* AA-safe on the elevated trace ground (the danger/muted mix landed at
       ~4.3:1); still the muted honest-counterpart red, never amber. */
    color: var(--ch-danger);
  }
  :global(.ch-trace-unavailable) {
    color: var(--ch-meta);
    font-style: italic;
  }
  :global(.ch-verify-issues) {
    margin-top: 3px;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
  }
  :global(.ch-verify-issues > summary) {
    cursor: pointer;
    list-style: none;
    color: var(--ch-meta);
  }
  :global(.ch-verify-issues > summary)::-webkit-details-marker { display: none; }
  :global(.ch-verify-issues > summary)::before { content: '▸ '; color: var(--fg-muted); }
  :global(.ch-verify-issues[open] > summary)::before { content: '▾ '; }
  :global(.ch-verify-issue-list) {
    margin: 4px 0 2px;
    padding-left: 18px;
    line-height: 1.6;
  }
  :global(.ch-verify-issue-list li) { margin: 0 0 2px; }

  /* ── Plan card (backlog #10) ─────────────────────────────────────────────
     The turn's committed insight brief, at the top of the trace. Same dark
     elevated ground + amber left-rule as the search receipt (amber is the
     receipt system's established emphasis colour, so the plan borrows it here
     for the same "this is the machinery showing its work" cue). The insight is
     Newsreader italic — human, a claim; the checklist is mono — the machinery. */
  :global(.ch-plan) {
    margin: 2px 0 8px;
    padding: 9px 11px;
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-left: 2px solid color-mix(in srgb, var(--signal) 55%, transparent);
    border-radius: var(--radius-sm);
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  :global(.ch-plan-header) {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }
  :global(.ch-plan-label) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--signal);
  }
  :global(.ch-plan-tokens) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
  }
  :global(.ch-plan-insight) {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-label);
    line-height: 1.35;
    color: var(--fg);
  }
  :global(.ch-plan-steps) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  :global(.ch-plan-step) {
    display: flex;
    align-items: baseline;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
    line-height: 1.4;
  }
  :global(.ch-plan-box) {
    flex-shrink: 0;
    width: 1em;
    text-align: center;
    color: var(--fg-muted);
  }
  :global(.ch-plan-step-done .ch-plan-box) { color: var(--signal); }
  :global(.ch-plan-step-done .ch-plan-what) { color: var(--fg); }
  /* Not-needed: a neutral strike — never a check, never implying it was done. */
  :global(.ch-plan-step-skipped .ch-plan-what) {
    text-decoration: line-through;
    text-decoration-thickness: 1px;
    color: var(--fg-faint);
    opacity: 0.85;
  }
  :global(.ch-plan-hint) {
    font-size: var(--text-tag);
    color: var(--ch-meta);
    opacity: 0.7;
    padding: 0 5px;
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-sm);
  }
  :global(.ch-plan-off) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    font-style: italic;
    color: var(--ch-meta);
    padding-top: 2px;
    border-top: 1px dashed var(--fg-faint);
  }
  /* A gated-but-unusable plan: a muted one-line receipt where the plan card
     would have been. Deliberately quiet (no dot, no border) — it explains an
     absence, it is not a failure. */
  :global(.ch-plan-skipped) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    font-style: italic;
    color: var(--ch-meta);
    margin: 2px 0 8px;
    padding: 0 0 0 2px;
  }

  /* A write_file/read_file trace row inline-expands its own file content —
     no separate "workspace" list duplicating the same file elsewhere on the
     page. `.ch-trace-file` wraps the row's existing `.ch-trace-head` inside
     a native <details>/<summary> so the whole head becomes the toggle. */
  :global(.ch-trace-file) { list-style: none; }
  :global(.ch-trace-file > summary) {
    display: flex;
    align-items: baseline;
    gap: 6px;
    cursor: pointer;
    list-style: none;
  }
  :global(.ch-trace-file > summary)::-webkit-details-marker { display: none; }
  :global(.ch-trace-file > summary)::before { content: '▸'; color: var(--fg-muted); flex-shrink: 0; }
  :global(.ch-trace-file[open] > summary)::before { content: '▾'; }

  /* Reasoning (OpenRouter reasoning models only): just the model's own
     words, in place, no label or toggle marking it as a distinct internal
     thing — it reads as part of the same terse narration as everything
     else in the receipt. */
  :global(.ch-trace-thinking) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
    line-height: 1.6;
    padding: 6px 0 6px 18px;
    margin: 0;
  }
  :global(.ch-file-ext) {
    margin-left: auto;
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ch-meta);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-full);
    padding: 0 7px;
  }
  :global(.ch-file-ext-json) { color: var(--info); border-color: color-mix(in srgb, var(--info) 40%, transparent); }
  :global(.ch-file-ext-csv) { color: var(--success); border-color: color-mix(in srgb, var(--success) 40%, transparent); }
  :global(.ch-file-ext-md) { color: var(--signal); border-color: color-mix(in srgb, var(--signal) 40%, transparent); }
  :global(.ch-file-body) {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    background: var(--bg);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-sm);
    padding: 8px 10px;
    margin: 2px 0 8px;
    max-height: 220px;
    overflow: auto;
    white-space: pre-wrap;
    word-break: break-word;
    line-height: 1.5;
  }

  /* Token + cost total, inline in the collapsed summary's metadata slot. */
  .ch-rail-total {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg);
    letter-spacing: 0.02em;
  }

  /* ── Chart canvas ─────────────────────────────────────────────────────
     Full width of the column, above the raw data and citations. Hidden
     entirely until render_chart mounts something — no placeholder box. */
  .ch-canvas { min-width: 0; margin-bottom: var(--space-md); }
  .ch-canvas.ch-canvas-pending { display: none; }
  .ch-canvas .ch-chart-card { margin: 0; }

  /* ── Answer ── */
  .ch-answer { margin-bottom: var(--space-md); animation: fadeIn 0.3s var(--ease); }
  .ch-meta { margin-bottom: var(--space-md); animation: fadeIn 0.3s var(--ease); }
  .ch-finding {
    font-family: var(--font-sans);
    font-size: var(--text-body-lg);
    font-weight: 450;
    color: var(--fg);
    line-height: 1.6;
    margin: 0 0 6px;
    max-width: 68ch;
  }
  .ch-finding:empty { display: none; }
  /* Open-ended (explanation) answers: rendered markdown at body size so a
     long answer reads as writing rather than one enormous headline. The
     child selectors are :global because the nodes come from innerHTML. */
  .ch-finding-prose {
    font-size: var(--text-body);
    font-weight: 400;
  }
  .ch-finding :global(p) { margin: 0 0 0.8em; }
  .ch-finding :global(p:last-child) { margin-bottom: 0; }
  .ch-finding :global(ul), .ch-finding :global(ol) { margin: 0 0 0.8em; padding-left: 1.4em; }
  .ch-finding :global(li) { margin: 0 0 0.35em; }
  .ch-finding :global(h4) {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 600;
    margin: 1.1em 0 0.4em;
  }
  .ch-finding :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-sm);
    padding: 0.05em 0.35em;
  }
  .ch-finding :global(strong) { font-weight: 600; }
  /* Zero-result closing line: same slot/typography as a normal finding, but
     muted and non-italic — reads as a plain-language explanation rather than
     an authoritative answer. No separate error component. */
  .ch-finding-empty {
    font-style: normal;
    color: var(--fg-muted);
  }
  /* Low-confidence word tint (confidence-tinting stretch goal). Seeded from
     --confidence-low (aliased to --danger — see global.css), per the design
     spec's token mapping. Only ever applied by renderFinding() when a
     logprobs array is actually passed in; see that function's comment for
     why the live app currently always takes the plain-text branch instead.
     (The dormant two-swatch legend that used to key this was removed with the
     verification-state work — it was the key for this never-live logprob
     feature, unrelated to the verification verdict, and would have muddled two
     different "confidence" concepts sitting beside each other.) */
  :global(.ch-conf-word-lo) {
    color: var(--confidence-low);
    text-decoration: underline dotted;
    text-underline-offset: 3px;
    cursor: help;
  }

  /* ── Answer-level verification cue ────────────────────────────────────────
     The honest non-verified states. Muted throughout — amber (--signal) is
     reserved exclusively for the genuine VERIFIED stamp in the trace. A
     could-not-verify tag gets a dashed border with a faint danger tint; a
     verification-unavailable tag gets a plain dotted muted border. */
  .ch-verify { margin: 2px 0 var(--space-sm); }
  .ch-verify-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    letter-spacing: 0.02em;
    color: var(--fg-muted);
    padding: 2px 10px;
    border-radius: var(--radius-full);
    border: 1px dashed var(--fg-faint);
    max-width: 68ch;
  }
  .ch-verify-unverified .ch-verify-tag {
    border-style: dashed;
    border-color: color-mix(in srgb, var(--danger) 40%, var(--fg-faint));
    color: color-mix(in srgb, var(--danger) 55%, var(--fg-muted));
  }
  .ch-verify-unavailable .ch-verify-tag {
    border-style: dotted;
    color: var(--fg-muted);
  }

  /* ── Shared-answer banner (backlog #15) ──
     Muted, understated — a frozen snapshot, never amber. A thin left rule and
     a soft elevated background mark it as meta, distinct from the answer. */
  .ch-share-banner {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    line-height: 1.6;
    color: var(--fg-muted);
    background: color-mix(in srgb, var(--fg) 4%, transparent);
    border-left: 2px solid var(--fg-faint);
    border-radius: var(--radius-sm, 4px);
    padding: 8px 12px;
    margin-bottom: var(--space-sm);
  }
  .ch-share-banner-error {
    border-left-color: color-mix(in srgb, var(--danger) 50%, var(--fg-faint));
    color: color-mix(in srgb, var(--danger) 55%, var(--fg-muted));
  }
  :global(.ch-share-banner-lead) { color: var(--fg-muted); }
  :global(.ch-share-banner-link) {
    color: var(--signal);
    text-decoration: underline;
    text-underline-offset: 2px;
    white-space: nowrap;
  }
  :global(.ch-share-banner-link:focus-visible) {
    outline: 2px solid color-mix(in srgb, var(--signal) 55%, transparent);
    outline-offset: 2px;
    border-radius: 2px;
  }
  /* Shared verification tag: same muted treatment as the live cue — the amber
     VERIFIED stamp is never shown on a restored snapshot. */
  :global(.ch-verify-shared) { margin-top: var(--space-sm); }
  .ch-chart-card {
    margin: var(--space-sm) 0 0;
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    padding: 12px 14px 14px;
  }
  /* Card header: title on the left, unit/axis description right-aligned.
     The unit used to be an ECharts y-axis name that clipped off-canvas —
     it lives here now, always fully visible. */
  .ch-chart-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    padding: 2px 4px 10px;
  }
  .ch-chart-title {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg);
  }
  .ch-chart-unit {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--ch-meta);
  }
  .ch-chart-unit:empty { display: none; }
  .ch-chart { width: 100%; height: 380px; }

  /* ── Data table ── */
  .ch-data {
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    padding: var(--space-sm) var(--space-md);
    margin-top: var(--space-sm);
  }
  .ch-data summary {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ch-meta);
    cursor: pointer;
    padding: 5px 0;
    list-style: none;
  }
  .ch-data summary::-webkit-details-marker { display: none; }
  .ch-data summary::before { content: '▸ '; color: var(--fg-muted); }
  .ch-data[open] summary::before { content: '▾ '; }
  .ch-csv {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    background: transparent;
    color: var(--signal);
    border: none;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-transform: none;
    letter-spacing: 0;
    padding: 0;
  }
  /* Share action, styled to match .ch-csv (same mono underline, same amber
     --signal the CSV button already spends — no new accent introduced). */
  .ch-share {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    background: transparent;
    color: var(--signal);
    border: none;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-transform: none;
    letter-spacing: 0;
    padding: 0;
  }
  .ch-share:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--signal) 55%, transparent);
    outline-offset: 3px;
    border-radius: 2px;
  }
  /* The "copied" confirmation / oversized refusal, announced via aria-live. */
  .ch-share-status {
    display: block;
    text-align: right;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    min-height: 1.2em;
    padding-top: 2px;
  }
  .ch-share-status-error { color: color-mix(in srgb, var(--danger) 60%, var(--fg-muted)); }
  /* Fallback selectable input when navigator.clipboard is unavailable. */
  .ch-share-fallback {
    width: 100%;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    padding: 4px 6px;
    margin-top: 4px;
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-sm, 4px);
    background: var(--bg-elevated);
    color: var(--fg);
  }

  /* CSV action, top of the expanded raw-data panel (moved out of <summary>). */
  .ch-data-actions { display: flex; justify-content: flex-end; gap: 14px; padding: 4px 0 0; }
  .ch-table-scroll { max-height: 340px; overflow: auto; margin-top: 8px; }
  .ch-table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: var(--text-tag); }
  :global(.ch-table th) {
    text-align: left;
    color: var(--ch-meta);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 5px 8px;
    border-bottom: 1px solid var(--fg-faint);
    position: sticky;
    top: 0;
    background: var(--bg-elevated);
  }
  :global(.ch-table td) {
    padding: 4px 8px;
    color: var(--fg);
    border-bottom: 1px solid var(--fg-faint);
  }
  :global(.ch-table-more) { color: var(--ch-meta); text-align: center; }

  /* ── Chart ↔ table linking ──
     Rows that back a visible chart point are interactive: a pointer cursor
     hints they're clickable-from-the-chart / hoverable-to-the-chart, and a
     keyboard focus ring keeps them reachable. The amber --signal accent is
     spent only on the *active* row (the one a chart click selected): a left
     border plus a whisper of tinted background, no layout shift. */
  :global(.ch-table tr.ch-row-linkable) { cursor: pointer; }
  :global(.ch-table tr.ch-row-linkable:hover td) {
    background: color-mix(in srgb, var(--fg) 5%, transparent);
  }
  :global(.ch-table tr.ch-row-linkable:focus-visible) {
    outline: 1px solid color-mix(in srgb, var(--signal) 55%, transparent);
    outline-offset: -1px;
  }
  :global(.ch-table tr.ch-row-active td) {
    background: color-mix(in srgb, var(--signal) 13%, transparent);
  }
  :global(.ch-table tr.ch-row-active td:first-child) {
    box-shadow: inset 3px 0 0 var(--signal);
  }

  /* ── Citations: a references section on a receipt — compact, mono,
     understated, amber used sparingly (only the section rule + hairlines). ── */
  .ch-cite {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    line-height: 1.6;
    margin-top: var(--space-sm);
    padding: 0 2px;
    word-break: break-word;
  }
  :global(.ch-cite-head) {
    font-size: var(--text-tag);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding-bottom: 4px;
    /* The one amber accent: a thin top rule stamps the references block, like a
       receipt's tear line above its footer. Everything else stays muted. */
    border-top: 1px dashed color-mix(in srgb, var(--signal) 45%, transparent);
    padding-top: 6px;
  }
  :global(.ch-cite-list) {
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
    counter-reset: ch-cite;
  }
  :global(.ch-cite-item) {
    counter-increment: ch-cite;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2px 8px;
    padding: 6px 0;
    border-bottom: 1px dotted var(--fg-faint);
  }
  :global(.ch-cite-item:last-child) { border-bottom: none; }
  /* A hanging "[n]" reference marker in the left gutter. */
  :global(.ch-cite-item::before) {
    content: '[' counter(ch-cite) ']';
    grid-row: 1 / span 2;
    color: var(--fg-muted);
    align-self: start;
    padding-top: 1px;
  }
  :global(.ch-cite-src) {
    grid-column: 2;
    color: var(--fg-muted);
    font-weight: 600;
  }
  :global(.ch-cite-ind) {
    grid-column: 2;
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--fg-muted);
  }
  :global(.ch-cite-ind:hover) { text-decoration-color: var(--fg); }
  :global(.ch-cite-id) { color: var(--fg-muted); }
  :global(.ch-cite-facets) {
    grid-column: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 6px;
    margin-top: 2px;
    color: var(--fg-muted);
  }
  /* Facets separated by a hairline middot, receipt-line style. */
  :global(.ch-cite-facet + .ch-cite-facet)::before,
  :global(.ch-cite-facet + .ch-cite-vintage)::before {
    content: '·';
    margin-right: 6px;
    color: var(--fg-muted);
  }
  /* The vintage — the one honest data-provenance fact worth a subtle amber tint. */
  :global(.ch-cite-vintage) {
    color: color-mix(in srgb, var(--signal) 80%, var(--fg-muted));
  }
  :global(.ch-cite a) { color: var(--fg-muted); text-decoration: underline; text-underline-offset: 2px; }
  :global(.ch-cite a:hover) { color: var(--fg); }

  /* ── Responsive ── */
  /* ── Dashboards: nav chip, pin action, pin picker, dashboard view ─────── */
  .ch-dash-nav {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    color: var(--fg-muted);
    background: transparent;
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-full);
    padding: 3px 11px;
    cursor: pointer;
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }
  .ch-dash-nav:hover { color: var(--fg); background: var(--bg-hover); border-color: color-mix(in srgb, var(--fg) 22%, transparent); }
  .ch-dash-nav:focus-visible { outline: 2px solid color-mix(in srgb, var(--signal) 55%, transparent); outline-offset: 2px; }
  .ch-dash-nav svg { flex-shrink: 0; }
  .ch-dash-nav-count {
    font-size: 10px;
    min-width: 16px;
    text-align: center;
    padding: 0 4px;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--signal) 20%, transparent);
    color: var(--fg);
  }

  /* Pin action: styled to match .ch-csv / .ch-share (same mono underline). */
  .ch-pin {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    background: transparent;
    color: var(--signal);
    border: none;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
    padding: 0;
  }
  .ch-pin:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--signal) 55%, transparent);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* Pin picker: a centered modal dialog with a dimmed backdrop. */
  .ch-pin-backdrop:not([hidden]) {
    display: block;
    position: fixed;
    inset: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--bg) 62%, transparent);
  }
  .ch-pin-dialog:not([hidden]) {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ch-pin-dialog {
    position: fixed;
    z-index: 41;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: min(420px, calc(100vw - 32px));
    max-height: 85vh;
    overflow-y: auto;
    background: color-mix(in srgb, var(--fg) 6%, var(--bg));
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-lg);
    box-shadow: 0 12px 48px color-mix(in srgb, var(--bg) 70%, transparent);
    padding: var(--space-md);
  }
  .ch-pin-head { display: flex; align-items: center; justify-content: space-between; }
  .ch-pin-title {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg);
  }
  .ch-pin-close {
    background: transparent; border: none; cursor: pointer;
    color: var(--fg-muted); font-size: 15px; line-height: 1; padding: 4px;
  }
  .ch-pin-close:hover { color: var(--fg); }
  .ch-pin-close:focus-visible { outline: 2px solid color-mix(in srgb, var(--signal) 55%, transparent); outline-offset: 2px; border-radius: 3px; }
  .ch-pin-sub { font-size: var(--text-tag); color: var(--fg-muted); margin: 0; }
  .ch-pin-list { display: flex; flex-direction: column; gap: 6px; }
  /* Rows inside the pin list are built in JS (no Astro scope attribute), so
     their selectors must be :global — same discipline as the trace/citation
     renderers elsewhere in this file. */
  :global(.ch-pin-empty) { font-family: var(--font-mono); font-size: var(--text-tag); color: var(--fg-muted); margin: 0; }
  :global(.ch-pin-existing) {
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
    font-family: var(--font-mono); font-size: var(--text-tag);
    text-align: left;
    background: var(--bg-elevated);
    border: 1px solid var(--fg-faint);
    border-radius: var(--radius-md);
    padding: 8px 11px;
    color: var(--fg);
    cursor: pointer;
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }
  :global(.ch-pin-existing:hover) { border-color: color-mix(in srgb, var(--signal) 45%, transparent); background: var(--bg-hover); }
  :global(.ch-pin-existing:focus-visible) { outline: 2px solid color-mix(in srgb, var(--signal) 55%, transparent); outline-offset: 2px; }
  :global(.ch-pin-existing-meta) { color: var(--fg-muted); flex-shrink: 0; }
  /* Replace-a-tile affordance (increment 2): the primary "add new" button plus a
     secondary toggle that expands the dashboard's tiles for a slot-preserving
     replace. */
  :global(.ch-pin-existing-row) { display: flex; flex-direction: column; gap: 4px; }
  :global(.ch-pin-existing-row .ch-pin-existing) { width: 100%; }
  :global(.ch-pin-replace-toggle) {
    align-self: flex-start;
    font-family: var(--font-mono); font-size: var(--text-tag);
    background: transparent; border: none; color: var(--fg-muted);
    padding: 2px 4px; cursor: pointer; text-decoration: underline; text-underline-offset: 2px;
  }
  :global(.ch-pin-replace-toggle:hover) { color: var(--fg); }
  :global(.ch-pin-replace-toggle:focus-visible) { outline: 2px solid color-mix(in srgb, var(--signal) 55%, transparent); outline-offset: 2px; }
  :global(.ch-pin-replace-list) { display: flex; flex-direction: column; gap: 4px; padding: 2px 0 4px 10px; border-left: 1px dashed var(--fg-faint); margin-left: 4px; }
  :global(.ch-pin-replace-tile) {
    text-align: left;
    font-family: var(--font-mono); font-size: var(--text-tag);
