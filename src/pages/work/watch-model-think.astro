  :global(.fd-pill) { font-family: var(--font-mono); font-size: var(--text-tag); color: var(--fg-muted); padding: 0.15rem 0.5rem; border: 1px solid var(--fg-faint); border-radius: 100px; white-space: nowrap; }
  :global(.fd-chosen) { color: var(--accent-color); border-color: var(--accent-color); }

  .stepper-callout { display: none; padding: var(--space-sm) var(--space-lg); margin: 0 var(--space-lg) var(--space-md); background: color-mix(in srgb, var(--accent-color) 6%, transparent); border-left: 2px solid var(--accent-color); border-radius: 0 6px 6px 0; font-size: var(--text-small); line-height: 1.6; color: var(--fg); }
