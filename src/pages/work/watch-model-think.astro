  .stepper-next, .stepper-prev { font-family: var(--font-mono); font-size: var(--text-label); color: var(--fg); background: var(--bg-elevated); border: 1px solid var(--fg-faint); border-radius: 6px; padding: 0.4rem 1.25rem; cursor: pointer; transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease); }
