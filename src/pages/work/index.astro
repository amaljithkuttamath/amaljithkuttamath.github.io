---
import Base from '../../layouts/Base.astro';

const allPosts = import.meta.glob('./*.md', { eager: true }) as Record<string, any>;
const posts = Object.entries(allPosts)
  .map(([path, mod]) => ({ ...mod, url: '/work/' + path.replace('./', '').replace('.md', '') }))
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

// ── Research & Experiments (open-source repos with blog posts) ──
const research = [
  {
    title: 'sae-explorer',
    metric: 'Cross-lingual feature found in 6 languages',
    desc: 'Found a single SAE feature in Gemma 2 2B that detects conjunctions across 6 languages with zero false positives.',
    tags: ['interpretability', 'sae', 'gemma'],
    post: '/work/sae-explorer',
    repo: 'https://github.com/amaljithkuttamath/sae-explorer',
    details: {
      problem: 'Do multilingual models store concepts once or per-language? SAEs can decompose activations into interpretable features, but finding genuinely monosemantic cross-lingual features requires systematic probing.',
      approach: 'Load Gemma Scope layer 12 SAE (16K features). Run parallel sentences in 6 languages through Gemma 2 2B. Filter for narrow, selective features.',
      stack: 'SAELens, TransformerLens, PyTorch, Gemma 2 2B',
      outcome: 'Feature #10543: conjunction-only, 6 languages, 0 false positives. Also found cross-lingual "cat" feature (#4497) and sentence-initial determiner feature (#1178).',
    },
  },
  {
    title: 'hybrid-attention-150m',
    metric: 'DeltaNet from scratch on Apple Silicon',
    desc: 'Trained Qwen3.5 hybrid architecture at 8M and 150M params. Found and fixed a numerical bug in the triangular solve.',
    tags: ['mlx', 'deltanet', 'training'],
    post: '/work/hybrid-attention-150m',
    repo: 'https://github.com/amaljithkuttamath/autoresearch-mlx-qwen-3-5',
    details: {
      problem: 'Qwen3.5 uses a novel 3:1 linear/full attention pattern. Understanding it requires training it, not just reading about it.',
      approach: 'From-scratch MLX implementation. Trained at 8M (works) and 150M (NaN). Debugged the repeated-squaring triangular solve to find missing terms in the Neumann series.',
      stack: 'MLX, Python, Apple Silicon M-series',
      outcome: '150M model trained to BPB 2.036. Found that MLX lacks tri_inv VJP and associative_scan, limiting DeltaNet training.',
    },
  },
  {
    title: 'calibration-probe',
    metric: 'ECE 0.107, overconfident by 3%',
    desc: 'Measures whether LLMs know when they are wrong. 102 factual questions, forced confidence, calibration curves.',
    tags: ['calibration', 'llm-safety', 'evaluation'],
    post: '/work/calibration-probe',
    repo: 'https://github.com/amaljithkuttamath/calibration-probe',
    details: {
      problem: 'A model that says "90% confident" but is only right 75% of the time is dangerous in production.',
      approach: '102 factual questions across 5 categories. Model states confidence 0-100. Binned by confidence, actual accuracy measured per bin.',
      stack: 'Python, matplotlib, Anthropic API, OpenAI API',
      outcome: 'Models are slightly overconfident (89% confidence, 86% accuracy). Geography worst calibrated. ECE = 0.107.',
    },
  },
  {
    title: 'superposition-viz',
    metric: 'Phase transition at 0.7 sparsity',
    desc: 'Reproduces key findings from Anthropic\'s Toy Models of Superposition paper.',
    tags: ['superposition', 'interpretability', 'anthropic'],
    post: '/work/superposition-viz',
    repo: 'https://github.com/amaljithkuttamath/superposition-viz',
    details: {
      problem: 'Superposition blocks mechanistic interpretability. If features share dimensions, no single neuron maps to a single concept.',
      approach: 'Toy model: linear encoder, ReLU bottleneck, tied decoder. Trains at multiple sparsity levels. Phase diagrams and interference matrices.',
      stack: 'PyTorch, matplotlib, numpy',
      outcome: 'Clear phase transition at 0.7 sparsity. Model jumps from 4 to 5+ features in a 5-dim bottleneck. Matches Anthropic Figure 2.',
    },
  },
  {
    title: 'attention-bench',
    metric: '4 variants from scratch',
    desc: 'Benchmarks MHA, GQA, MQA, and Sliding Window attention by training small transformers on identical data.',
    tags: ['attention', 'pytorch', 'from-scratch'],
    post: '/work/attention-bench',
    repo: 'https://github.com/amaljithkuttamath/attention-bench',
    details: {
      problem: 'Attention variant papers describe tradeoffs theoretically. Direct empirical comparison on identical setups is rare.',
      approach: 'Four attention mechanisms from scratch. Same decoder-only transformer, same data, same hyperparameters.',
      stack: 'PyTorch, tiktoken, HuggingFace datasets',
      outcome: 'MQA uses 25% fewer KV parameters than MHA. GQA sits between. SWA trades global context for linear memory scaling.',
    },
  },
  {
    title: 'scaling-laws',
    metric: '5 model sizes, power law fit',
    desc: 'Tests whether Chinchilla scaling laws hold at toy scale. Trains 100K to 10M param transformers.',
    tags: ['scaling-laws', 'chinchilla', 'training'],
    post: '/work/scaling-laws',
    repo: 'https://github.com/amaljithkuttamath/scaling-laws',
    details: {
      problem: 'Scaling laws guide billion-dollar training decisions. Do they hold when you go small?',
      approach: 'Five decoder-only transformers (100K-10M params) trained on TinyStories. Power law fitted with scipy.',
      stack: 'PyTorch, tiktoken, scipy, matplotlib',
      outcome: 'GitHub Action auto-generates scaling curves and compute-optimal frontier plots.',
    },
  },
  {
    title: 'activation-atlas',
    metric: 'Layer-by-layer UMAP projections',
    desc: 'Visualizes how a CNN transforms raw pixels into class-separable representations.',
    tags: ['activations', 'umap', 'visualization'],
    post: '/work/activation-atlas',
    repo: 'https://github.com/amaljithkuttamath/activation-atlas',
    details: {
      problem: 'Neural networks learn hierarchical representations, but this is invisible during training.',
      approach: 'Forward hooks capture activations at every layer. UMAP projects to 2D, colored by class.',
      stack: 'PyTorch, umap-learn, scikit-learn, matplotlib',
      outcome: 'Early layers: classes overlap. Final layers: tight clusters. PCA shows compression from distributed to compact.',
    },
  },
  {
    title: 'loss-landscape',
    metric: '3D loss surface visualization',
    desc: 'Visualizes the loss landscape around trained weights. Sharp vs flat minima and what controls which one you find.',
    tags: ['optimization', 'generalization', 'pytorch'],
    post: '/work/loss-landscape',
    repo: 'https://github.com/amaljithkuttamath/loss-landscape',
    details: {
      problem: 'Sharp minima generalize poorly. No standard tool makes the landscape concrete.',
      approach: 'Filter-normalized perturbations (Li et al. 2018) along two random directions. Maps loss on a 2D grid around the minimum.',
      stack: 'PyTorch, matplotlib, numpy',
      outcome: 'Large LR and small batch size produce flatter minima. 3D surface plots and quantified sharpness comparison.',
    },
  },
];

// ── Production Systems (professional work, no public repos) ──
const production = [
  {
    title: 'Healthcare RAG Pipeline',
    metric: '10K+ daily queries',
    desc: 'Production RAG system for clinicians. Hallucination-aware retrieval with domain-specific re-ranking.',
    tags: ['RAG', 'vertex ai', 'hallucination detection'],
    details: {
      problem: 'Clinicians need grounded answers from medical records and research. Standard retrieval surfaces irrelevant context, leading to hallucinated outputs.',
      approach: 'Retrieval-augmented generation on Vertex AI with hallucination-aware retrieval. Domain-specific re-ranking for clinical relevance.',
      stack: 'Vertex AI, Gemini Pro, LangChain, LlamaIndex',
      outcome: 'Serves 10,000+ daily clinical queries. Developed methodology for measuring retrieval fidelity and hallucination rates.',
    },
  },
  {
    title: 'LLM Fine-tuning System',
    metric: '25% lower inference cost',
    desc: 'Fine-tuning Qwen2.5-3B with GRPO + LoRA. Studied how reward-guided optimization changes model behavior.',
    tags: ['fine-tuning', 'GRPO', 'vLLM'],
    details: {
      problem: 'Off-the-shelf models underperform on domain tasks. Understanding how fine-tuning alters behavior requires both training infra and evaluation methodology.',
      approach: '4-bit quantization with LoRA adapters. GRPO for reward-guided optimization. vLLM for high-throughput inference.',
      stack: 'PyTorch, Hugging Face, LoRA, vLLM',
      outcome: 'Deployed fine-tuned 3B model to production, reducing inference costs by 25%.',
    },
  },
  {
    title: 'Medical Knowledge Graph',
    metric: '5 entity types, cross-format search',
    desc: 'Knowledge graph connecting diseases, drugs, treatments, and clinical trials. Powers retrieval grounding.',
    tags: ['neo4j', 'knowledge graphs', 'embeddings'],
    details: {
      problem: 'Medical knowledge is scattered across databases, papers, and records. Flat storage loses entity relationships.',
      approach: 'Graph schema mapping diseases, treatments, drugs, clinical trials. Multi-modal embeddings for cross-format querying.',
      stack: 'Neo4j, Elasticsearch, sentence-transformers',
      outcome: 'Powers the retrieval grounding layer. Enables entity-aware queries across text, structured data, and metadata.',
    },
  },
  {
    title: 'Drug Safety Sentiment Analysis',
    metric: 'Early warning signals',
    desc: 'Transformer classifiers detecting sentiment shifts in medical expert opinions for pharmacovigilance.',
    tags: ['NLP', 'safety signals', 'healthcare'],
    details: {
      problem: 'Pharmaceutical safety teams need to detect early warning signs before adverse events escalate.',
      approach: 'Fine-tuned transformer classifiers on domain-specific medical language. Tracks sentiment per drug per condition over time.',
      stack: 'PyTorch, Hugging Face, spaCy',
      outcome: 'Surfaces drugs with increasing negative sentiment. Integrated into pharmacovigilance workflows.',
    },
  },
  {
    title: 'Predictive Maintenance',
    metric: '90%+ accuracy, 50% less downtime',
    desc: 'Digital twin platform for industrial machinery. Anomaly detection and time-to-failure prediction from IoT streams.',
    tags: ['anomaly detection', 'time series', 'digital twins'],
    details: {
      problem: 'Unplanned machine downtime is expensive. Raw sensor data exists but is not used for proactive failure prediction.',
      approach: 'Signal processing pipeline ingesting IoT sensor streams. Feature extraction and time-to-failure models trained on historical failure data.',
      stack: 'Python, scikit-learn, Azure Data Lake, Power BI',
      outcome: '90%+ anomaly detection accuracy. Reduced machine downtime by 50% across deployed sites.',
    },
  },
];

// ── Open-Source Tools (installable CLIs) ──
const tools = [
  {
    title: 'crux',
    metric: 'Real-time token analytics',
    desc: 'Terminal dashboard for Claude Code usage. Tracks context growth, cache efficiency, cost breakdowns, and session health.',
    tags: ['rust', 'tui', 'claude-code'],
    post: '/work/crux',
    repo: 'https://github.com/amaljithkuttamath/crux',
    install: { brew: 'brew install amaljithkuttamath/tap/crux', cargo: 'cargo install crux-cli' },
    details: {
      problem: 'Claude Code users have no visibility into token usage patterns. Sessions vary wildly in cost with no way to diagnose why.',
      approach: 'Rust TUI that reads Claude Code JSONL session logs in real-time. Computes rolling statistics, cache hit ratios, and health grades.',
      stack: 'Rust, ratatui, tokio, serde, MCP server',
      outcome: 'Open-source with cross-platform releases. Reveals usage patterns invisible from the Claude Code interface.',
    },
  },
  {
    title: 'tokenizer-arena',
    metric: 'Compare 4 encodings',
    desc: 'CLI that runs the same text through multiple LLM tokenizers and shows differences in token count and boundaries.',
    tags: ['rust', 'tokenizers', 'cli'],
    post: '/work/tokenizer-arena',
    repo: 'https://github.com/amaljithkuttamath/tokenizer-arena',
    install: { cargo: 'cargo install tokenizer-arena' },
    details: {
      problem: 'Tokenizer choice affects training efficiency and inference cost, but comparing tokenizers requires custom scripts.',
      approach: 'Wraps tiktoken-rs to compare cl100k_base, o200k_base, p50k_base, and r50k_base side by side.',
      stack: 'Rust, tiktoken-rs, comfy-table, clap',
      outcome: 'Newer tokenizers are ~25% more efficient on code. Works fully offline. JSON output for scripting.',
    },
  },
  {
    title: 'gguf-inspect',
    metric: 'Parse models byte by byte',
    desc: 'CLI that reads GGUF model files and prints architecture, quantization, tensor shapes, and memory estimates.',
    tags: ['rust', 'gguf', 'model-internals'],
    post: '/work/gguf-inspect',
    repo: 'https://github.com/amaljithkuttamath/gguf-inspect',
    details: {
      problem: 'Understanding what is inside a quantized model file requires reading llama.cpp source or scattered docs.',
      approach: 'From-scratch GGUF binary parser in Rust. Reads header, metadata, tensor info. Computes parameter counts and memory estimates.',
      stack: 'Rust, byteorder, comfy-table, clap',
      outcome: 'Tested on Llama 3.2 3B. Reveals mixed-precision quantization, GQA head ratios, and 6.7x compression from FP32.',
    },
  },
  {
    title: 'skill-doctor',
    metric: 'Claude Code plugin',
    desc: 'Audits your Claude Code skills and diagnoses issues. Builds upgrades in staging with rollback.',
    tags: ['claude-code', 'skills', 'tooling'],
    post: '/work/skill-doctor',
    repo: 'https://github.com/amaljithkuttamath/skill-doctor',
    details: {
      problem: 'Claude Code skills accumulate bad patterns: redundant context, missing guards, no tool restrictions.',
      approach: 'Reads all skills and sends each to the claude-code-guide agent for evaluation against current docs.',
      stack: 'Claude Code plugin, Markdown skills',
      outcome: 'Found and fixed issues in all 5 of my own skills. Saved ~2,500 tokens per session from context duplication.',
    },
  },
];

// ── Spotlight ──
const spotlight = {
  title: 'Trust Bench',
  desc: 'Open-source profiler for LLM trustworthiness. Extracts internal signals, evaluates across safety dimensions, diagnoses failure modes, and measures trust boundaries specific to deployment context.',
  tags: ['AI safety', 'mechanistic interpretability', 'PyTorch', 'evaluation'],
  status: 'in progress',
};

const paper = {
  title: 'Predicting Risk of Lung Cancer From Medical History',
  journal: 'Quality Management in Health Care',
  year: 2025,
  links: [
    { label: 'paper', url: 'https://doi.org/10.1097/QMH.0000000000000525' },
    { label: 'pubmed', url: 'https://pubmed.ncbi.nlm.nih.gov/40197410/' },
  ],
};
---

<Base title="Work | Amaljith Kuttamath" description="Research in LLM trust and safety, production AI systems, and open-source developer tools.">

  <div class="page-header animate-in">
    <h1>Work</h1>
  </div>

  <!-- ── Spotlight ── -->
  <section class="animate-in animate-in-delay-1">
    <div class="section-label">Spotlight</div>
    <div class="spotlight-card">
      <div class="spotlight-head">
        <h2>{spotlight.title}</h2>
        <span class="status-badge">{spotlight.status}</span>
      </div>
      <p>{spotlight.desc}</p>
      <div class="tags">
        {spotlight.tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    </div>
    <div class="paper-row">
      <span class="paper-title">{paper.title}</span>
      <span class="paper-meta">
        <em>{paper.journal}, {paper.year}</em>
        {paper.links.map((link) => (
          <a href={link.url} class="paper-link" target="_blank" rel="noopener noreferrer">{link.label} &rarr;</a>
        ))}
      </span>
    </div>
  </section>

  <!-- ── Research & Experiments ── -->
  <section class="animate-in animate-in-delay-1">
    <div class="section-label">Research &amp; Experiments</div>
    <div class="proof-grid">
      {research.map((item) => (
        <details class="proof-card">
          <summary>
            <span class="proof-metric">{item.metric}</span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <div class="tags">
              {item.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </summary>
          <div class="work-item-details">
            <div class="detail-row">
              <span class="detail-label">Problem</span>
              <span class="detail-value">{item.details.problem}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Approach</span>
              <span class="detail-value">{item.details.approach}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Stack</span>
              <span class="detail-value detail-stack">{item.details.stack}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Outcome</span>
              <span class="detail-value">{item.details.outcome}</span>
            </div>
            <div class="detail-links">
              {item.post && <a href={item.post} class="work-link">read more &rarr;</a>}
              {item.repo && <a href={item.repo} class="work-link" target="_blank" rel="noopener noreferrer">code &rarr;</a>}
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- ── Production Systems ── -->
  <section class="animate-in animate-in-delay-2">
    <div class="section-label">Production Systems</div>
    <div class="proof-grid">
      {production.map((item) => (
        <details class="proof-card">
          <summary>
            <span class="proof-metric">{item.metric}</span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <div class="tags">
              {item.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </summary>
          <div class="work-item-details">
            <div class="detail-row">
              <span class="detail-label">Problem</span>
              <span class="detail-value">{item.details.problem}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Approach</span>
              <span class="detail-value">{item.details.approach}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Stack</span>
              <span class="detail-value detail-stack">{item.details.stack}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Outcome</span>
              <span class="detail-value">{item.details.outcome}</span>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- ── Open-Source Tools ── -->
  <section class="animate-in animate-in-delay-2">
    <div class="section-label">Open-Source Tools</div>
    <div class="proof-grid">
      {tools.map((item) => (
        <details class="proof-card">
          <summary>
            <span class="proof-metric">{item.metric}</span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            {item.install && (
              <div class="install-row">
                {Object.entries(item.install).map(([key, cmd]) => (
                  <code class={`install-cmd ${key === 'brew' ? 'install-primary' : ''}`}>{cmd}</code>
                ))}
              </div>
            )}
            <div class="tags">
              {item.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </summary>
          <div class="work-item-details">
            <div class="detail-row">
              <span class="detail-label">Problem</span>
              <span class="detail-value">{item.details.problem}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Approach</span>
              <span class="detail-value">{item.details.approach}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Stack</span>
              <span class="detail-value detail-stack">{item.details.stack}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Outcome</span>
              <span class="detail-value">{item.details.outcome}</span>
            </div>
            <div class="detail-links">
              {item.post && <a href={item.post} class="work-link">read more &rarr;</a>}
              {item.repo && <a href={item.repo} class="work-link" target="_blank" rel="noopener noreferrer">code &rarr;</a>}
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- ── Interactive ── -->
  <section class="animate-in animate-in-delay-2">
    <div class="section-label">Interactive</div>
    <a href="/playground" class="playground-card">
      <div class="playground-head">
        <h3>microGPT Playground</h3>
        <span class="playground-cta">try it live &rarr;</span>
      </div>
      <p>Train a transformer in your browser. Watch attention patterns, embeddings, and loss evolve in real time.</p>
      <div class="tags">
        <span class="tag">interactive</span>
        <span class="tag">d3.js</span>
        <span class="tag">transformers</span>
      </div>
    </a>
  </section>

</Base>

<style>
  /* ── Section labels ── */
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    margin-bottom: var(--space-md);
    margin-top: var(--space-xl);
  }

  /* ── Spotlight ── */
  .spotlight-card {
    padding: var(--space-lg);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    background: var(--bg-elevated);
  }

  .spotlight-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .spotlight-card h2 {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .status-badge {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-color);
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--accent-color);
    border-radius: 100px;
  }

  .spotlight-card p {
    font-size: var(--text-body);
    color: var(--fg-muted);
    line-height: 1.7;
    margin: 0.25rem 0 var(--space-md);
    max-width: 580px;
  }

  .paper-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.75rem 0;
    margin-top: 0.75rem;
    border-top: 1px solid var(--fg-faint);
  }

  .paper-title {
    font-size: var(--text-small);
    font-weight: 500;
  }

  .paper-meta {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: var(--text-small);
    color: var(--fg-muted);
  }

  .paper-link {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
    text-decoration: none;
  }

  .paper-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Playground card ── */
  .playground-card {
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .playground-card:hover {
    border-color: var(--accent-color);
    background: var(--bg-elevated);
  }

  .playground-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .playground-card h3 {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .playground-cta {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
    white-space: nowrap;
  }

  .playground-card p {
    font-size: var(--text-body);
    color: var(--fg-muted);
    line-height: 1.7;
    margin: 0 0 var(--space-md);
    max-width: 580px;
  }

  /* ── Proof grid ── */
  .proof-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .proof-card {
    padding: var(--space-md);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    cursor: pointer;
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .proof-card:hover {
    border-color: var(--accent-color);
    background: var(--bg-elevated);
  }

  .proof-card summary {
    list-style: none;
  }

  .proof-card summary::-webkit-details-marker {
    display: none;
  }

  .proof-metric {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
    text-transform: uppercase;
