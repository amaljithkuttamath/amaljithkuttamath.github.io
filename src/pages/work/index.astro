---
import Base from '../../layouts/Base.astro';

const allPosts = import.meta.glob('./*.md', { eager: true }) as Record<string, any>;
const posts = Object.entries(allPosts)
  .map(([path, mod]) => ({ ...mod, url: '/work/' + path.replace('./', '').replace('.md', '') }))
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

// ── Spotlight: defines who you are right now ──
const spotlight = [
  {
    title: 'Trust Bench',
    desc: 'Framework for profiling LLM trustworthiness. Extracts internal signals, evaluates across safety dimensions (truthfulness, fairness, robustness), diagnoses failure modes, and measures trust boundaries specific to deployment context.',
    tags: ['AI safety', 'mechanistic interpretability', 'PyTorch', 'evaluation'],
    status: 'in progress',
    links: [],
  },
  {
    title: 'Predicting Risk of Lung Cancer From Medical History',
    desc: 'Peer-reviewed research achieving AUC 0.82 in lung cancer risk prediction using Electronic Health Records. Developed methodology for clinical risk modeling with structured EHR data.',
    journal: 'Quality Management in Health Care',
    year: 2025,
    tags: ['research', 'healthcare', 'machine learning'],
    links: [
      { label: 'paper', url: 'https://doi.org/10.1097/QMH.0000000000000525' },
      { label: 'pubmed', url: 'https://pubmed.ncbi.nlm.nih.gov/40197410/' },
    ],
  },
];

// ── Proof: shipped systems with hard numbers ──
const proof = [
  {
    title: 'skill-doctor',
    metric: 'Claude Code plugin',
    desc: 'Audits your Claude Code skills against 10 best-practice checks. Diagnoses issues, builds upgrades in a staging directory, and migrates with rollback.',
    tags: ['claude-code', 'skills', 'tooling'],
    details: {
      problem: 'Claude Code skills accumulate bad patterns: redundant context, missing tool restrictions, no invocation guards. Existing validators only check YAML syntax.',
      approach: 'Reads all skills, agents, and CLAUDE.md. Scores against 10 checks covering dynamic injection, duplication, tool restrictions, and invocation safety. Consult mode maps findings to actual workflow pain points.',
      stack: 'Claude Code plugin, Markdown skills',
      outcome: 'Found and fixed issues in all 5 of my own skills. Saved ~2,500 tokens per session from context duplication alone.',
    },
  },
  {
    title: 'Healthcare RAG Pipeline',
    metric: '10K+ daily queries',
    desc: 'Production RAG system for clinicians querying medical records and PubMed. Built hallucination-aware retrieval with domain-specific re-ranking.',
    tags: ['RAG', 'vertex ai', 'hallucination detection'],
    details: {
      problem: 'Clinicians need accurate, grounded answers from medical records and research. Standard retrieval surfaces irrelevant context, leading to hallucinated outputs in clinical settings.',
      approach: 'Retrieval-augmented generation on Vertex AI with hallucination-aware retrieval. Domain-specific re-ranking ensures clinical relevance. Measurement of retrieval fidelity across query types.',
      stack: 'Vertex AI, Gemini Pro, LangChain, LlamaIndex, Python',
      outcome: 'Serves 10,000+ daily clinical queries. Developed methodology for measuring retrieval fidelity and hallucination rates in domain-specific RAG.',
    },
  },
  {
    title: 'Medical Knowledge Graph',
    metric: '5 entity types, cross-format search',
    desc: 'Knowledge graph connecting diseases, drugs, treatments, and clinical trials. Powers retrieval grounding for the RAG system.',
    tags: ['neo4j', 'knowledge graphs', 'embeddings'],
    details: {
      problem: 'Medical knowledge is scattered across databases, papers, and records. Flat storage loses entity relationships critical for accurate retrieval.',
      approach: 'Graph schema mapping diseases, treatments, drugs, clinical trials, and expert opinions. Multi-modal embeddings for cross-format querying. Provides structured grounding for RAG retrieval.',
      stack: 'Neo4j, Elasticsearch, Python, sentence-transformers',
      outcome: 'Powers the retrieval grounding layer. Enables entity-aware queries across text, structured data, and metadata.',
    },
  },
  {
    title: 'LLM Fine-tuning System',
    metric: '25% lower inference cost',
    desc: 'Fine-tuning Qwen2.5-3B with GRPO + LoRA. Studied how reward-guided optimization changes model behavior at the output distribution level.',
    tags: ['LLM', 'fine-tuning', 'GRPO', 'vLLM'],
    details: {
      problem: 'Off-the-shelf models underperform on domain tasks. Understanding how fine-tuning alters model behavior requires both training infrastructure and evaluation methodology.',
      approach: '4-bit quantization with LoRA adapters for memory-efficient training. GRPO for reward-guided optimization. vLLM for high-throughput inference with auto-scaling.',
      stack: 'PyTorch, Hugging Face, LoRA, vLLM, Python',
      outcome: 'Deployed fine-tuned 3B parameter model to production, reducing inference costs by 25%. Developed evaluation pipeline for measuring behavioral shift pre/post fine-tuning.',
    },
  },
  {
    title: 'Drug Safety Sentiment Analysis',
    metric: 'early warning signals',
    desc: 'Transformer classifiers detecting sentiment shifts in medical expert opinions to flag safety signals for pharmaceutical products.',
    tags: ['NLP', 'safety signals', 'healthcare'],
    details: {
      problem: 'Pharmaceutical safety teams need to detect early warning signs in expert opinions before adverse events escalate. Manual review doesn\'t scale.',
      approach: 'Fine-tuned transformer classifiers on domain-specific medical language. Tracks sentiment shifts per drug per condition over time. Measures classifier reliability against pharmacovigilance ground truth.',
      stack: 'PyTorch, Hugging Face Transformers, spaCy, Python',
      outcome: 'Surfaces drugs with increasing negative sentiment for safety review. Integrated into existing pharmacovigilance workflows.',
    },
  },
  {
    title: 'NL-to-Insights',
    metric: '5,000+ SKUs',
    desc: 'Ask a question in plain English about your inventory, get back a chart.',
    tags: ['RAG', 'GPT', 'plotly'],
    details: {
      problem: "Warehouse managers need inventory analytics but can't write SQL. Analysts become bottlenecks for routine data questions.",
      approach: 'Natural language to SQL translation via GPT-3.5 Turbo. Queries execute against inventory and sales databases. Results render as interactive Plotly charts.',
      stack: 'GPT-3.5 Turbo, Plotly, PostgreSQL, Python, FastAPI',
      outcome: 'Used for demand forecasting across 5,000+ SKUs. Eliminated analyst dependency for standard inventory queries.',
    },
  },
  {
    title: 'EDI Pipelines',
    metric: '2TB+ processed, 50+ pipelines',
    desc: 'Data pipelines moving business data between ERP systems, warehouses, and reporting tools.',
    tags: ['azure', 'databricks', 'ETL'],
    details: {
      problem: 'Business partners exchange data via EDI, a standardized-in-theory format that varies wildly in practice.',
      approach: 'Azure Data Factory orchestrates ingestion and routing. Databricks handles transformation, schema normalization, and quality checks.',
      stack: 'Azure Data Factory, Databricks, Azure Data Lake, Python, SQL',
      outcome: 'Processed over 2TB of transaction data. Connected ERP systems, warehouses, and reporting tools into a single pipeline.',
    },
  },
  {
    title: 'Predictive Maintenance',
    metric: '90%+ accuracy, 50% less downtime',
    desc: 'Digital twin platform for industrial machinery. Anomaly detection and time-to-failure prediction from IoT sensor streams.',
    tags: ['anomaly detection', 'time series', 'digital twins'],
    details: {
      problem: "Unplanned machine downtime is expensive. Raw sensor data exists but isn't used for proactive failure prediction.",
      approach: 'Signal processing pipeline ingesting IoT sensor streams. Feature extraction, anomaly detection, and time-to-failure models trained on historical failure data.',
      stack: 'Python, scikit-learn, Azure Data Lake, Power BI',
      outcome: '90%+ anomaly detection accuracy. 95% time-to-failure prediction. Reduced machine downtime by 50% across deployed sites.',
    },
  },
];
---

<Base title="Work | Amaljith Kuttamath" description="Research in LLM trust and safety, production AI systems, and technical writing on mechanistic interpretability.">

  <div class="page-header animate-in">
    <h1>Work</h1>
  </div>

  <!-- ── Spotlight ── -->
  <section class="spotlight animate-in animate-in-delay-1">
    {spotlight.map((item) => (
      <div class="spotlight-card">
        <div class="spotlight-head">
          <h2>{item.title}</h2>
          {item.status && <span class="status-badge">{item.status}</span>}
          {item.journal && (
            <span class="citation">{item.journal}, {item.year}</span>
          )}
        </div>
        <p>{item.desc}</p>
        <div class="spotlight-footer">
          <div class="tags">
            {item.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
          {item.links && (
            <div class="work-links">
              {item.links.map((link) => (
                <a href={link.url} class="work-link" target="_blank" rel="noopener noreferrer">{link.label} &rarr;</a>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </section>

  <!-- ── Interactive ── -->
  <section class="animate-in animate-in-delay-1">
    <div class="section-label">Interactive</div>
    <a href="/playground" class="playground-card">
      <div class="playground-head">
        <h3>microGPT Playground</h3>
        <span class="playground-cta">try it live &rarr;</span>
      </div>
      <p>Train a transformer in your browser. Watch attention patterns, embeddings, and loss evolve in real time. Same architecture as frontier models, small enough to inspect every component.</p>
      <div class="tags">
        <span class="tag">interactive</span>
        <span class="tag">d3.js</span>
        <span class="tag">transformers</span>
      </div>
    </a>
  </section>

  <!-- ── Writing ── -->
  {posts.length > 0 && (
    <section class="animate-in animate-in-delay-2">
      <div class="section-label">Writing</div>
      <div class="writing-list">
        {posts.map((post) => (
          <a href={post.url} class="writing-item">
            <h3>{post.frontmatter.title}</h3>
            <time class="mono">{formatDate(post.frontmatter.date)}</time>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── Shipped ── -->
  <section class="animate-in animate-in-delay-2">
    <div class="section-label">Shipped</div>
    <div class="proof-grid">
      {proof.map((item) => (
        <details class="proof-card" id={item.title.toLowerCase().replace(/\s+/g, '-')}>
          <summary>
            <span class="proof-metric">{item.metric}</span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <div class="tags">
              {item.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </summary>
          <div class="work-item-details">
            <div class="detail-row">
              <span class="detail-label">Problem</span>
              <span class="detail-value">{item.details.problem}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Approach</span>
              <span class="detail-value">{item.details.approach}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Stack</span>
              <span class="detail-value detail-stack">{item.details.stack}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Outcome</span>
              <span class="detail-value">{item.details.outcome}</span>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

</Base>

<style>
  /* ── Section labels ── */
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    margin-bottom: var(--space-md);
    margin-top: var(--space-xl);
  }

  /* ── Spotlight ── */
  .spotlight {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .spotlight-card {
    padding: var(--space-lg);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    background: var(--bg-elevated);
  }

  .spotlight-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .spotlight-card h2 {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .status-badge {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-color);
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--accent-color);
    border-radius: 100px;
  }

  .citation {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-small);
    color: var(--fg-muted);
  }

  .spotlight-card p {
    font-size: var(--text-body);
    color: var(--fg-muted);
    line-height: 1.7;
    margin: 0.25rem 0 var(--space-md);
    max-width: 580px;
  }

  .spotlight-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* ── Playground card ── */
  .playground-card {
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .playground-card:hover {
    border-color: var(--accent-color);
    background: var(--bg-elevated);
  }

  .playground-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .playground-card h3 {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
    transition: color var(--duration) var(--ease);
  }

  .playground-card:hover h3 {
    color: var(--accent-color);
  }

  .playground-cta {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
    white-space: nowrap;
  }

  .playground-card p {
    font-size: var(--text-body);
    color: var(--fg-muted);
    line-height: 1.7;
    margin: 0 0 var(--space-md);
    max-width: 580px;
  }

  /* ── Writing ── */
  .writing-list {
    display: flex;
    flex-direction: column;
  }

  .writing-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--fg-faint);
    text-decoration: none;
    color: var(--fg);
    transition: color var(--duration) var(--ease);
  }

  .writing-item:first-child {
    border-top: 1px solid var(--fg-faint);
  }

  .writing-item:hover {
    color: var(--accent-color);
  }

  .writing-item h3 {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 500;
    margin: 0;
  }

  /* ── Proof grid ── */
  .proof-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .proof-card {
    padding: var(--space-md);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    cursor: pointer;
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .proof-card:hover {
    border-color: var(--accent-color);
    background: var(--bg-elevated);
  }

  .proof-card summary {
    list-style: none;
  }

  .proof-card summary::-webkit-details-marker {
    display: none;
  }

  .proof-metric {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.375rem;
  }

  .proof-card h3 {
    font-family: var(--font-sans);
    font-size: var(--text-item-title);
    font-weight: 500;
    margin: 0 0 0.25rem;
    transition: color var(--duration) var(--ease);
  }

  .proof-card:hover h3 {
    color: var(--accent-color);
  }

  .proof-card p {
    font-size: var(--text-small);
    color: var(--fg-muted);
    margin: 0 0 0.5rem;
    line-height: 1.55;
  }

  .proof-card .work-item-details {
    border-left: 1px solid var(--fg-faint);
    margin-top: var(--space-md);
    padding-left: 1rem;
    padding-bottom: 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    animation: fadeIn 0.2s var(--ease);
  }

  /* ── Links ── */
  .work-links {
    display: flex;
    gap: 0.75rem;
  }

  .work-link {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
    text-decoration: none;
    text-transform: lowercase;
    transition: color var(--duration) var(--ease);
  }

  .work-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .proof-grid {
      grid-template-columns: 1fr;
    }

    .spotlight-head {
      flex-direction: column;
      gap: 0.25rem;
    }

    .playground-head {
      flex-direction: column;
      gap: 0.25rem;
    }

    .spotlight-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .writing-item {
      flex-direction: column;
      gap: 0.125rem;
    }
  }
</style>
