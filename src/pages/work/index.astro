---
import Base from '../../layouts/Base.astro';

const allPosts = import.meta.glob('./*.md', { eager: true }) as Record<string, any>;
const posts = Object.entries(allPosts)
  .map(([path, mod]) => ({ ...mod, url: '/work/' + path.replace('./', '').replace('.md', '') }))
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

// ── Spotlight: defines who you are right now ──
const spotlight = [
  {
    title: 'Trust Bench',
    desc: 'Open-source tool for profiling LLM trustworthiness. Extract trust signals from model internals, evaluate across safety dimensions, diagnose failures, and apply targeted improvements.',
    tags: ['AI safety', 'interpretability', 'PyTorch', 'LLM evaluation'],
    status: 'in progress',
    links: [
      { label: 'github', url: 'https://github.com/amaljithkuttamath/trust-bench' },
    ],
  },
  {
    title: 'Predicting Risk of Lung Cancer From Medical History',
    desc: 'AUC 0.82 in lung cancer risk prediction using Electronic Health Records.',
    journal: 'Quality Management in Health Care',
    year: 2025,
    tags: ['research', 'healthcare', 'machine learning'],
    links: [
      { label: 'paper', url: 'https://doi.org/10.1097/QMH.0000000000000525' },
      { label: 'pubmed', url: 'https://pubmed.ncbi.nlm.nih.gov/40197410/' },
    ],
  },
];

// ── Proof: shipped systems with hard numbers ──
const proof = [
  {
    title: 'Healthcare RAG Pipeline',
    metric: '10K+ daily queries',
    desc: 'Retrieval-augmented generation on Vertex AI for clinicians querying medical records and PubMed.',
    tags: ['RAG', 'vertex ai', 'langchain'],
    details: {
      problem: 'Clinicians need fast, accurate answers from medical records and research papers. Manual search across PubMed and internal records is slow and error-prone.',
      approach: 'Retrieval-augmented generation pipeline on Google Cloud Vertex AI. Documents are chunked, embedded with multi-modal indexing, and stored for vector retrieval. Gemini Pro generates answers grounded in retrieved context.',
      stack: 'Vertex AI, Gemini Pro, LangChain, LlamaIndex, Python',
      outcome: 'Serves oncology-specific queries with domain-aware re-ranking. Handles 10,000+ daily queries across medical records and PubMed.',
    },
  },
  {
    title: 'Medical Knowledge Graph',
    metric: '5 entity types, cross-format search',
    desc: 'Graph connecting diseases, drugs, treatments, and clinical trials with vector search.',
    tags: ['neo4j', 'elasticsearch', 'embeddings'],
    details: {
      problem: 'Medical knowledge is scattered across databases, papers, and records. Relationships between entities are lost in flat storage.',
      approach: 'Graph schema in Neo4j mapping diseases, treatments, drugs, clinical trials, and expert opinions. Elasticsearch for full-text and vector search. Multi-modal embeddings for cross-format querying.',
      stack: 'Neo4j, Elasticsearch, Python, sentence-transformers',
      outcome: 'Powers the retrieval layer of the RAG pipeline. Enables queries across text, structured data, and metadata in a single interface.',
    },
  },
  {
    title: 'LLM Fine-tuning System',
    metric: '25% lower inference cost',
    desc: 'Production fine-tuning pipeline for Qwen2.5-3B with GRPO + LoRA, deployed via vLLM.',
    tags: ['LLM', 'fine-tuning', 'vLLM'],
    details: {
      problem: 'Off-the-shelf models underperform on domain tasks. Fine-tuning at scale requires efficient training and serving infrastructure.',
      approach: '4-bit quantization with LoRA adapters for memory-efficient training. GRPO for reward-guided optimization. vLLM for high-throughput inference with auto-scaling.',
      stack: 'PyTorch, Hugging Face, LoRA, vLLM, Python',
      outcome: 'Fine-tuned 3B parameter model deployed to production, reducing inference costs by 25%.',
    },
  },
  {
    title: 'Drug Safety Sentiment Analysis',
    metric: 'early warning signals',
    desc: 'Reads medical expert opinions and flags potential safety signals for pharmaceutical products.',
    tags: ['NLP', 'classification', 'healthcare'],
    details: {
      problem: 'Pharmaceutical safety teams need to catch early warning signs in expert opinion records before adverse events escalate.',
      approach: 'Fine-tuned transformer classifiers on domain-specific medical language. Detects sentiment shifts in expert opinions per drug per condition over time.',
      stack: 'PyTorch, Hugging Face Transformers, spaCy, Python',
      outcome: 'Surfaces drugs with increasing negative sentiment for safety review. Feeds directly into existing pharmacovigilance workflows.',
    },
  },
  {
    title: 'NL-to-Insights',
    metric: '5,000+ SKUs',
    desc: 'Ask a question in plain English about your inventory, get back a chart.',
    tags: ['RAG', 'GPT', 'plotly'],
    details: {
      problem: "Warehouse managers need inventory analytics but can't write SQL. Analysts become bottlenecks for routine data questions.",
      approach: 'Natural language to SQL translation via GPT-3.5 Turbo. Queries execute against inventory and sales databases. Results render as interactive Plotly charts.',
      stack: 'GPT-3.5 Turbo, Plotly, PostgreSQL, Python, FastAPI',
      outcome: 'Used for demand forecasting across 5,000+ SKUs. Eliminated analyst dependency for standard inventory queries.',
    },
  },
  {
    title: 'EDI Pipelines',
    metric: '2TB+ processed, 50+ pipelines',
    desc: 'Data pipelines moving business data between ERP systems, warehouses, and reporting tools.',
    tags: ['azure', 'databricks', 'ETL'],
    details: {
      problem: 'Business partners exchange data via EDI, a standardized-in-theory format that varies wildly in practice.',
      approach: 'Azure Data Factory orchestrates ingestion and routing. Databricks handles transformation, schema normalization, and quality checks.',
      stack: 'Azure Data Factory, Databricks, Azure Data Lake, Python, SQL',
      outcome: 'Processed over 2TB of transaction data. Connected ERP systems, warehouses, and reporting tools into a single pipeline.',
    },
  },
  {
    title: 'Predictive Maintenance',
    metric: '90%+ accuracy, 50% less downtime',
    desc: 'Sensor data from industrial equipment, turned into early warnings before machines break down.',
    tags: ['signal processing', 'time series', 'python'],
    details: {
      problem: "Unplanned machine downtime is expensive. Sensor data exists but isn't used for proactive maintenance.",
      approach: 'Signal processing pipeline: ingest raw sensor data, clean and featurize, train models for anomaly detection and time-to-failure prediction.',
      stack: 'Python, scikit-learn, Azure Data Lake, Power BI',
      outcome: '90%+ anomaly detection accuracy. 95% time-to-failure prediction accuracy. KPI dashboards reduced machine downtime by 50%.',
    },
  },
];
---

<Base title="Work | Amaljith Kuttamath" description="Research, shipped systems, and technical writing.">

  <div class="page-header animate-in">
    <h1>Work</h1>
  </div>

  <!-- ── Spotlight ── -->
  <section class="spotlight animate-in animate-in-delay-1">
    {spotlight.map((item) => (
      <div class="spotlight-card">
        <div class="spotlight-head">
          <h2>{item.title}</h2>
          {item.status && <span class="status-badge">{item.status}</span>}
          {item.journal && (
            <span class="citation">{item.journal}, {item.year}</span>
          )}
        </div>
        <p>{item.desc}</p>
        <div class="spotlight-footer">
          <div class="tags">
            {item.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
          {item.links && (
            <div class="work-links">
              {item.links.map((link) => (
                <a href={link.url} class="work-link" target="_blank" rel="noopener noreferrer">{link.label} &rarr;</a>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </section>

  <!-- ── Interactive ── -->
  <section class="animate-in animate-in-delay-1">
    <div class="section-label">Interactive</div>
    <a href="/playground" class="playground-card">
      <div class="playground-head">
        <h3>microGPT Playground</h3>
        <span class="playground-cta">try it live &rarr;</span>
      </div>
      <p>Train a GPT in your browser. Watch attention, embeddings, and loss evolve in real time. Same architecture as ChatGPT, small enough to understand.</p>
      <div class="tags">
        <span class="tag">interactive</span>
        <span class="tag">d3.js</span>
        <span class="tag">transformers</span>
      </div>
    </a>
  </section>

  <!-- ── Writing ── -->
  {posts.length > 0 && (
    <section class="animate-in animate-in-delay-2">
      <div class="section-label">Writing</div>
      <div class="writing-list">
        {posts.map((post) => (
          <a href={post.url} class="writing-item">
            <h3>{post.frontmatter.title}</h3>
            <time class="mono">{formatDate(post.frontmatter.date)}</time>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── Shipped ── -->
  <section class="animate-in animate-in-delay-2">
    <div class="section-label">Shipped</div>
    <div class="proof-grid">
      {proof.map((item) => (
        <details class="proof-card" id={item.title.toLowerCase().replace(/\s+/g, '-')}>
          <summary>
            <span class="proof-metric">{item.metric}</span>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <div class="tags">
              {item.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </summary>
          <div class="work-item-details">
            <div class="detail-row">
              <span class="detail-label">Problem</span>
              <span class="detail-value">{item.details.problem}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Approach</span>
              <span class="detail-value">{item.details.approach}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Stack</span>
              <span class="detail-value detail-stack">{item.details.stack}</span>
            </div>
            <div class="detail-row">
              <span class="detail-label">Outcome</span>
              <span class="detail-value">{item.details.outcome}</span>
            </div>
          </div>
        </details>
      ))}
    </div>
  </section>

</Base>

<style>
  /* ── Section labels ── */
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    margin-bottom: var(--space-md);
    margin-top: var(--space-3xl);
  }

  /* ── Spotlight ── */
  .spotlight {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .spotlight-card {
    padding: var(--space-lg);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    background: var(--bg-elevated);
  }

  .spotlight-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .spotlight-card h2 {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .status-badge {
    font-family: var(--font-mono);
    font-size: var(--text-tag);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-color);
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--accent-color);
    border-radius: 100px;
  }

  .citation {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-small);
    color: var(--fg-muted);
  }

  .spotlight-card p {
    font-size: var(--text-body);
    color: var(--fg-muted);
    line-height: 1.7;
    margin: 0.25rem 0 var(--space-md);
    max-width: 580px;
  }

  .spotlight-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* ── Playground card ── */
  .playground-card {
    display: block;
    padding: var(--space-lg);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .playground-card:hover {
    border-color: var(--accent-color);
    background: var(--bg-elevated);
  }

  .playground-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .playground-card h3 {
    font-family: var(--font-serif);
    font-size: var(--text-section);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
    transition: color var(--duration) var(--ease);
  }

  .playground-card:hover h3 {
    color: var(--accent-color);
  }

  .playground-cta {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
    white-space: nowrap;
  }

  .playground-card p {
    font-size: var(--text-body);
    color: var(--fg-muted);
    line-height: 1.7;
    margin: 0 0 var(--space-md);
    max-width: 580px;
  }

  /* ── Writing ── */
  .writing-list {
    display: flex;
    flex-direction: column;
  }

  .writing-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--fg-faint);
    text-decoration: none;
    color: var(--fg);
    transition: color var(--duration) var(--ease);
  }

  .writing-item:first-child {
    border-top: 1px solid var(--fg-faint);
  }

  .writing-item:hover {
    color: var(--accent-color);
  }

  .writing-item h3 {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 500;
    margin: 0;
  }

  /* ── Proof grid ── */
  .proof-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .proof-card {
    padding: var(--space-md);
    border: 1px solid var(--fg-faint);
    border-radius: 8px;
    cursor: pointer;
    transition: border-color var(--duration) var(--ease), background var(--duration) var(--ease);
  }

  .proof-card:hover {
    border-color: var(--accent-color);
    background: var(--bg-elevated);
  }

  .proof-card summary {
    list-style: none;
  }

  .proof-card summary::-webkit-details-marker {
    display: none;
  }

  .proof-metric {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.375rem;
  }

  .proof-card h3 {
    font-family: var(--font-sans);
    font-size: var(--text-item-title);
    font-weight: 500;
    margin: 0 0 0.25rem;
    transition: color var(--duration) var(--ease);
  }

  .proof-card:hover h3 {
    color: var(--accent-color);
  }

  .proof-card p {
    font-size: var(--text-small);
    color: var(--fg-muted);
    margin: 0 0 0.5rem;
    line-height: 1.55;
  }

  .proof-card .work-item-details {
    border-left: 1px solid var(--fg-faint);
    margin-top: var(--space-md);
    padding-left: 1rem;
    padding-bottom: 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    animation: fadeIn 0.2s var(--ease);
  }

  /* ── Links ── */
  .work-links {
    display: flex;
    gap: 0.75rem;
  }

  .work-link {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    color: var(--accent-color);
    text-decoration: none;
    text-transform: lowercase;
    transition: color var(--duration) var(--ease);
  }

  .work-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .proof-grid {
      grid-template-columns: 1fr;
    }

    .spotlight-head {
      flex-direction: column;
      gap: 0.25rem;
    }

    .playground-head {
      flex-direction: column;
      gap: 0.25rem;
    }

    .spotlight-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .writing-item {
      flex-direction: column;
      gap: 0.125rem;
    }
  }
</style>
