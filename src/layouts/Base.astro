---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'AI Engineer. Building things that think.', ogImage = '/amal.jpg' } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/playground', label: 'Playground' },
  { href: '/about', label: 'About' },
];

const breadcrumbItems: { "@type": string; position: number; name: string; item: string }[] = [
  { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL('/', Astro.site).href }
];

const matchedNav = navItems.find(item =>
  item.href !== '/' && (currentPath === item.href || currentPath === item.href + '/' || currentPath.startsWith(item.href))
);

if (matchedNav) {
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": 2,
    "name": matchedNav.label,
    "item": new URL(matchedNav.href, Astro.site).href
  });

  const isSubpage = currentPath !== matchedNav.href && currentPath !== matchedNav.href + '/';
  if (isSubpage) {
    breadcrumbItems.push({
      "@type": "ListItem",
      "position": 3,
      "name": title.replace(/ \| .+$/, ''),
      "item": canonicalURL.href
    });
  }
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="author" content="Amaljith Kuttamath" />
  <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#fafaf9" media="(prefers-color-scheme: light)" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Preconnect to Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="Amaljith Kuttamath" />
  <meta property="og:image" content={ogImageURL} />

  <!-- Twitter -->
  <meta name="twitter:card" content={ogImage === '/amal.jpg' ? 'summary' : 'summary_large_image'} />
  <meta name="twitter:site" content="@amaljithkm" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="Amaljith Kuttamath" href={new URL('/rss.xml', Astro.site)} />

  <!-- JSON-LD: Person -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Amaljith Kuttamath",
    "url": "https://amaljithkuttamath.github.io",
    "jobTitle": "AI Engineer",
    "sameAs": [
      "https://github.com/amaljithkuttamath",
      "https://linkedin.com/in/amaljithk",
      "https://x.com/amaljithkm"
    ]
  })} />

  <!-- JSON-LD: WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Amaljith Kuttamath",
    "url": "https://amaljithkuttamath.github.io",
    "description": "AI Engineer. Building things that think.",
    "author": {
      "@type": "Person",
      "name": "Amaljith Kuttamath"
    }
  })} />

  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbItems
  })} />

</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>

  <div class="container">
    <nav>
      <a href="/" class="logo" class:list={[{ active: currentPath === '/' }]} aria-label="Home">AK</a>
      <div class="nav-links">
        <a href="/" class:list={[{ active: currentPath === '/' }]}>home</a>
        <a href="/work" class:list={[{ active: currentPath.startsWith('/work') }]}>work</a>
        <a href="/playground" class:list={[{ active: currentPath === '/playground' || currentPath === '/playground/' }]}>playground</a>
        <a href="/about" class:list={[{ active: currentPath === '/about' || currentPath === '/about/' }]}>about</a>
      </div>
    </nav>

    <main id="main">
      <slot />
    </main>

    <footer>
      <div class="footer-links">
        <a href="https://github.com/amaljithkuttamath" target="_blank" rel="noopener noreferrer" aria-label="GitHub (opens in new tab)">github</a>
        <a href="https://linkedin.com/in/amaljithk" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn (opens in new tab)">linkedin</a>
        <a href="https://x.com/amaljithkm" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter (opens in new tab)">x</a>
        <a href="mailto:amaljithkuttamath@gmail.com" aria-label="Send email">email</a>
      </div>
    </footer>
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
